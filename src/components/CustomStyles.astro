---
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/dm-serif-display/400.css';
import '@fontsource/dm-mono/400.css';
import '@fontsource/dm-mono/500.css';
---

<style is:inline>
  /* ─── Civic Luminance Design System ─────────────────────────────────── */

  :root {
    /* Typography */
    --aw-font-sans: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
    --aw-font-serif: 'DM Serif Display', Georgia, serif;
    --aw-font-heading: 'DM Serif Display', Georgia, serif;
    --aw-font-mono: 'DM Mono', ui-monospace, monospace;

    /* Brand palette */
    --cl-navy-50: #eef1f5;
    --cl-navy-100: #d5dce8;
    --cl-navy-200: #aab8d1;
    --cl-navy-300: #7f94ba;
    --cl-navy-400: #5470a3;
    --cl-navy-500: #324e7a;
    --cl-navy-600: #1e3560;
    --cl-navy-700: #152649;
    --cl-navy-800: #0d1b2a;
    --cl-navy-900: #070e16;

    --cl-amber-100: #feeece;
    --cl-amber-200: #fcdb9e;
    --cl-amber-300: #fac76d;
    --cl-amber-400: #f8b43c;
    --cl-amber-500: #e8a020;
    --cl-amber-600: #c4841a;
    --cl-amber-700: #9a6714;

    --cl-teal-100: #cbf2ee;
    --cl-teal-300: #63d8cb;
    --cl-teal-400: #30cbba;
    --cl-teal-500: #0e9f8e;
    --cl-teal-600: #0b8275;

    --cl-stone-50: #fdfcfa;
    --cl-stone-100: #f5f1eb;
    --cl-stone-200: #ebe5d8;
    --cl-stone-300: #d9d0c0;

    /* Semantic — light mode */
    --aw-color-primary: #0d1b2a;
    --aw-color-secondary: #1e3560;
    --aw-color-accent: #e8a020;
    --aw-color-accent-2: #0e9f8e;

    --aw-color-text-heading: #0d1b2a;
    --aw-color-text-default: #1f2937;
    --aw-color-text-muted: #6b7280;
    --aw-color-text-accent: #c4841a;

    --aw-color-bg-page: #f5f1eb;
    --aw-color-bg-raised: #ffffff;
    --aw-color-bg-overlay: #ebe5d8;
    --aw-color-bg-page-dark: #070e16;

    --aw-border-subtle: #d9d0c0;
    --aw-border-default: #d1d5db;
    --aw-border-strong: #9ca3af;

    /* Shadows */
    --aw-shadow-sm: 0 1px 2px 0 rgba(13, 27, 42, 0.08);
    --aw-shadow-md: 0 4px 16px 0 rgba(13, 27, 42, 0.12);
    --aw-shadow-lg: 0 8px 32px 0 rgba(13, 27, 42, 0.14);
    --aw-shadow-amber-glow: 0 0 32px 0 rgba(232, 160, 32, 0.2);
    --aw-shadow-teal-glow: 0 0 32px 0 rgba(14, 159, 142, 0.2);

    ::selection {
      background-color: #fcdb9e;
      color: #0d1b2a;
    }
  }

  .dark {
    --aw-color-primary: #f8b43c;
    --aw-color-secondary: #30cbba;
    --aw-color-accent: #5470a3;
    --aw-color-accent-2: #0e9f8e;

    --aw-color-text-heading: #f5f1eb;
    --aw-color-text-default: #d9d0c0;
    --aw-color-text-muted: #9ca3af;
    --aw-color-text-accent: #f8b43c;

    --aw-color-bg-page: #070e16;
    --aw-color-bg-raised: #0d1b2a;
    --aw-color-bg-overlay: #152649;

    --aw-border-subtle: rgba(245, 241, 235, 0.08);
    --aw-border-default: rgba(245, 241, 235, 0.14);
    --aw-border-strong: rgba(245, 241, 235, 0.24);

    ::selection {
      background-color: #e8a020;
      color: #070e16;
    }
  }
</style>
