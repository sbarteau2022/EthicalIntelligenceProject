---
// Shared auth modal + window.EIH global for hub pages that talk to the worker.
// Uses the SAME token key as /elle and /landing/product, so one sign-in works
// across every surface of the site.
//
// OAUTH ONLY, DELIBERATELY: no email/password form. "Sign in" and "sign up"
// are the same Google button — the worker's /api/elle-oauth upserts by email,
// so someone who already has a password-based account just signs in with
// Google using the same address and lands on their existing row.
//
// Needs PUBLIC_GOOGLE_CLIENT_ID set at build time (Google Cloud Console →
// OAuth client ID, type "Web application") AND the elle-worker secret
// GOOGLE_CLIENT_ID set to the same value (wrangler secret put GOOGLE_CLIENT_ID)
// — the worker verifies the credential's `aud` against it. Until both are
// set, the modal shows a "temporarily unavailable" message instead of a
// broken button.
const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? '';
---

<div class="eih-auth" id="eih-auth" data-client-id={GOOGLE_CLIENT_ID}>
  <div class="card">
    <button class="x" id="eih-auth-x" aria-label="Close">×</button>
    <h2 id="eih-auth-title">Sign in</h2>
    <div class="h-sub">One free account for Elle, your Optimus journal, and the analysis engine.</div>
    <div class="google-btn-wrap" id="eih-google-btn"></div>
    <p class="unavailable" id="eih-auth-unavailable" style="display:none">
      Sign-in is being set up — check back shortly.
    </p>
    <div class="err" id="eih-auth-err"></div>
  </div>
</div>

<script is:inline>
  (function () {
    if (window.EIH) return;

    const WORKER = 'https://elle-worker.sbarteau2022.workers.dev';
    const TOKEN_KEY = 'eip_elle_jwt';

    let token = null;
    try {
      token = localStorage.getItem(TOKEN_KEY) || null;
    } catch {
      /* ignore */
    }

    const authEl = document.getElementById('eih-auth');
    const errEl = document.getElementById('eih-auth-err');
    const titleEl = document.getElementById('eih-auth-title');
    const unavailableEl = document.getElementById('eih-auth-unavailable');
    const googleBtnEl = document.getElementById('eih-google-btn');
    const CLIENT_ID = authEl.dataset.clientId || '';
    let onAuthed = null;

    function emit() {
      document.dispatchEvent(new CustomEvent('eih:auth', { detail: { token: token } }));
      const acct = document.getElementById('eih-acct');
      if (acct) acct.textContent = token ? 'Sign out' : 'Sign in';
    }
    function openAuth(startMode, cb) {
      titleEl.textContent = startMode === 'signup' ? 'Create your free account' : 'Sign in';
      errEl.textContent = '';
      onAuthed = cb || null;
      authEl.classList.add('show');
    }
    function closeAuth() {
      authEl.classList.remove('show');
    }
    function logout() {
      token = null;
      try {
        localStorage.removeItem(TOKEN_KEY);
      } catch {
        /* ignore */
      }
      emit();
    }
    function onGoogleCredential(response) {
      errEl.textContent = '';
      fetch(WORKER + '/api/elle-oauth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ credential: response.credential }),
      })
        .then(function (r) {
          return r.json().then(function (d) {
            return { ok: r.ok, status: r.status, d: d };
          });
        })
        .then(function (res) {
          if (!res.ok || !res.d.access_token) {
            errEl.textContent = res.d.error || 'Google sign-in failed (' + res.status + ')';
            return;
          }
          token = res.d.access_token;
          try {
            localStorage.setItem(TOKEN_KEY, token);
          } catch {
            /* ignore */
          }
          closeAuth();
          emit();
          if (onAuthed) onAuthed();
        })
        .catch(function () {
          errEl.textContent = 'Connection failed. Try again.';
        });
    }
    function initGoogle() {
      if (!CLIENT_ID) {
        unavailableEl.style.display = 'block';
        return;
      }
      const s = document.createElement('script');
      s.src = 'https://accounts.google.com/gsi/client';
      s.async = true;
      s.defer = true;
      s.onload = function () {
        try {
          window.google.accounts.id.initialize({ client_id: CLIENT_ID, callback: onGoogleCredential });
          window.google.accounts.id.renderButton(googleBtnEl, {
            theme: 'filled_black',
            size: 'large',
            shape: 'pill',
            text: 'continue_with',
            width: 280,
          });
        } catch {
          unavailableEl.style.display = 'block';
        }
      };
      s.onerror = function () {
        unavailableEl.style.display = 'block';
      };
      document.head.appendChild(s);
    }
    initGoogle();

    document.getElementById('eih-auth-x').addEventListener('click', closeAuth);
    authEl.addEventListener('click', function (e) {
      if (e.target === authEl) closeAuth();
    });

    window.EIH = {
      getToken: function () {
        return token;
      },
      openAuth: openAuth,
      logout: logout,
      // Authenticated JSON POST to the worker. Resolves {ok, status, d}.
      fetch: function (path, payload) {
        return fetch(WORKER + path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
          body: JSON.stringify(payload || {}),
        }).then(function (r) {
          return r
            .json()
            .catch(function () {
              return {};
            })
            .then(function (d) {
              return { ok: r.ok, status: r.status, d: d };
            });
        });
      },
    };

    document.addEventListener('DOMContentLoaded', function () {
      const acct = document.getElementById('eih-acct');
      if (acct) {
        acct.textContent = token ? 'Sign out' : 'Sign in';
        acct.addEventListener('click', function (e) {
          e.preventDefault();
          if (token) logout();
          else openAuth('signin');
        });
      }
      emit();
    });
  })();
</script>
