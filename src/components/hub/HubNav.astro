---
// Sticky hub nav shared by all hub pages. `current` highlights the active tab;
// `showAccount` renders the sign-in/out link wired up by HubAuth's script.
import { HUB_TABS } from '~/hub';

export interface Props {
  current?: string;
  showAccount?: boolean;
}
const { current = '', showAccount = false } = Astro.props;
---

<nav class="hub-nav">
  <svg class="mark" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="7" y="7.5" width="1.5" height="13" rx=".75" fill="#C9A84C"></rect>
    <rect x="7" y="7.5" width="11.5" height="1.5" rx=".75" fill="#C9A84C"></rect>
    <rect x="7" y="13.25" width="8" height="1.25" rx=".6" fill="#C9A84C" opacity=".6"></rect>
    <rect x="7" y="19" width="11.5" height="1.5" rx=".75" fill="#C9A84C"></rect>
    <circle cx="21.5" cy="8.75" r="2" fill="#E8CC88"></circle>
  </svg>
  <a href="/">
    <div class="word">The Ethical Intelligence Project</div>
    <div class="sub">Powered by Elle AI</div>
  </a>
  <div class="hub-links">
    {
      HUB_TABS.map((tab) => (
        <a href={tab.href} class={current === tab.href ? 'on' : ''}>
          {tab.text}
        </a>
      ))
    }
    {
      showAccount && (
        <a href="#" class="acct" id="eih-acct">
          Sign in
        </a>
      )
    }
    <a href="/elle" class="pill">Talk to Elle →</a>
  </div>
</nav>
