---
// Hub footer: social/publication icon row + site links. Icon glyphs are inline
// mono-color SVGs so the footer needs no icon library and inherits currentColor.
import { SOCIALS } from '~/hub';

const ICONS: Record<string, string> = {
  // Substack — the three stacked bars
  substack:
    '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M4 3h16v2.4H4zM4 7.8h16v2.4H4zM4 12.6h16V21l-8-4.2L4 21z"/></svg>',
  facebook:
    '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M13.5 21v-8.2h2.8l.4-3.2h-3.2V7.5c0-.9.3-1.6 1.6-1.6h1.7V3.1c-.3 0-1.3-.1-2.5-.1-2.5 0-4.2 1.5-4.2 4.3v2.3H7.3v3.2h2.8V21h3.4z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M4.98 3.5A2 2 0 1 1 5 7.48a2 2 0 0 1-.02-3.98zM3.5 9h3v11.5h-3V9zm5.5 0h2.9v1.6h.04c.4-.76 1.39-1.56 2.86-1.56 3.06 0 3.7 2.01 3.7 4.63v6.83h-3v-6.05c0-1.44-.03-3.3-2.01-3.3-2.01 0-2.32 1.57-2.32 3.2v6.15H9V9z"/></svg>',
  medium:
    '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><circle cx="7" cy="12" r="4.5"/><ellipse cx="16.5" cy="12" rx="2.2" ry="4.2"/><ellipse cx="21" cy="12" rx="1" ry="3.8"/></svg>',
  philarchive:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><text x="12" y="17" text-anchor="middle" font-family="Georgia, serif" font-size="16" fill="currentColor">φ</text></svg>',
  zenodo:
    '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><text x="12" y="17" text-anchor="middle" font-family="Georgia, serif" font-size="15" font-weight="bold" fill="currentColor">Z</text></svg>',
  ssrn: '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><text x="12" y="15.5" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" font-weight="bold" letter-spacing="0.5" fill="currentColor">SSRN</text></svg>',
};
---

<footer class="hub-footer">
  <div class="foot-links">
    <a href="/optimus">Optimus</a>
    <a href="/engine">Analysis Engine</a>
    <a href="/business">Small Business</a>
    <a href="/learn">Learn</a>
    <a href="/observer">The Observer</a>
    <a href="/elle">Talk to Elle</a>
    <a href="/pricing">Pricing</a>
    <a href="/contact">Contact</a>
  </div>
  <div class="socials">
    {
      SOCIALS.map((s) => (
        <a href={s.href} target="_blank" rel="noreferrer" aria-label={s.name} title={s.name} set:html={ICONS[s.icon]} />
      ))
    }
  </div>
  <div class="foot-note">
    © 2026 The Ethical Intelligence Project · Powered by Elle AI · Hermann, Missouri · Co-authored with Claude
    (Anthropic)
  </div>
</footer>

<script is:inline>
  // Scroll-reveal engine for every hub page: elements with .rv get .in when
  // they enter the viewport (staggered via the .stagger helper / --d custom
  // property). Runs once per element; respects prefers-reduced-motion.
  (function () {
    if (window.__eihFx) return;
    window.__eihFx = true;
    const els = document.querySelectorAll('.eih .rv');
    if (!els.length) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(function (el) {
        el.classList.add('in');
      });
      return;
    }
    const io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
    );
    els.forEach(function (el) {
      io.observe(el);
    });
  })();
</script>
