    <!-- AUTH MODAL -->
    <div id="op-auth">
      <div class="card">
        <button class="x" id="op-auth-x" aria-label="Close">×</button>
        <h2 id="op-auth-title">Sign in</h2>
        <div class="h-sub" id="op-auth-sub">One account for Elle, your Optimus journal, and everything below.</div>
        <label>Email</label>
        <input id="op-email" type="email" autocomplete="email" placeholder="you@example.com" />
        <label>Password</label>
        <input id="op-pw" type="password" autocomplete="current-password" placeholder="••••••••" />
        <div class="err" id="op-auth-err"></div>
        <button class="primary" id="op-auth-go">Sign in</button>
        <div class="toggle" id="op-auth-toggle">New here? <b>Create an account</b></div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (window.__opInit) return;
      window.__opInit = true;

      const WORKER = 'https://elle-worker.sbarteau2022.workers.dev';
      const TOKEN_KEY = 'eip_elle_jwt';

      let token = null;
      try {
        token = localStorage.getItem(TOKEN_KEY) || null;
      } catch {
        /* ignore */
      }

      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
      }
      function fmt(s) {
        return esc(s)
          .split(/\n\n+/)
          .map(function (p) {
            return '<p>' + p.replace(/\n/g, '<br>') + '</p>';
          })
          .join('');
      }
      function authedFetch(path, payload) {
        return fetch(WORKER + path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
          body: JSON.stringify(payload || {}),
        }).then(function (r) {
          return r.json().then(function (d) {
            return { ok: r.ok, status: r.status, d: d };
          });
        });
      }

      // ── auth modal ──────────────────────────────────────────
      const authEl = document.getElementById('op-auth');
      const emailEl = document.getElementById('op-email');
      const pwEl = document.getElementById('op-pw');
      const errEl = document.getElementById('op-auth-err');
      const goEl = document.getElementById('op-auth-go');
      const titleEl = document.getElementById('op-auth-title');
      const toggleEl = document.getElementById('op-auth-toggle');
      let mode = 'signin';
      let onAuthed = null;

      function setMode(m) {
        mode = m;
        if (m === 'signup') {
          titleEl.textContent = 'Create your account';
          goEl.textContent = 'Create account';
          toggleEl.innerHTML = 'Already have an account? <b>Sign in</b>';
          pwEl.setAttribute('autocomplete', 'new-password');
        } else {
          titleEl.textContent = 'Sign in';
          goEl.textContent = 'Sign in';
          toggleEl.innerHTML = 'New here? <b>Create an account</b>';
          pwEl.setAttribute('autocomplete', 'current-password');
        }
      }
      function openAuth(startMode, cb) {
        setMode(startMode || 'signin');
        errEl.textContent = '';
        onAuthed = cb || null;
        authEl.classList.add('show');
        setTimeout(function () {
          emailEl.focus();
        }, 60);
      }
      function closeAuth() {
        authEl.classList.remove('show');
      }
      function doAuth() {
        const email = emailEl.value.trim(),
          pw = pwEl.value;
        if (!email || !pw) {
          errEl.textContent = 'Email and password required.';
          return;
        }
        goEl.disabled = true;
        errEl.textContent = '';
        fetch(WORKER + '/api/elle-auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: mode === 'signup' ? 'signup' : 'login', email: email, password: pw }),
        })
          .then(function (r) {
            return r.json().then(function (d) {
              return { ok: r.ok, status: r.status, d: d };
            });
          })
          .then(function (res) {
            if (!res.ok || !res.d.access_token) {
              errEl.textContent = res.d.error || 'Failed (' + res.status + ')';
              return;
            }
            token = res.d.access_token;
            try {
              localStorage.setItem(TOKEN_KEY, token);
            } catch {
              /* ignore */
            }
            closeAuth();
            refreshGates();
            if (onAuthed) onAuthed();
          })
          .catch(function () {
            errEl.textContent = 'Connection failed. Try again.';
          })
          .finally(function () {
            goEl.disabled = false;
          });
      }
      document.getElementById('op-auth-x').addEventListener('click', closeAuth);
      goEl.addEventListener('click', doAuth);
      pwEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') doAuth();
      });
      toggleEl.addEventListener('click', function (e) {
        if (e.target.tagName === 'B') setMode(mode === 'signup' ? 'signin' : 'signup');
      });
      authEl.addEventListener('click', function (e) {
        if (e.target === authEl) closeAuth();
      });
      document.getElementById('op-hero-signup').addEventListener('click', function () {
        openAuth('signup');
      });
      document.getElementById('op-pricing-signup').addEventListener('click', function () {
        openAuth('signup');
      });
      document.getElementById('op-lib-signin').addEventListener('click', function () {
        openAuth('signin', loadLibrary);
      });
      document.getElementById('op-eng-signin').addEventListener('click', function () {
        openAuth('signin', refreshGates);
      });

      function refreshGates() {
        const signedIn = !!token;
        document.getElementById('op-lib-gate').style.display = signedIn ? 'none' : 'block';
        document.getElementById('op-lib-body').style.display = signedIn ? 'block' : 'none';
        document.getElementById('op-eng-gate').style.display = signedIn ? 'none' : 'block';
        document.getElementById('op-eng-body').style.display = signedIn ? 'block' : 'none';
        const pill = document.getElementById('op-account-pill');
        if (signedIn) pill.textContent = 'Open Elle →';
        if (signedIn) loadLibrary();
      }

      // ── tabs ────────────────────────────────────────────────
      document.querySelectorAll('.tab-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.tab-btn').forEach(function (b) {
            b.classList.remove('on');
          });
          document.querySelectorAll('.panel').forEach(function (p) {
            p.classList.remove('on');
          });
          btn.classList.add('on');
          document.getElementById('op-panel-' + btn.dataset.tab).classList.add('on');
        });
      });

      // ── manuscript library ───────────────────────────────────
      let libLoaded = false;
      const libList = document.getElementById('op-lib-list');
      const libReader = document.getElementById('op-lib-reader');
      const libQ = document.getElementById('op-lib-q');
      const libSeries = document.getElementById('op-lib-series');

      function renderPapers(papers) {
        if (!papers || !papers.length) {
          libList.innerHTML = '<div class="empty-note">No papers found.</div>';
          return;
        }
        libList.innerHTML = papers
          .map(function (p) {
            return (
              '<div class="lib-item" data-id="' +
              esc(p.id) +
              '"><span class="t">' +
              esc(p.title) +
              '</span><span class="s">' +
              esc(p.series || 'unsorted') +
              '</span></div>'
            );
          })
          .join('');
        libList.querySelectorAll('.lib-item').forEach(function (el) {
          el.addEventListener('click', function () {
            libList.querySelectorAll('.lib-item').forEach(function (x) {
              x.classList.remove('sel');
            });
            el.classList.add('sel');
            openPaper(el.dataset.id);
          });
        });
      }

      function openPaper(id) {
        libReader.innerHTML = '<div class="empty-note">Loading…</div>';
        authedFetch('/api/corpus-paper', { id: id }).then(function (res) {
          if (!res.ok || !res.d.paper) {
            libReader.innerHTML = '<div class="empty-note">Could not open that paper.</div>';
            return;
          }
          const p = res.d.paper;
          libReader.innerHTML =
            '<div class="r-title">' +
            esc(p.title) +
            '</div><div class="r-meta">' +
            esc(p.series || 'unsorted') +
            (p.word_count ? ' · ' + esc(p.word_count) + ' words' : '') +
            '</div>' +
            (p.abstract ? '<p><strong>' + esc(p.abstract) + '</strong></p>' : '') +
            fmt(p.full_text || '(no text)');
        });
      }

      function loadPapers() {
        libList.innerHTML = '<div class="empty-note">Loading…</div>';
        authedFetch('/api/corpus-papers', {
          q: libQ.value.trim() || undefined,
          series: libSeries.value || undefined,
          limit: 200,
        }).then(function (res) {
          if (!res.ok) {
            libList.innerHTML =
              '<div class="empty-note">Sign-in required, or the library is unavailable right now.</div>';
            return;
          }
          renderPapers(res.d.papers);
        });
      }

      function loadLibrary() {
        if (!token) return;
        if (!libLoaded) {
          libLoaded = true;
          authedFetch('/api/corpus-series', {}).then(function (res) {
            if (res.ok && res.d.series) {
              res.d.series.forEach(function (s) {
                const o = document.createElement('option');
                o.value = s.series;
                o.textContent = s.series + ' (' + s.count + ')';
                libSeries.appendChild(o);
              });
            }
          });
        }
        loadPapers();
      }
      let qTimer;
      libQ.addEventListener('input', function () {
        clearTimeout(qTimer);
        qTimer = setTimeout(loadPapers, 350);
      });
      libSeries.addEventListener('change', loadPapers);

      // ── structural analysis engine ───────────────────────────
      const engDirection = document.getElementById('op-eng-direction');
      const engRun = document.getElementById('op-eng-run');
      const engStatus = document.getElementById('op-eng-status');
      const engResults = document.getElementById('op-eng-results');

      function axisCard(axis) {
        const data = axis.data || {};
        let main = '';
        const keys = Object.keys(data);
        for (let i = 0; i < keys.length; i++) {
          const v = data[keys[i]];
          if (typeof v === 'string' && v.length > 25) {
            main = v;
            break;
          }
        }
        let lists = '';
        keys.forEach(function (k) {
          const v = data[k];
          if (Array.isArray(v) && v.length) {
            lists +=
              '<ul>' +
              v
                .slice(0, 5)
                .map(function (item) {
                  return '<li>' + esc(typeof item === 'string' ? item : JSON.stringify(item)) + '</li>';
                })
                .join('') +
              '</ul>';
          }
        });
        return (
          '<div class="axis-card"><div class="lbl">' +
          esc(axis.label) +
          '</div>' +
          (main ? '<p>' + esc(main) + '</p>' : '') +
          lists +
          '</div>'
        );
      }

      function renderFalcon(d) {
        let html = '';
        if (d.tier1 && d.tier1.length) {
          html += '<div class="axis-tier-label">Tier 1 · Material Ground</div><div class="axis-grid">';
          html += d.tier1.map(axisCard).join('');
          html += '</div>';
        }
        if (d.tier2 && d.tier2.length) {
          html += '<div class="axis-tier-label">Tier 2 · Observer Reading</div><div class="axis-grid">';
          html += d.tier2.map(axisCard).join('');
          html += '</div>';
        }
        if (d.validation) {
          html +=
            '<div class="axis-tier-label">Tier 3 · Validation (self-check)</div><div class="axis-card">' +
            (d.validation.type6_check ? '<p>' + esc(d.validation.type6_check) + '</p>' : '') +
            (d.validation.drift_check ? '<p>' + esc(d.validation.drift_check) + '</p>' : '') +
            '</div>';
        }
        if (d.rupture) {
          html +=
            '<div class="rupture-box"><div class="tag">The Rupture — what this all points to</div>' +
            (d.rupture.rupture ? '<h3>' + esc(d.rupture.rupture) + '</h3>' : '') +
            (d.rupture.what_exists_after ? '<p>' + esc(d.rupture.what_exists_after) + '</p>' : '') +
            (d.rupture.first_thing_to_build
              ? '<p><strong>First thing to build:</strong> ' + esc(d.rupture.first_thing_to_build) + '</p>'
              : '') +
            '</div>';
        }
        engResults.innerHTML = html || '<div class="empty-note">No result.</div>';
      }

      engRun.addEventListener('click', function () {
        const direction = engDirection.value.trim();
        if (!direction || !token) return;
        engRun.disabled = true;
        engResults.classList.remove('on');
        engStatus.classList.add('on');
        authedFetch('/api/falcon', { action: 'run', direction: direction })
          .then(function (res) {
            engStatus.classList.remove('on');
            if (!res.ok) {
              engResults.innerHTML =
                '<div class="empty-note">' +
                esc(res.d.error || 'Could not complete the analysis. Try again.') +
                '</div>';
              engResults.classList.add('on');
              return;
            }
            renderFalcon(res.d);
            engResults.classList.add('on');
          })
          .catch(function () {
            engStatus.classList.remove('on');
            engResults.innerHTML = '<div class="empty-note">Connection failed. Try again.</div>';
            engResults.classList.add('on');
          })
          .finally(function () {
            engRun.disabled = false;
          });
      });

      refreshGates();
    })();
  </script>
</Layout>
