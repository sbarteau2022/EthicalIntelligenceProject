---
// ============================================================
// OPTIMUS & ELLE — Product Page
// Powered by Elle AI · The Ethical Intelligence Project
// Same visual language as /elle: void black, one gold, hairline
// borders. Cormorant Garamond for display, Instrument Sans for UI,
// DM Mono for anything that is data.
// ============================================================
import Layout from '~/layouts/Layout.astro';

const metadata = {
  title: 'Optimus & Elle — The Ethical Intelligence Project',
  description:
    'Every account gets an append-only Optimus journal, free access to Elle during beta, an open shelf of working papers, and a structural analysis engine you can point at anything.',
};
---

<Layout metadata={metadata}>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Instrument+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');

    #op-page {
      --void: #06060a;
      --base: #0b0b11;
      --raised: #101018;
      --float: #16161f;
      --overlay: #1c1c27;
      --gold: #c9a84c;
      --gold-l: #e8cc88;
      --gold-d: #8b6b28;
      --ivory: #f5f0e8;
      --t1: #eee8d8;
      --t2: #9a9480;
      --t3: #5a5448;
      --t4: #38342c;
      --b1: rgba(201, 168, 76, 0.18);
      --b2: rgba(255, 255, 255, 0.06);
      --b3: rgba(255, 255, 255, 0.03);
      --gold-gl: rgba(201, 168, 76, 0.12);
      --gold-gb: rgba(201, 168, 76, 0.06);
      --font-display: 'Cormorant Garamond', serif;
      --font-ui: 'Instrument Sans', system-ui, sans-serif;
      --font-mono: 'DM Mono', monospace;
      background: var(--void);
      color: var(--t1);
      font-family: var(--font-ui);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    #op-page * {
      box-sizing: border-box;
    }
    #op-page ::selection {
      background: rgba(201, 168, 76, 0.18);
    }
    #op-page a {
      color: inherit;
      text-decoration: none;
    }
    #op-page .wrap {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 24px;
    }
    #op-page section {
      padding: 88px 0;
      border-bottom: 0.5px solid var(--b2);
    }
    #op-page section:last-of-type {
      border-bottom: none;
    }
    #op-page .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
    }
    #op-page h1,
    #op-page h2,
    #op-page h3 {
      font-family: var(--font-display);
      font-weight: 500;
      color: var(--ivory);
      letter-spacing: 0.005em;
      margin: 0;
    }
    #op-page h2 {
      font-size: 2.1rem;
      margin-bottom: 20px;
    }
    #op-page h3 {
      font-size: 1.3rem;
      color: var(--gold-l);
    }
    #op-page p {
      line-height: 1.75;
      color: var(--t2);
      font-size: 1.03rem;
      margin: 0 0 1.1em;
    }
    #op-page p:last-child {
      margin-bottom: 0;
    }
    #op-page strong {
      color: var(--t1);
      font-weight: 600;
    }
    #op-page .lede {
      font-size: 1.18rem;
      color: var(--t1);
    }

    /* nav */
    #op-page .nav {
      position: sticky;
      top: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 24px;
      border-bottom: 0.5px solid var(--b2);
      background: rgba(6, 6, 10, 0.86);
      backdrop-filter: blur(10px);
    }
    #op-page .nav .mark {
      width: 26px;
      height: 26px;
      flex-shrink: 0;
    }
    #op-page .nav .word {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--gold-l);
      line-height: 1;
    }
    #op-page .nav .sub {
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--t2);
      font-family: var(--font-mono);
      margin-top: 2px;
    }
    #op-page .nav-links {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 18px;
      font-size: 0.82rem;
      color: var(--t2);
    }
    #op-page .nav-links a:hover {
      color: var(--gold-l);
    }
    #op-page .nav-links .pill {
      padding: 7px 14px;
      border-radius: 999px;
      border: 0.5px solid var(--b1);
      background: var(--gold-gb);
      color: var(--gold-l);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.02em;
    }
    #op-page .nav-links .pill:hover {
      background: var(--gold-gl);
    }
    @media (max-width: 720px) {
      #op-page .nav-links {
        display: none;
      }
    }

    /* hero */
    #op-page .hero {
      padding: 96px 0 72px;
      text-align: center;
    }
    #op-page .hero h1 {
      font-size: 3rem;
      max-width: 780px;
      margin: 0 auto 22px;
      line-height: 1.14;
    }
    #op-page .hero .lede {
      max-width: 620px;
      margin: 0 auto 34px;
    }
    #op-page .cta-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
    #op-page .btn {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      letter-spacing: 0.03em;
      padding: 13px 24px;
      border-radius: 10px;
      cursor: pointer;
      border: 0.5px solid var(--gold-d);
      background: var(--gold-gl);
      color: var(--gold-l);
      transition: 0.15s;
      display: inline-block;
    }
    #op-page .btn:hover {
      background: rgba(201, 168, 76, 0.26);
    }
    #op-page .btn.ghost {
      background: transparent;
      border-color: var(--b2);
      color: var(--t1);
    }
    #op-page .btn.ghost:hover {
      border-color: var(--b1);
      color: var(--gold-l);
    }
    #op-page .btn:disabled {
      opacity: 0.4;
      cursor: default;
    }

    /* facts strip */
    #op-page .facts {
      padding: 40px 0;
    }
    #op-page .facts .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--b2);
      border: 0.5px solid var(--b2);
      border-radius: 14px;
      overflow: hidden;
    }
    #op-page .facts .cell {
      background: var(--raised);
      padding: 22px 20px;
    }
    #op-page .facts .cell .k {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
    }
    #op-page .facts .cell p {
      font-size: 0.9rem;
      margin: 0;
    }
    @media (max-width: 720px) {
      #op-page .facts .grid {
        grid-template-columns: 1fr;
      }
    }

    /* card grid */
    #op-page .cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    #op-page .card {
      background: var(--raised);
      border: 0.5px solid var(--b2);
      border-radius: 14px;
      padding: 22px;
      transition: 0.15s;
    }
    #op-page a.card:hover {
      border-color: var(--b1);
      background: var(--float);
    }
    #op-page .card .n {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--gold);
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }
    #op-page .card h3 {
      font-size: 1.08rem;
      margin-bottom: 8px;
    }
    #op-page .card p {
      font-size: 0.88rem;
      margin: 0;
    }
    @media (max-width: 900px) {
      #op-page .cards {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 560px) {
      #op-page .cards {
        grid-template-columns: 1fr;
      }
    }

    /* two-col section */
    #op-page .split {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 56px;
      align-items: start;
    }
    @media (max-width: 860px) {
      #op-page .split {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }

    /* illustrative ledger */
    #op-page .ledger {
      background: var(--raised);
      border: 0.5px solid var(--b2);
      border-radius: 14px;
      padding: 20px;
    }
    #op-page .ledger .tag {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--t3);
      margin-bottom: 14px;
    }
    #op-page .ledger .entry {
      padding: 12px 0;
      border-top: 0.5px solid var(--b2);
    }
    #op-page .ledger .entry:first-of-type {
      border-top: none;
    }
    #op-page .ledger .entry .meta {
      display: flex;
      justify-content: space-between;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--t3);
      margin-bottom: 6px;
    }
    #op-page .ledger .entry .meta .kappa {
      color: var(--gold);
    }
    #op-page .ledger .entry p {
      font-size: 0.86rem;
      margin: 0;
    }
    #op-page .ledger .plus {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--t3);
      padding-top: 10px;
    }

    /* lever diagram */
    #op-page .lever-box {
      background: var(--raised);
      border: 0.5px solid var(--b2);
      border-radius: 14px;
      padding: 22px;
    }
    #op-page .lever-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 9px 0;
    }
    #op-page .lever-row .bar {
      flex: 1;
      height: 7px;
      border-radius: 999px;
      background: var(--b3);
      overflow: hidden;
    }
    #op-page .lever-row .bar i {
      display: block;
      height: 100%;
      background: var(--t4);
      border-radius: 999px;
    }
    #op-page .lever-row.active .bar i {
      background: linear-gradient(90deg, var(--gold-d), var(--gold-l));
    }
    #op-page .lever-row span.lbl {
      width: 128px;
      flex-shrink: 0;
      font-size: 0.8rem;
      color: var(--t3);
    }
    #op-page .lever-row.active span.lbl {
      color: var(--gold-l);
      font-weight: 600;
    }
    #op-page .lever-note {
      margin-top: 16px;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--t3);
      border-top: 0.5px solid var(--b2);
      padding-top: 14px;
    }

    /* workspace / tabs */
    #op-page .ws-head {
      text-align: center;
      margin-bottom: 34px;
    }
    #op-page .ws-head h2 {
      margin-bottom: 10px;
    }
    #op-page .ws-head p {
      max-width: 560px;
      margin: 0 auto;
    }
    #op-page .tabs {
      display: flex;
      gap: 8px;
      justify-content: center;
      margin-bottom: 26px;
    }
    #op-page .tab-btn {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
      padding: 10px 18px;
      border-radius: 999px;
      border: 0.5px solid var(--b2);
      background: transparent;
      color: var(--t2);
      cursor: pointer;
    }
    #op-page .tab-btn.on {
      border-color: var(--b1);
      background: var(--gold-gb);
      color: var(--gold-l);
    }
    #op-page .panel {
      display: none;
      background: var(--raised);
      border: 0.5px solid var(--b2);
      border-radius: 16px;
      padding: 26px;
      min-height: 320px;
    }
    #op-page .panel.on {
      display: block;
    }
    #op-page .gate {
      text-align: center;
      padding: 40px 20px;
    }
    #op-page .gate p {
      max-width: 420px;
      margin: 0 auto 20px;
    }

    /* library */
    #op-page .lib-tools {
      display: flex;
      gap: 10px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    #op-page .lib-tools input,
    #op-page .lib-tools select {
      background: var(--float);
      border: 0.5px solid var(--b2);
      border-radius: 9px;
      color: var(--t1);
      font-family: var(--font-ui);
      font-size: 0.88rem;
      padding: 9px 12px;
      outline: none;
    }
    #op-page .lib-tools input:focus,
    #op-page .lib-tools select:focus {
      border-color: rgba(201, 168, 76, 0.5);
    }
    #op-page .lib-tools input {
      flex: 1;
      min-width: 160px;
    }
    #op-page .lib-body {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 18px;
      min-height: 260px;
    }
    @media (max-width: 720px) {
      #op-page .lib-body {
        grid-template-columns: 1fr;
      }
    }
    #op-page .lib-list {
      border-right: 0.5px solid var(--b2);
      padding-right: 14px;
      max-height: 460px;
      overflow-y: auto;
    }
    #op-page .lib-item {
      padding: 10px 8px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.86rem;
    }
    #op-page .lib-item:hover,
    #op-page .lib-item.sel {
      background: var(--gold-gb);
    }
    #op-page .lib-item .t {
      color: var(--t1);
      display: block;
      margin-bottom: 3px;
    }
    #op-page .lib-item .s {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    #op-page .reader {
      max-height: 460px;
      overflow-y: auto;
      padding-right: 6px;
    }
    #op-page .reader .r-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: var(--ivory);
      margin-bottom: 4px;
    }
    #op-page .reader .r-meta {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--t3);
      margin-bottom: 16px;
    }
    #op-page .reader p {
      font-size: 0.92rem;
      color: var(--t1);
    }
    #op-page .empty-note {
      color: var(--t3);
      font-size: 0.86rem;
      text-align: center;
      padding: 60px 20px;
    }

    /* engine */
    #op-page .eng-input {
      display: flex;
      gap: 10px;
      align-items: flex-end;
      margin-bottom: 8px;
    }
    #op-page .eng-input textarea {
      flex: 1;
      resize: none;
      background: var(--float);
      border: 0.5px solid var(--b2);
      border-radius: 12px;
      color: var(--t1);
      font-family: var(--font-ui);
      font-size: 0.94rem;
      padding: 12px 14px;
      outline: none;
      min-height: 52px;
    }
    #op-page .eng-input textarea:focus {
      border-color: rgba(201, 168, 76, 0.5);
    }
    #op-page .eng-note {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--t3);
      margin-bottom: 20px;
    }
    #op-page .eng-status {
      text-align: center;
      padding: 30px;
      color: var(--t2);
      font-size: 0.9rem;
      display: none;
    }
    #op-page .eng-status.on {
      display: block;
    }
    #op-page .eng-results {
      display: none;
    }
    #op-page .eng-results.on {
      display: block;
    }
    #op-page .axis-tier-label {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 22px 0 10px;
    }
    #op-page .axis-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    @media (max-width: 720px) {
      #op-page .axis-grid {
        grid-template-columns: 1fr;
      }
    }
    #op-page .axis-card {
      background: var(--float);
      border: 0.5px solid var(--b2);
      border-radius: 10px;
      padding: 14px;
    }
    #op-page .axis-card .lbl {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.06em;
      color: var(--t2);
      margin-bottom: 6px;
    }
    #op-page .axis-card p {
      font-size: 0.84rem;
      margin: 0 0 8px;
    }
    #op-page .axis-card ul {
      margin: 0;
      padding-left: 18px;
    }
    #op-page .axis-card li {
      font-size: 0.8rem;
      color: var(--t2);
      margin-bottom: 3px;
    }
    #op-page .rupture-box {
      margin-top: 24px;
      background: var(--gold-gb);
      border: 0.5px solid var(--b1);
      border-radius: 14px;
      padding: 22px;
    }
    #op-page .rupture-box .tag {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 10px;
    }
    #op-page .rupture-box h3 {
      margin-bottom: 10px;
    }

    /* pricing */
    #op-page .pricing-box {
      background: var(--raised);
      border: 0.5px solid var(--b1);
      border-radius: 16px;
      padding: 34px;
      text-align: center;
    }
    #op-page .pricing-box .lede {
      max-width: 620px;
      margin: 0 auto 24px;
    }

    /* auth modal */
    #op-auth {
      position: fixed;
      inset: 0;
      background: rgba(6, 6, 10, 0.86);
      backdrop-filter: blur(7px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 90;
      padding: 20px;
    }
    #op-auth.show {
      display: flex;
    }
    #op-auth .card {
      width: 380px;
      max-width: 100%;
      background: var(--float);
      border: 0.5px solid var(--b1);
      border-radius: 16px;
      padding: 26px 24px;
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.7);
    }
    #op-auth h2 {
      font-size: 1.55rem;
      margin-bottom: 4px;
    }
    #op-auth .h-sub {
      font-size: 0.82rem;
      color: var(--t2);
      margin-bottom: 20px;
      line-height: 1.5;
    }
    #op-auth label {
      display: block;
      font-size: 0.64rem;
      font-family: var(--font-mono);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--t2);
      margin: 14px 0 5px;
    }
    #op-auth input {
      width: 100%;
      background: var(--raised);
      border: 0.5px solid var(--b1);
      border-radius: 9px;
      color: var(--t1);
      font-size: 0.95rem;
      font-family: var(--font-ui);
      padding: 10px 12px;
      outline: none;
    }
    #op-auth input:focus {
      border-color: rgba(201, 168, 76, 0.5);
    }
    #op-auth .err {
      color: #e08585;
      font-size: 0.78rem;
      font-family: var(--font-mono);
      margin-top: 12px;
      min-height: 1em;
    }
    #op-auth .primary {
      width: 100%;
      margin-top: 18px;
      padding: 11px;
      border-radius: 10px;
      border: 0.5px solid var(--gold-d);
      background: var(--gold-gl);
      color: var(--gold-l);
      font-size: 0.92rem;
      font-family: var(--font-ui);
      font-weight: 600;
      cursor: pointer;
    }
    #op-auth .primary:hover {
      background: rgba(201, 168, 76, 0.26);
    }
    #op-auth .toggle {
      font-size: 0.8rem;
      color: var(--t2);
      text-align: center;
      margin-top: 14px;
    }
    #op-auth .toggle b {
      color: var(--gold-l);
      cursor: pointer;
      font-weight: 600;
    }
    #op-auth .x {
      position: absolute;
      top: 18px;
      right: 20px;
      color: var(--t3);
      font-size: 1.3rem;
      cursor: pointer;
      background: none;
      border: none;
    }
    #op-auth .x:hover {
      color: var(--gold-l);
    }
    #op-auth .card {
      position: relative;
    }

    #op-page .footer-cta {
      text-align: center;
      padding: 80px 0 100px;
    }
    #op-page .footer-cta p {
      max-width: 480px;
      margin: 0 auto 26px;
    }
    #op-page .foot-note {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--t3);
      padding: 0 0 40px;
    }
  </style>

  <div id="op-page">
    <!-- NAV -->
    <nav class="nav">
      <svg class="mark" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="7" y="7.5" width="1.5" height="13" rx=".75" fill="#C9A84C"></rect>
        <rect x="7" y="7.5" width="11.5" height="1.5" rx=".75" fill="#C9A84C"></rect>
        <rect x="7" y="13.25" width="8" height="1.25" rx=".6" fill="#C9A84C" opacity=".6"></rect>
        <rect x="7" y="19" width="11.5" height="1.5" rx=".75" fill="#C9A84C"></rect>
        <circle cx="21.5" cy="8.75" r="2" fill="#E8CC88"></circle>
      </svg>
