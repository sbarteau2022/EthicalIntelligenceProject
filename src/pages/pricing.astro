---
// ============================================================
// PRICING — currently a beta sign-up page. No billing is wired up
// yet: every "Join the beta" button opens the real free sign-up
// flow (window.EIH, shared with /elle, /optimus, /engine, etc.) and
// grants the same free account every other hub page promises.
// The $10/$20 figures are the beta rates that take effect once
// billing turns on — beta members keep the rate they joined at,
// same promise already made on /business.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import HubAuth from '~/components/hub/HubAuth.astro';

const metadata = {
  title: 'Pricing — The Ethical Intelligence Project',
  description:
    'The Ethical Intelligence Project is in beta. Join free right now — no card required — and lock in beta pricing ($10/mo or $20/mo) for when billing turns on.',
};
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/pricing" showAccount={true} />

    <!-- HERO -->
    <section class="hero wrap">
      <div class="eyebrow rv">Beta · Free to join</div>
      <h1>Join free during beta. Lock in the rate.</h1>
      <p class="lede">
        We're in beta, so signing up costs nothing — no card required. The plans below are the rates that take effect
        once billing turns on, and <strong>beta members keep the rate they joined at, indefinitely</strong>. The earlier
        you join, the less you'll ever pay.
      </p>
      <div class="cta-row">
        <button class="btn" id="pricing-cta">Join the beta — free</button>
        <a href="#plans" class="btn ghost">See the beta rates</a>
      </div>
    </section>

    <!-- PLANS -->
    <section id="plans" class="wrap">
      <div class="eyebrow rv">After beta</div>
      <h2 class="rv">Two plans. Both free right now.</h2>
      <div class="cards two rv stagger">
        <div class="card">
          <div class="n">STANDARD</div>
          <h3>$10<span class="per">/mo after beta</span></h3>
          <p>Full access to the whole hub: your Optimus journal, the Analysis Engine, Atlas Edu courses, and Elle.</p>
          <ul class="plan-list">
            <li>✓ Optimus Journal</li>
            <li>✓ Analysis Engine</li>
            <li>✓ Atlas Edu courses</li>
            <li>✓ Talk to Elle</li>
          </ul>
          <button class="btn plan-cta" data-plan="standard">Join the beta — free</button>
        </div>
        <div class="card">
          <div class="n">PLUS</div>
          <h3>$20<span class="per">/mo after beta</span></h3>
          <p>Everything in Standard, plus priority support and direct input on what we build next.</p>
          <ul class="plan-list">
            <li>✓ Everything in Standard</li>
            <li>✓ Priority support</li>
            <li>✓ Direct input on the roadmap</li>
          </ul>
          <button class="btn plan-cta" data-plan="plus">Join the beta — free</button>
        </div>
      </div>
      <p class="plan-note">
        No payment is collected during beta. Pick whichever rate you want to lock in — you can change your mind later.
      </p>
    </section>

    <!-- FAQ -->
    <section id="faq" class="wrap">
      <div class="eyebrow rv">Questions</div>
      <h2 class="rv">Beta pricing FAQ</h2>
      <div class="cards rv stagger">
        <div class="card">
          <h3>Is the beta really free?</h3>
          <p>Yes. Sign up with an email and password, no card required, and you're in.</p>
        </div>
        <div class="card">
          <h3>What happens when beta ends?</h3>
          <p>
            Billing starts at whichever rate you joined at — $10/mo or $20/mo. You'll be notified before anything is
            charged.
          </p>
        </div>
        <div class="card">
          <h3>Can I switch plans later?</h3>
          <p>Yes, any time — reach out and we'll move you.</p>
        </div>
        <div class="card">
          <h3>What do I actually get?</h3>
          <p>
            One account for the whole hub: the Optimus journal, the Analysis Engine, Atlas Edu courses, and Elle
            herself.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="wrap" style="text-align:center">
      <h2 class="rv">Ready to join?</h2>
      <p style="max-width:520px;margin:0 auto 26px">It's free during beta — takes about thirty seconds.</p>
      <div class="cta-row">
        <button class="btn" id="pricing-cta-2">Join the beta — free</button>
      </div>
    </section>

    <HubFooter />
  </div>

  <HubAuth />

  <style>
    .eih .plan-list {
      list-style: none;
      margin: 16px 0 20px;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
      font-size: 0.92rem;
      color: var(--t2);
    }
    .eih .card h3 .per {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--t3);
    }
    .eih .plan-cta {
      width: 100%;
      justify-content: center;
    }
    .eih .plan-note {
      margin-top: 18px;
      font-size: 0.85rem;
      color: var(--t3);
    }
  </style>

  <script is:inline>
    (function () {
      function joinBeta() {
        if (window.EIH && window.EIH.getToken()) {
          window.location.href = '/optimus';
        } else if (window.EIH) {
          window.EIH.openAuth('signup');
        }
      }
      document.getElementById('pricing-cta').addEventListener('click', joinBeta);
      document.getElementById('pricing-cta-2').addEventListener('click', joinBeta);
      document.querySelectorAll('.plan-cta').forEach(function (btn) {
        btn.addEventListener('click', joinBeta);
      });
    })();
  </script>
</Layout>
