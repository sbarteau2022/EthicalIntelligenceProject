---
// Google OAuth callback — exchanges code for token, stores session, redirects
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>RAPID²AI — Signing in…</title>
  <style>
    body { background: #0a0e0c; color: #e8ede9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .msg { text-align: center; }
    .spinner { width: 32px; height: 32px; border: 2px solid #2a332a; border-top-color: #c9a55c;
               border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 16px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    p { color: #7a8278; font-size: 0.875rem; }
  </style>
</head>
<body>
<div class="msg">
  <div class="spinner"></div>
  <p>Verifying credentials…</p>
</div>
<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const idToken = params.get('id_token');
    const hashParams = new URLSearchParams(window.location.hash.slice(1));
    const token = idToken || hashParams.get('id_token') || hashParams.get('access_token');
    const returnTo = sessionStorage.getItem('rapidai_return') || '/coo/';

    if (token) {
      sessionStorage.setItem('rapidai_auth', token);
      sessionStorage.setItem('rapidai_authed_at', Date.now().toString());
      sessionStorage.removeItem('rapidai_return');
      window.location.replace(returnTo);
    } else {
      // Google One Tap / GSI posts credential via form POST — check for it
      const credParam = params.get('credential');
      if (credParam) {
        sessionStorage.setItem('rapidai_auth', credParam);
        sessionStorage.setItem('rapidai_authed_at', Date.now().toString());
        sessionStorage.removeItem('rapidai_return');
        window.location.replace(returnTo);
      } else {
        document.querySelector('p').textContent = 'Sign-in failed — no credentials received. Redirecting…';
        setTimeout(() => window.location.replace('/'), 2000);
      }
    }
  })();
</script>
</body>
</html>
