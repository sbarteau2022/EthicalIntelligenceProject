---
// ============================================================
// MASTER ATLAS — everything, one rendering.
//
// The Harmonic Atlas (the unified function: 21 load-bearing pillars, 19
// relational lobes, the hubless bridge fabric) and the Neural Atlas (the
// knowledge neural structure: a singularity at each pole, toroid spirals
// winding through layers of 1, 3, 5, 7 halo-bound tuples to the equator,
// where they meet their inverse and phase-lock) rendered together in ONE
// scene, nested around the same center: the singularity core and the
// unified-function vessel, seated where the Metatron's Cube would sit.
//
// A master selector switches the view — Combined · Unified function ·
// Neural map — and every structure keeps its own legend row, so any part
// can be toggled and overlaid against any other.
//
// ONE SOURCE OF TRUTH, LOCKED: positions are read verbatim from
// `harmonic-snapshot.json` and `neural-structure-snapshot.json`. The
// renderer draws them; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import harmonic from '~/data/harmonic-snapshot.json';
import neural from '~/data/neural-structure-snapshot.json';

const metadata = {
  title: 'Master Atlas — everything, one rendering',
  description:
    'The unified function and the knowledge neural structure rendered together in one 3D scene — switch between Combined, Unified function, and Neural map views, and toggle every structure independently to overlay and examine any combination.',
};

const u = harmonic.unifiedFunction;
const nm = neural.meta;
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="master-stage">
      <canvas id="master-canvas" aria-label="Rotatable 3D rendering combining the unified function and the neural map"
      ></canvas>

      <div class="master-title">
        <div class="master-eyebrow">Master Atlas</div>
        <h1>Everything, one rendering</h1>
        <p class="master-sub">
          the unified function nested inside the neural map · drag to orbit · scroll to zoom · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="master-mode" id="master-mode" role="group" aria-label="Select which structure family to view">
        <button data-mode="combined" class="on">Combined</button>
        <button data-mode="unified">Unified function</button>
        <button data-mode="neural">Neural map</button>
      </div>

      <div class="master-legend" id="master-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>

        <div class="lg-section" data-family="unified">
          <div class="lg-head">Unified function</div>
          <button class="lg-row keep" data-g="vessel">
            <span class="sw" style="--c:#b79cff"></span><b>Vessel</b> · the unified function itself — seated at the shared
            center, in the cube slot
          </button>
          <button class="lg-row" data-g="uPillars">
            <span class="sw" style="--c:#ff5c9e"></span><b>Pillars</b> · 21 · the load-bearing architecture · 5 axes × 4 +
            the core
          </button>
          <button class="lg-row" data-g="uFlower">
            <span class="sw" style="--c:#ff8a4d"></span><b>Lobes / flower</b> · 19 · the relational structure
          </button>
          <button class="lg-row" data-g="uBridges">
            <span class="sw" style="--c:#6ee87a"></span><b>Bridges</b> · hubless fabric, no privileged node
          </button>
        </div>

        <div class="lg-section" data-family="neural">
          <div class="lg-head">Neural map</div>
          <button class="lg-row" data-g="nSpirals">
            <span class="sw" style="--c:#6ea8ff"></span><b>Toroid spirals</b> · pole singularities → equator, meeting their
            inverse
          </button>
          <button class="lg-row" data-g="nTuples">
            <span class="sw" style="--c:#55e9d0"></span><b>Tuples</b> · {nm.stackLabel} = {nm.totalStations} stations · the
            7-ring shared at the lock
          </button>
          <button class="lg-row" data-g="nHalos">
            <span class="sw" style="--c:#d0a94e"></span><b>Halos</b> · one per layer + the phase-lock ring
          </button>
          <button class="lg-row" data-g="nFlowerLife">
            <span class="sw" style="--c:#e06cff"></span><b>Flower of Life</b> · one circle per tuple center at every level
          </button>
          <button class="lg-row" data-g="nLobes">
            <span class="sw" style="--c:#ffe45c"></span><b>Lemniscate lobes</b> · one per node, tangent to its counterpart
          </button>
          <button class="lg-row" data-g="nThreads">
            <span class="sw" style="--c:#3a8f82"></span><b>Shadow paths</b> · straight tuple-to-singularity binds
          </button>
          <button class="lg-row" data-g="nEnvelope">
            <span class="sw" style="--c:#7c88b8"></span><b>Emission envelope</b> · the hyperbolic hourglass, maxima at the
            poles
          </button>
        </div>

        <div class="lg-section">
          <div class="lg-head">Shared center</div>
          <button class="lg-row" data-g="singularity">
            <span class="sw" style="--c:#ffffff"></span><b>Singularity</b> · the center everything holds around
          </button>
          <button class="lg-row" data-g="ghost">
            <span class="sw" style="--c:#cdd6ff"></span><b>Metatron ghost</b> · the cube's 13-circle lattice — the shadow
            of the equilibrium
          </button>
          <button class="lg-row" data-g="equilibrium">
            <span class="sw" style="--c:#9fb6ff"></span><b>Jitterbug</b> · 12-around-1, unstable · core pulled to the shell,
            12+1 → 13
          </button>
        </div>
      </div>

      <div class="master-hud" id="master-hud">
        <div class="hud-h">Master Atlas · locked</div>
        <div class="hud-m"><span>unified · pillars / lobes</span><b>21 / 19</b></div>
        <div class="hud-m">
          <span>neural · stack</span><b>{nm.stackLabel} = {nm.totalStations}</b>
        </div>
        <div class="hud-m"><span>area φ·1/φ</span><b>{u.area_invariant.toFixed(3)}</b></div>
        <div class="hud-m"><span>free energy F</span><b>{u.free_energy.toFixed(3)}</b></div>
        <div class="hud-m">
          <span>no privileged node</span><b class="ok">{u.no_privileged_node ? 'true' : 'false'}</b>
        </div>
        <div class="hud-m"><span>obliquity θ</span><b>{harmonic.obliquity.thetaDeg.toFixed(1)}°</b></div>
        <div class="hud-m"><span>phase lock</span><b id="hud-phase">counter-rotation · synced</b></div>
        <div class="hud-m"><span>break event</span><b>spherical pulse · 1 / cycle</b></div>
        <div class="hud-src">sources: harmonic-snapshot.json · neural-structure-snapshot.json</div>
      </div>

      <noscript><div class="master-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .master-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1220 0%, #070811 70%, #05050b 100%);
    }
    #master-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #master-canvas:active {
      cursor: grabbing;
    }

    .master-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 46%;
      pointer-events: none;
      z-index: 2;
    }
    .master-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #d0a94e;
      margin-bottom: 12px;
    }
    .master-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.4vw, 2.8rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .master-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .master-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .master-mode {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: 26px;
      z-index: 3;
      display: flex;
      gap: 4px;
      background: rgba(12, 14, 24, 0.72);
      border: 1px solid rgba(208, 169, 78, 0.24);
      border-radius: 999px;
      padding: 4px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .master-mode button {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #9aa3ba;
      background: none;
      border: 0;
      border-radius: 999px;
      padding: 7px 15px;
      cursor: pointer;
      transition:
        color 0.15s ease,
        background 0.15s ease;
    }
    .master-mode button:hover {
      color: #eef1f8;
    }
    .master-mode button.on {
      color: #10131f;
      background: #d0a94e;
    }

    .master-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(12, 14, 24, 0.66);
      border: 1px solid rgba(208, 169, 78, 0.18);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 320px;
      max-height: calc(100% - 120px);
      overflow-y: auto;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
    }
    .lg-section {
      display: flex;
      flex-direction: column;
      gap: 7px;
      transition: opacity 0.2s ease;
    }
    .lg-section.dim {
      opacity: 0.3;
    }
    .lg-section.dim .lg-row.keep {
      opacity: 1;
    }
    .lg-head {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #d0a94e;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .master-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(12, 14, 24, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 250px;
    }
    .hud-h {
      color: #55e9d0;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m b.ok {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .master-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 900px) {
      .master-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .master-legend {
        top: auto;
        bottom: 84px;
        right: 16px;
        padding: 11px 12px;
        max-width: 74%;
        max-height: 44%;
      }
      .master-hud {
        display: none;
      }
      .master-mode {
        bottom: 16px;
      }
    }
  </style>

  <script type="application/json" id="harmonic-snap" set:html={JSON.stringify(harmonic)} />
  <script type="application/json" id="neural-snap" set:html={JSON.stringify(neural)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface HarmonicSnap {
      meta: { phi: number; phiInv: number; goldenWinding: number };
      architecture: { nodes: { id: number; kind: string; pos: number[] }[]; edges: number[][] };
      fabric: { edges: number[][] };
      flower: { nodes: { id: number; ring: number; pos: number[] }[]; edges: number[][] };
      vessel: { orbit: number[][]; snapshotAngleRad: number };
      obliquity: { thetaDeg: number };
    }
    interface NeuralLayer {
      k: number;
      count: number;
      radius: number;
      y: number;
      tuples: { angleDeg: number; pos: number[] }[];
      lobes: number[][][];
    }
    interface NeuralHalf {
      sign: number;
      handedness: number;
      singularity: number[];
      layers: NeuralLayer[];
      spiral: number[][];
      flower: { k: number; y: number; radius: number; centers: number[][] }[];
    }
    interface NeuralSnap {
      halves: NeuralHalf[];
      equator: {
        k: number;
        count: number;
        radius: number;
        y: number;
        tuples: { angleDeg: number; pos: number[] }[];
        lobes: number[][][];
        flower: { radius: number; centers: number[][] };
      };
      envelope: { profile: number[][] };
      lockRing: { radius: number; y: number };
      metatronGhost: { circleRadius: number; centers: number[][]; edges: number[][] };
      vectorEquilibrium: { radius: number; vertices: number[][]; edges: number[][] };
      jitterbug: {
        targets13: number[][];
        coreTargetIndex: number;
        pairing: number[];
        coreAxis: number[];
        shadowCircleR: number;
      };
      singularity: { radius: number };
    }

    const H: HarmonicSnap = JSON.parse((document.getElementById('harmonic-snap') as HTMLElement).textContent || '{}');
    const N: NeuralSnap = JSON.parse((document.getElementById('neural-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('master-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // One distinct color per structure across BOTH families.
    const COL = {
      uPillar: 0xff5c9e,
      uFlower: 0xff8a4d,
      uBridge: 0x6ee87a,
      nSpiral: 0x6ea8ff,
      nTuple: 0x55e9d0,
      nTuplePartner: 0x2fb3a0,
      nHalo: 0xd0a94e,
      nLock: 0xf2ead9,
      nFlowerLife: 0xe06cff,
      nLobe: 0xffe45c,
      nThread: 0x55e9d0,
      nEnvelope: 0x7c88b8,
      equilibrium: 0x9fb6ff,
      singularity: 0xffffff,
      vessel: 0xb79cff,
      plus: 0xff5cc8,
      minus: 0x5cd8ff,
      bond: 0xd0a94e,
      ghost: 0xcdd6ff,
    };
    const PHI = H.meta.phi,
      PHI_INV = H.meta.phiInv,
      WIND = H.meta.goldenWinding;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(3.6, 2.2, 4.2);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.6;
    controls.maxDistance = 18;
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.34;

    scene.add(new THREE.AmbientLight(0x2a3050, 1.1));
    const key = new THREE.PointLight(0xaec2ff, 40, 40);
    key.position.set(4, 6, 5);
    scene.add(key);
    const rim = new THREE.PointLight(0xd0a94e, 16, 40);
    rim.position.set(-5, -4, -4);
    scene.add(rim);

    const world = new THREE.Group();
    scene.add(world);
    const V3 = (a: number[]) => new THREE.Vector3(a[0], a[1], a[2]);

    function nodeMesh(pos: THREE.Vector3, color: number, radius: number) {
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(radius, 20, 20),
        new THREE.MeshStandardMaterial({
          color,
          emissive: color,
          emissiveIntensity: 0.7,
          roughness: 0.35,
          metalness: 0.1,
        })
      );
      mesh.position.copy(pos);
      return mesh;
    }
    function edgeLines(nodesById: Record<number, number[]>, edges: number[][], color: number, opacity: number) {
      const pts: THREE.Vector3[] = [];
      for (const [a, b] of edges) {
        pts.push(V3(nodesById[a]), V3(nodesById[b]));
      }
      return new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(pts),
        new THREE.LineBasicMaterial({ color, transparent: true, opacity })
      );
    }

    // ════ SHARED CENTER — the singularity and the vessel, common to both maps ════
    const singularity = new THREE.Group();
    world.add(singularity);
    const coreR = 0.42;
    singularity.add(
      new THREE.Mesh(
        new THREE.IcosahedronGeometry(coreR, 3),
        new THREE.MeshStandardMaterial({
          color: 0x0c1020,
          emissive: 0x1f2246,
          emissiveIntensity: 0.6,
          roughness: 0.5,
          metalness: 0.3,
        })
      )
    );
    singularity.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(coreR * 1.002, 3)),
        new THREE.LineBasicMaterial({ color: 0x5a6ba8, transparent: true, opacity: 0.4 })
      )
    );
    const glow = new THREE.Mesh(
      new THREE.SphereGeometry(coreR * 0.5, 24, 24),
      new THREE.MeshBasicMaterial({ color: COL.singularity })
    );
    singularity.add(glow);

    // the ghost Metatron's Cube — the slot the vessel occupies
    const ghost = new THREE.Group();
    world.add(ghost);
    const ghostCenters = N.metatronGhost.centers.map(([x, z]) => new THREE.Vector3(x, 0, z));
    const circleSegs = 40;
    for (const c of ghostCenters) {
      const pts: THREE.Vector3[] = [];
      for (let s = 0; s <= circleSegs; s++) {
        const a = (2 * Math.PI * s) / circleSegs;
        pts.push(
          new THREE.Vector3(
            c.x + N.metatronGhost.circleRadius * Math.cos(a),
            0,
            c.z + N.metatronGhost.circleRadius * Math.sin(a)
          )
        );
      }
      ghost.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(pts),
          new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.1 })
        )
      );
    }
    const ghostLinePts: THREE.Vector3[] = [];
    for (const [i, j] of N.metatronGhost.edges) {
      ghostLinePts.push(ghostCenters[i], ghostCenters[j]);
    }
    ghost.add(
      new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(ghostLinePts),
        new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.06 })
      )
    );

    // ── the jitterbug — the vector equilibrium is unstable, not a cage ──
    // Fuller's vector equilibrium (12 around 1) is a balance point: driven by
    // the orbital phase, the center sphere spirals outward and the shell opens
    // from the symmetric 12+1 toward the asymmetric 13-on-shell, leaving a
    // vacancy where the core was — the slot the vessel occupies. The lattice
    // shadow (plane projection) deforms with it in real time; it breathes
    // 12+1 <-> 13, so the symmetry break is reversible on screen.
    const equilibrium = new THREE.Group();
    world.add(equilibrium);
    const jb = N.jitterbug;
    const veR = N.vectorEquilibrium.radius;
    const jbShellStart = N.vectorEquilibrium.vertices.map(V3);
    const jbTargets = jb.targets13.map(V3);
    const jbShellTarget = jb.pairing.map((t: number) => jbTargets[t]);
    const jbCoreTarget = jbTargets[jb.coreTargetIndex];
    const jbEdges = N.vectorEquilibrium.edges;

    const jbNodes: THREE.Mesh[] = [];
    for (let i = 0; i < 13; i++) {
      const mesh = nodeMesh(new THREE.Vector3(0, 0, 0), COL.equilibrium, i === 12 ? 0.022 : 0.018);
      equilibrium.add(mesh);
      jbNodes.push(mesh);
    }
    const jbCurrent: THREE.Vector3[] = Array.from({ length: 13 }, () => new THREE.Vector3());

    const spokeGeo = new THREE.BufferGeometry();
    const spokePos = new Float32Array(13 * 2 * 3);
    spokeGeo.setAttribute('position', new THREE.BufferAttribute(spokePos, 3));
    equilibrium.add(
      new THREE.LineSegments(
        spokeGeo,
        new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.22 })
      )
    );

    const cageGeo = new THREE.BufferGeometry();
    const cagePos = new Float32Array(jbEdges.length * 2 * 3);
    cageGeo.setAttribute('position', new THREE.BufferAttribute(cagePos, 3));
    const cageMat = new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.45 });
    equilibrium.add(new THREE.LineSegments(cageGeo, cageMat));

    // the live lattice shadow: 13 circles on y=0 tracking the projected centers
    const SHADOW_SEGS = 40;
    const shadowCircles: { pos: Float32Array; geo: THREE.BufferGeometry }[] = [];
    for (let i = 0; i < 13; i++) {
      const pos = new Float32Array((SHADOW_SEGS + 1) * 3);
      const g = new THREE.BufferGeometry();
      g.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      equilibrium.add(
        new THREE.Line(g, new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.14 }))
      );
      shadowCircles.push({ pos, geo: g });
    }

    function jbSmooth(x: number) {
      return x * x * (3 - 2 * x);
    }
    function updateJitterbug(sRaw: number) {
      const s = jbSmooth(Math.max(0, Math.min(1, sRaw)));
      for (let i = 0; i < 13; i++) {
        const p = jbCurrent[i];
        if (i < 12) {
          p.copy(jbShellStart[i]).lerp(jbShellTarget[i], s);
          if (p.lengthSq() > 1e-9) p.setLength(veR);
        } else {
          p.set(0, 0, 0).lerp(jbCoreTarget, s); // the core, pulled from center to shell
        }
        jbNodes[i].position.copy(p);
        spokePos[i * 6 + 3] = p.x;
        spokePos[i * 6 + 4] = p.y;
        spokePos[i * 6 + 5] = p.z;
        const sc = shadowCircles[i];
        for (let k = 0; k <= SHADOW_SEGS; k++) {
          const a = (2 * Math.PI * k) / SHADOW_SEGS;
          sc.pos[k * 3] = p.x + jb.shadowCircleR * Math.cos(a);
          sc.pos[k * 3 + 1] = 0;
          sc.pos[k * 3 + 2] = p.z + jb.shadowCircleR * Math.sin(a);
        }
        sc.geo.attributes.position.needsUpdate = true;
      }
      spokeGeo.attributes.position.needsUpdate = true;
      for (let e = 0; e < jbEdges.length; e++) {
        const pa = jbCurrent[jbEdges[e][0]];
        const pb = jbCurrent[jbEdges[e][1]];
        cagePos[e * 6] = pa.x;
        cagePos[e * 6 + 1] = pa.y;
        cagePos[e * 6 + 2] = pa.z;
        cagePos[e * 6 + 3] = pb.x;
        cagePos[e * 6 + 4] = pb.y;
        cagePos[e * 6 + 5] = pb.z;
      }
      cageGeo.attributes.position.needsUpdate = true;
      cageMat.opacity = 0.45 * (1 - s) * (1 - s); // the cuboctahedral cage dissolves as the core leaves
    }
    updateJitterbug(0);

    // the break event: when the core reaches the shell (s → 1) the symmetric
    // 12+1 balance collapses and releases a spherical pulse — the emission that
    // carries the energy of the symmetry break outward through the structure
    // and decoheres the balance. It fires once per breathe cycle, at the break.
    const PULSE_MAX_R = 1.4;
    const pulseSphere = new THREE.Mesh(
      new THREE.SphereGeometry(1, 32, 24),
      new THREE.MeshBasicMaterial({
        color: 0xffe9c0,
        transparent: true,
        opacity: 0,
        side: THREE.DoubleSide,
        depthWrite: false,
      })
    );
    equilibrium.add(pulseSphere);
    const pulseWire = new THREE.LineSegments(
      new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(1, 2)),
      new THREE.LineBasicMaterial({ color: 0xffe9c0, transparent: true, opacity: 0 })
    );
    equilibrium.add(pulseWire);
    function updatePulse(ph: number) {
      const u = ((((ph * 0.5) / (2 * Math.PI)) % 1) + 1) % 1; // position in the breathe cycle
      const fired = u >= 0.5; // the break is at the peak (u = 0.5); the pulse expands after it
      pulseSphere.visible = fired;
      pulseWire.visible = fired;
      if (!fired) return;
      const t = (u - 0.5) / 0.5; // 0 at the break → 1 fully expanded
      const r = 0.02 + t * PULSE_MAX_R;
      pulseSphere.scale.setScalar(r);
      pulseWire.scale.setScalar(r);
      const fade = (1 - t) * (1 - t);
      (pulseSphere.material as THREE.MeshBasicMaterial).opacity = 0.08 * fade;
      (pulseWire.material as THREE.MeshBasicMaterial).opacity = 0.35 * fade;
    }
    updatePulse(0);

    // the vessel — the unified-function rendering, seated where the cube would be
    const vessel = new THREE.Group();
    world.add(vessel);
    const shellR = 0.66;
    vessel.add(
      new THREE.Mesh(
        new THREE.IcosahedronGeometry(shellR, 1),
        new THREE.MeshPhysicalMaterial({
          color: COL.vessel,
          transparent: true,
          opacity: 0.1,
          roughness: 0.1,
          metalness: 0,
          transmission: 0.6,
          side: THREE.DoubleSide,
        })
      )
    );
    vessel.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(shellR, 1)),
        new THREE.LineBasicMaterial({ color: COL.vessel, transparent: true, opacity: 0.32 })
      )
    );
    const orbScale = (shellR * 0.82) / PHI;
    vessel.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          H.vessel.orbit.map(([q, p]) => new THREE.Vector3(q * orbScale, p * orbScale, 0))
        ),
        new THREE.LineBasicMaterial({ color: COL.bond, transparent: true, opacity: 0.6 })
      )
    );
    const mPlus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.plus, 0.06);
    vessel.add(mPlus);
    const mMinus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.minus, 0.045);
    vessel.add(mMinus);
    const bond = new THREE.Mesh(
      new THREE.CylinderGeometry(0.012, 0.012, 1, 8),
      new THREE.MeshStandardMaterial({ color: COL.bond, emissive: COL.bond, emissiveIntensity: 0.5, roughness: 0.4 })
    );
    vessel.add(bond);

    function placeMolecule(angle: number) {
      const q = PHI * Math.cos(angle) * orbScale,
        p = PHI_INV * Math.sin(angle) * orbScale;
      mPlus.position.set(q, p, 0);
      mMinus.position.set(-q, -p, 0);
      const a = mPlus.position,
        b = mMinus.position;
      bond.position.copy(a.clone().add(b).multiplyScalar(0.5));
      bond.scale.set(1, a.distanceTo(b), 1);
      bond.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), b.clone().sub(a).normalize());
    }
    placeMolecule(H.vessel.snapshotAngleRad);

    // ════ UNIFIED FUNCTION — the harmonic architecture, tilted by its obliquity ════
    const unified = new THREE.Group();
    world.add(unified);
    unified.rotation.z = (H.obliquity.thetaDeg * Math.PI) / 180;

    const uPillars = new THREE.Group();
    unified.add(uPillars);
    const archById: Record<number, number[]> = {};
    H.architecture.nodes.forEach((n) => {
      archById[n.id] = n.pos;
    });
    H.architecture.nodes.forEach((n) =>
      uPillars.add(nodeMesh(V3(n.pos), COL.uPillar, n.kind === 'apex' ? 0.075 : 0.05))
    );
    uPillars.add(edgeLines(archById, H.architecture.edges, COL.uPillar, 0.5));

    const uBridges = new THREE.Group();
    unified.add(uBridges);
    uBridges.add(edgeLines(archById, H.fabric.edges, COL.uBridge, 0.5));

    const uFlower = new THREE.Group();
    unified.add(uFlower);
    const flowerById: Record<number, number[]> = {};
    H.flower.nodes.forEach((n) => {
      flowerById[n.id] = n.pos;
    });
    H.flower.nodes.forEach((n) => uFlower.add(nodeMesh(V3(n.pos), COL.uFlower, n.ring === 0 ? 0.07 : 0.045)));
    uFlower.add(edgeLines(flowerById, H.flower.edges, COL.uFlower, 0.42));

    // ════ NEURAL MAP — the corrected layer hierarchy ════
    // Layer 0: a singularity at each pole. A toroid spiral winds from each
    // through layers of 1, 3, 5, 7 halo-bound tuples to the equator, where it
    // meets its inverse and the two phase-lock (counter-rotation in sync).
    const neuralGrp = new THREE.Group();
    world.add(neuralGrp);

    // per-structure part registries (the halves counter-rotate, so structure
    // parts can't share one parent group)
    const nSpiralParts: THREE.Object3D[] = [];
    const nTupleParts: THREE.Object3D[] = [];
    const nHaloParts: THREE.Object3D[] = [];
    const nFlowerParts: THREE.Object3D[] = [];
    const nLobeParts: THREE.Object3D[] = [];
    const nThreadParts: THREE.Object3D[] = [];
    const nHalfGroups: THREE.Group[] = [];

    for (const half of N.halves) {
      const hg = new THREE.Group();
      neuralGrp.add(hg);
      nHalfGroups.push(hg);
      const hgSpiral = new THREE.Group();
      const hgTuples = new THREE.Group();
      const hgHalos = new THREE.Group();
      const hgFlower = new THREE.Group();
      const hgLobes = new THREE.Group();
      const hgThreads = new THREE.Group();
      hg.add(hgSpiral, hgTuples, hgHalos, hgFlower, hgLobes, hgThreads);
      nSpiralParts.push(hgSpiral);
      nTupleParts.push(hgTuples);
      nHaloParts.push(hgHalos);
      nFlowerParts.push(hgFlower);
      nLobeParts.push(hgLobes);
      nThreadParts.push(hgThreads);

      // layer 0: the pole singularity (rides with its spiral)
      const sPos = V3(half.singularity);
      const poleR = N.singularity.radius;
      const pole = new THREE.Mesh(
        new THREE.IcosahedronGeometry(poleR, 2),
        new THREE.MeshStandardMaterial({
          color: 0x0c0f1a,
          emissive: 0x241a3a,
          emissiveIntensity: 0.6,
          roughness: 0.5,
          metalness: 0.3,
        })
      );
      pole.position.copy(sPos);
      hgSpiral.add(pole);
      const poleGlow = new THREE.Mesh(
        new THREE.SphereGeometry(poleR * 0.5, 20, 20),
        new THREE.MeshBasicMaterial({ color: COL.singularity })
      );
      poleGlow.position.copy(sPos);
      hgSpiral.add(poleGlow);

      // the toroid spiral, singularity → equator
      hgSpiral.add(
        new THREE.Mesh(
          new THREE.TubeGeometry(new THREE.CatmullRomCurve3(half.spiral.map(V3)), 320, 0.009, 8, false),
          new THREE.MeshStandardMaterial({
            color: COL.nSpiral,
            emissive: COL.nSpiral,
            emissiveIntensity: 0.55,
            roughness: 0.4,
          })
        )
      );

      // layers 1-4: halo-bound, singularity-bound tuples
      for (const layer of half.layers) {
        const torus = new THREE.Mesh(
          new THREE.TorusGeometry(layer.radius, 0.008 + layer.radius * 0.01, 8, 72),
          new THREE.MeshStandardMaterial({
            color: COL.nHalo,
            emissive: COL.nHalo,
            emissiveIntensity: 0.45,
            roughness: 0.4,
          })
        );
        torus.rotation.x = Math.PI / 2;
        torus.position.y = layer.y;
        hgHalos.add(torus);

        for (const t of layer.tuples) {
          const p = V3(t.pos);
          const tangent = new THREE.Vector3(-p.z, 0, p.x).normalize().multiplyScalar(0.034);
          hgTuples.add(nodeMesh(p.clone().add(tangent), COL.nTuple, 0.03));
          hgTuples.add(nodeMesh(p.clone().sub(tangent), COL.nTuplePartner, 0.024));
          const bondMesh = new THREE.Mesh(
            new THREE.CylinderGeometry(0.008, 0.008, 0.068, 6),
            new THREE.MeshStandardMaterial({
              color: COL.nTuple,
              emissive: COL.nTuple,
              emissiveIntensity: 0.4,
              roughness: 0.4,
            })
          );
          bondMesh.position.copy(p);
          bondMesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tangent.clone().normalize());
          hgTuples.add(bondMesh);
          // the shadow path, restored as its own layer
          hgThreads.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints([sPos, p]),
              new THREE.LineBasicMaterial({ color: COL.nThread, transparent: true, opacity: 0.18 })
            )
          );
        }

        // lemniscate lobes: one per node, tangent to its counterpart — these
        // carry the singularity binding (the shadow threads are gone)
        for (const lobe of layer.lobes) {
          hgLobes.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(lobe.map(V3)),
              new THREE.LineBasicMaterial({ color: COL.nLobe, transparent: true, opacity: 0.55 })
            )
          );
        }
      }

      // the Flower of Life: one circle per tuple center at every level
      const CIRCLE_SEGS = 72;
      for (const level of half.flower) {
        for (const [cx, cz] of level.centers) {
          const pts: THREE.Vector3[] = [];
          for (let s = 0; s <= CIRCLE_SEGS; s++) {
            const a = (2 * Math.PI * s) / CIRCLE_SEGS;
            pts.push(new THREE.Vector3(cx + level.radius * Math.cos(a), level.y, cz + level.radius * Math.sin(a)));
          }
          hgFlower.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(pts),
              new THREE.LineBasicMaterial({ color: COL.nFlowerLife, transparent: true, opacity: 0.32 })
            )
          );
        }
      }
    }

    // ── layer 4: the shared equator ring — the phase lock itself ──
    // One ring of 7 tuples at y=0, belonging to neither half: it holds still
    // while the halves counter-rotate against it. Its halo is the lock ring.
    const sharedGrp = new THREE.Group();
    neuralGrp.add(sharedGrp);
    const sharedTuples = new THREE.Group();
    const sharedLobes = new THREE.Group();
    const sharedThreads = new THREE.Group();
    const sharedFlower = new THREE.Group();
    sharedGrp.add(sharedTuples, sharedLobes, sharedThreads, sharedFlower);
    nTupleParts.push(sharedTuples);
    nLobeParts.push(sharedLobes);
    nThreadParts.push(sharedThreads);
    nFlowerParts.push(sharedFlower);
    const poleA = V3(N.halves[0].singularity);
    const poleB = V3(N.halves[1].singularity);
    for (const t of N.equator.tuples) {
      const p = V3(t.pos);
      const tangent = new THREE.Vector3(-p.z, 0, p.x).normalize().multiplyScalar(0.034);
      sharedTuples.add(nodeMesh(p.clone().add(tangent), COL.nTuple, 0.03));
      sharedTuples.add(nodeMesh(p.clone().sub(tangent), COL.nTuplePartner, 0.024));
      const eqBond = new THREE.Mesh(
        new THREE.CylinderGeometry(0.008, 0.008, 0.068, 6),
        new THREE.MeshStandardMaterial({
          color: COL.nTuple,
          emissive: COL.nTuple,
          emissiveIntensity: 0.4,
          roughness: 0.4,
        })
      );
      eqBond.position.copy(p);
      eqBond.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tangent.clone().normalize());
      sharedTuples.add(eqBond);
      // the equator binds to BOTH poles
      for (const pole of [poleA, poleB]) {
        sharedThreads.add(
          new THREE.Line(
            new THREE.BufferGeometry().setFromPoints([pole, p]),
            new THREE.LineBasicMaterial({ color: COL.nThread, transparent: true, opacity: 0.18 })
          )
        );
      }
    }
    for (const lobe of N.equator.lobes) {
      sharedLobes.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(lobe.map(V3)),
          new THREE.LineBasicMaterial({ color: COL.nLobe, transparent: true, opacity: 0.55 })
        )
      );
    }
    {
      const SEGS = 72;
      for (const [cx, cz] of N.equator.flower.centers) {
        const pts: THREE.Vector3[] = [];
        for (let s = 0; s <= SEGS; s++) {
          const a = (2 * Math.PI * s) / SEGS;
          pts.push(
            new THREE.Vector3(cx + N.equator.flower.radius * Math.cos(a), 0, cz + N.equator.flower.radius * Math.sin(a))
          );
        }
        sharedFlower.add(
          new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(pts),
            new THREE.LineBasicMaterial({ color: COL.nFlowerLife, transparent: true, opacity: 0.32 })
          )
        );
      }
    }

    // the lock ring — where the toroid meets its inverse and phase-locks
    const lockRing = new THREE.Mesh(
      new THREE.TorusGeometry(N.lockRing.radius, 0.014, 8, 96),
      new THREE.MeshStandardMaterial({
        color: COL.nLock,
        emissive: COL.nLock,
        emissiveIntensity: 0.7,
        roughness: 0.3,
      })
    );
    lockRing.rotation.x = Math.PI / 2;
    lockRing.position.y = N.lockRing.y;
    neuralGrp.add(lockRing);
    nHaloParts.push(lockRing);

    // the emission envelope: the hyperbolic hourglass, maxima at the poles
    const nEnvelope = new THREE.Group();
    neuralGrp.add(nEnvelope);
    const envGeo = new THREE.LatheGeometry(
      N.envelope.profile.map(([r, y]) => new THREE.Vector2(r, y)),
      72
    );
    nEnvelope.add(
      new THREE.Mesh(
        envGeo,
        new THREE.MeshBasicMaterial({
          color: COL.nEnvelope,
          transparent: true,
          opacity: 0.05,
          side: THREE.DoubleSide,
          depthWrite: false,
        })
      )
    );
    nEnvelope.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(envGeo),
        new THREE.LineBasicMaterial({ color: COL.nEnvelope, transparent: true, opacity: 0.07 })
      )
    );

    // phase lock: the halves counter-rotate at the same rate, driven by the
    // same phase that winds the molecule
    const LOCK_SPIN = 0.22;
    function applyPhaseLock(ph: number) {
      nHalfGroups.forEach((hg, i) => {
        hg.rotation.y = (i === 0 ? 1 : -1) * ph * LOCK_SPIN;
      });
      const beat = 1 - ((((ph / (2 * Math.PI)) % 1) + 1) % 1);
      (lockRing.material as THREE.MeshStandardMaterial).emissiveIntensity = 0.5 + 0.7 * beat * beat;
    }
    applyPhaseLock(H.vessel.snapshotAngleRad);

    // ════ the master selector + the per-structure legend ════
    const registry: Record<string, THREE.Object3D[]> = {
      uPillars: [uPillars],
      uFlower: [uFlower],
      uBridges: [uBridges],
      nSpirals: nSpiralParts,
      nTuples: nTupleParts,
      nHalos: nHaloParts,
      nFlowerLife: nFlowerParts,
      nLobes: nLobeParts,
      nThreads: nThreadParts,
      nEnvelope: [nEnvelope],
      equilibrium: [equilibrium],
      singularity: [singularity],
      vessel: [vessel],
      ghost: [ghost],
    };
    document.querySelectorAll<HTMLButtonElement>('#master-legend .lg-row').forEach((row) => {
      row.addEventListener('click', () => {
        const parts = registry[row.dataset.g || ''];
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    const modeBtns = document.querySelectorAll<HTMLButtonElement>('#master-mode button');
    const sections = document.querySelectorAll<HTMLElement>('#master-legend .lg-section[data-family]');
    function setMode(mode: string) {
      unified.visible = mode !== 'neural';
      neuralGrp.visible = mode !== 'unified';
      modeBtns.forEach((b) => b.classList.toggle('on', b.dataset.mode === mode));
      sections.forEach((s) => {
        const fam = s.dataset.family;
        s.classList.toggle('dim', (fam === 'unified' && !unified.visible) || (fam === 'neural' && !neuralGrp.visible));
      });
    }
    modeBtns.forEach((b) => b.addEventListener('click', () => setMode(b.dataset.mode || 'combined')));
    setMode('combined');

    // ════ post / resize / freeze / animate ════
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.65, 0.6, 0.22));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);
    resize();

    let frozen = false,
      phase = H.vessel.snapshotAngleRad;
    const hudPhase = document.getElementById('hud-phase');
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudPhase) hudPhase.textContent = frozen ? 'FROZEN' : 'counter-rotation · synced';
      }
    });

    const clock = new THREE.Clock();
    function frame() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        phase += WIND * dt * 1.6;
        placeMolecule(phase);
        applyPhaseLock(phase);
        updateJitterbug((1 - Math.cos(phase * 0.5)) / 2);
        updatePulse(phase);
        (glow.material as THREE.MeshBasicMaterial).opacity = 0.85 + 0.15 * Math.sin(clock.elapsedTime * 1.3);
      }
      vessel.rotation.y += frozen ? 0 : dt * 0.15;
      ghost.rotation.y += frozen ? 0 : -dt * 0.05;
      equilibrium.rotation.y = ghost.rotation.y; // the shadow tracks its body
      controls.update();
      composer.render();
      requestAnimationFrame(frame);
    }
    frame();
  </script>
</Layout>
