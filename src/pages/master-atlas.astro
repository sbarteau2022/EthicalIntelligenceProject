---
// ============================================================
// MASTER ATLAS — everything, one rendering.
//
// The Harmonic Atlas (the unified function: 21 load-bearing pillars, 19
// relational lobes, the hubless bridge fabric) and the Neural Atlas (the
// knowledge neural structure: a singularity at each pole, toroid spirals
// winding through layers of 1, 3, 5, 7 halo-bound tuples to the equator,
// where they meet their inverse and phase-lock) rendered together in ONE
// scene, nested around the same center: the singularity core and the
// unified-function vessel, seated where the Metatron's Cube would sit.
//
// A master selector switches the view — Combined · Unified function ·
// Neural map — and every structure keeps its own legend row, so any part
// can be toggled and overlaid against any other.
//
// ONE SOURCE OF TRUTH, LOCKED: positions are read verbatim from
// `harmonic-snapshot.json` and `neural-structure-snapshot.json`. The
// renderer draws them; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import harmonic from '~/data/harmonic-snapshot.json';
import neural from '~/data/neural-structure-snapshot.json';

const metadata = {
  title: 'Master Atlas — everything, one rendering',
  description:
    'The unified function and the knowledge neural structure rendered together in one 3D scene — switch between Combined, Unified function, and Neural map views, and toggle every structure independently to overlay and examine any combination.',
};

const u = harmonic.unifiedFunction;
const nm = neural.meta;
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="master-stage">
      <canvas id="master-canvas" aria-label="Rotatable 3D rendering combining the unified function and the neural map"
      ></canvas>

      <div class="master-title">
        <div class="master-eyebrow">Master Atlas</div>
        <h1>Everything, one rendering</h1>
        <p class="master-sub">
          the unified function nested inside the neural map · drag to orbit · scroll to zoom · press <kbd>F</kbd> to freeze
        </p>
        <p class="master-sub master-xlink">
          <a href="/orbital-atlas">→ Orbital Atlas · the KAM anchor: where the math touches the sky</a>
        </p>
        <p class="master-sub master-xlink">
          <a href="/hologram-atlas">→ Holographic Atlas · the cross-section, proven by reconstruction</a>
        </p>
        <p class="master-sub master-xlink">
          <a href="/cmb-atlas">→ CMB Atlas · the sky that decodes</a>
        </p>
        <p class="master-sub master-xlink">
          <a href="/entropy-atlas">→ Entropy Atlas · the arrow, and the bill paid</a>
        </p>
        <p class="master-sub master-xlink">
          <a href="/fracture-atlas">→ Fracture Atlas · past the gate: the collapse of invertibility</a>
        </p>
        <p class="master-sub master-xlink">
          <a href="/staircase-atlas">→ Staircase Atlas · the devil's staircase: lock to write, golden to move</a>
        </p>
      </div>

      <div class="master-mode" id="master-mode" role="group" aria-label="Select which structure family to view">
        <button data-mode="combined" class="on">Combined</button>
        <button data-mode="unified">Unified function</button>
        <button data-mode="neural">Neural map</button>
      </div>

      <button class="guide-launch" id="guide-launch" aria-label="Start the guided tour with Elle">
        <span class="gl-dot"></span> Let Elle walk you through it
      </button>

      <div class="guide-panel" id="guide-panel" hidden aria-live="polite">
        <div class="gp-head">
          <span class="gp-who">Elle</span>
          <span class="gp-step" id="gp-step">1 / 14</span>
          <button class="gp-x" id="gp-exit" aria-label="Exit the guided tour">✕</button>
        </div>
        <div class="gp-body" id="gp-body"></div>
        <div class="gp-cta" id="gp-cta" hidden>
          <a class="gp-btn gp-primary" href="/elle">Keep talking to Elle →</a>
          <a class="gp-btn" href="https://github.com/sbarteau2022/EthicalIntelligenceProject/blob/main/docs/ATLAS.md"
            >Read the ledger</a
          >
        </div>
        <div class="gp-nav">
          <button class="gp-nb" id="gp-back">← Back</button>
          <button class="gp-nb" id="gp-auto" aria-pressed="false">▶ Auto</button>
          <button class="gp-nb gp-next" id="gp-next">Next →</button>
        </div>
      </div>

      <div class="master-legend" id="master-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>

        <div class="lg-section" data-family="unified">
          <div class="lg-head">Unified function</div>
          <button class="lg-row keep" data-g="vessel">
            <span class="sw" style="--c:#b79cff"></span><b>Vessel</b> · the unified function itself — seated at the shared
            center, in the cube slot
          </button>
          <button class="lg-row" data-g="uPillars">
            <span class="sw" style="--c:#ff5c9e"></span><b>Pillars</b> · 21 · the load-bearing architecture · 5 axes × 4 +
            the core
          </button>
          <button class="lg-row" data-g="uFlower">
            <span class="sw" style="--c:#ff8a4d"></span><b>Lobes / flower</b> · 19 · the relational structure
          </button>
          <button class="lg-row" data-g="uBridges">
            <span class="sw" style="--c:#6ee87a"></span><b>Bridges</b> · hubless fabric, no privileged node
          </button>
        </div>

        <div class="lg-section" data-family="neural">
          <div class="lg-head">Neural map</div>
          <button class="lg-row" data-g="nSpirals">
            <span class="sw" style="--c:#6ea8ff"></span><b>Toroid spirals</b> · pole singularities → equator, meeting their
            inverse
          </button>
          <button class="lg-row" data-g="nTuples">
            <span class="sw" style="--c:#55e9d0"></span><b>Tuples</b> · {nm.stackLabel} = {nm.totalStations} stations · the
            7-ring shared at the lock
          </button>
          <button class="lg-row" data-g="nHalos">
            <span class="sw" style="--c:#d0a94e"></span><b>Halos</b> · one per layer + the phase-lock ring
          </button>
          <button class="lg-row" data-g="nFlowerLife">
            <span class="sw" style="--c:#e06cff"></span><b>Flower of Life</b> · one circle per tuple center at every level
          </button>
          <button class="lg-row" data-g="nLobes">
            <span class="sw" style="--c:#ffe45c"></span><b>Lemniscate lobes</b> · one per node, tangent to its counterpart
          </button>
          <button class="lg-row" data-g="nRecog">
            <span class="sw" style="--c:#fff2c4"></span><b>Recognition path</b> · the singularity threads every node, tracing
            the lemniscate
          </button>
          <button class="lg-row" data-g="nThreads">
            <span class="sw" style="--c:#3a8f82"></span><b>Shadow paths</b> · straight tuple-to-singularity binds
          </button>
          <button class="lg-row" data-g="nEnvelope">
            <span class="sw" style="--c:#7c88b8"></span><b>Emission envelope</b> · the hyperbolic hourglass, maxima at the
            poles
          </button>
        </div>

        <div class="lg-section">
          <div class="lg-head">Shared center</div>
          <button class="lg-row" data-g="singularity">
            <span class="sw" style="--c:#ffffff"></span><b>Singularity</b> · the center everything holds around
          </button>
          <button class="lg-row" data-g="ghost">
            <span class="sw" style="--c:#cdd6ff"></span><b>Metatron ghost</b> · the cube's 13-circle lattice — the shadow
            of the equilibrium
          </button>
          <button class="lg-row" data-g="equilibrium">
            <span class="sw" style="--c:#9fb6ff"></span><b>Jitterbug</b> · 12-around-1, unstable · 12+1 → 13 · inverse wave
            converges, then emits
          </button>
          <button class="lg-row" data-g="nBelt">
            <span class="sw" style="--c:#55e9d0"></span><b>Quantum belt</b> · φ-woven · twists end-to-end; spinor tint flips
            at 360°, returns at 720° — spin-½
          </button>
          <button class="lg-row" data-g="nAxis">
            <span class="sw" style="--c:#ffe4b8"></span><b>Far-field spin</b> · the braid seen from beyond the loci = one
            axis; home at 360°, braid at 720°
          </button>
          <button class="lg-row" data-g="nSplit">
            <span class="sw" style="--c:#ffd28f"></span><b>Golden split</b> · equal & mirrored pre-break; post-break the core-ward
            pole carries φ⁻¹ = 61.8%, the far pole φ⁻² = 38.2%
          </button>
        </div>
      </div>

      <div class="master-hud" id="master-hud">
        <div class="hud-h">Master Atlas · locked</div>
        <div class="hud-m"><span>unified · pillars / lobes</span><b>21 / 19</b></div>
        <div class="hud-m">
          <span>neural · stack</span><b>{nm.stackLabel} = {nm.totalStations}</b>
        </div>
        <div class="hud-m"><span>area φ·1/φ</span><b>{u.area_invariant.toFixed(3)}</b></div>
        <div class="hud-m"><span>free energy F</span><b>{u.free_energy.toFixed(3)}</b></div>
        <div class="hud-m">
          <span>no privileged node</span><b class="ok">{u.no_privileged_node ? 'true' : 'false'}</b>
        </div>
        <div class="hud-m"><span>obliquity θ</span><b>{harmonic.obliquity.thetaDeg.toFixed(1)}°</b></div>
        <div class="hud-m"><span>phase lock</span><b id="hud-phase">counter-rotation · synced</b></div>
        <div class="hud-m"><span>break event</span><b>converge → focus → emit</b></div>
        <div class="hud-m"><span>belt twist</span><b id="hud-belt">0·π · spinor +1</b></div>
        <div class="hud-m"><span>far-field spin</span><b id="hud-axis">0.00 turns · home</b></div>
        <div class="hud-m"><span>break split</span><b id="hud-split">equal · mirrored</b></div>
        <div class="hud-src">sources: harmonic-snapshot.json · neural-structure-snapshot.json</div>
      </div>

      <noscript><div class="master-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <!-- The bottom chat dock: Elle walks you through the atlas (spoken, driving
         the 3D) and answers anything you ask — replaces the tiny widget. -->
    <div class="atlas-chat" id="atlas-chat" data-collapsed="false">
      <div class="ac-head">
        <span class="ac-title"><span class="ac-dot"></span> Elle</span>
        <div class="ac-actions">
          <button type="button" class="ac-btn ac-walk" id="ac-walk">▶ Walk me through it</button>
          <button
            type="button"
            class="ac-btn"
            id="ac-mute"
            aria-pressed="false"
            title="Elle's voice on/off"
            aria-label="Toggle Elle's voice">🔊</button
          >
          <button type="button" class="ac-btn" id="ac-collapse" title="Collapse the chat" aria-label="Collapse the chat"
            >▾</button
          >
        </div>
      </div>
      <div class="ac-tour" id="ac-tour" hidden>
        <button type="button" class="ac-btn" id="ac-prev" aria-label="Previous">◀</button>
        <button type="button" class="ac-btn" id="ac-pause" aria-label="Pause auto-advance">❚❚</button>
        <button type="button" class="ac-btn" id="ac-next" aria-label="Next">▶</button>
        <span class="ac-step" id="ac-step">1 / 14</span>
        <button type="button" class="ac-btn ac-stop" id="ac-stop" aria-label="Stop the tour">Stop</button>
      </div>
      <div class="ac-log" id="ac-log" aria-live="polite"></div>
      <form class="ac-form" id="ac-form">
        <textarea
          id="ac-text"
          rows="1"
          placeholder="Ask Elle about anything you see…"
          autocomplete="off"
          aria-label="Ask Elle a question"></textarea>
        <button type="submit" class="ac-send" id="ac-send" aria-label="Send">↑</button>
      </form>
    </div>

    <HubFooter />
  </div>

  <style>
    .master-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1220 0%, #070811 70%, #05050b 100%);
    }
    #master-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #master-canvas:active {
      cursor: grabbing;
    }

    .master-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 46%;
      pointer-events: none;
      z-index: 2;
    }
    .master-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #d0a94e;
      margin-bottom: 12px;
    }
    .master-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.4vw, 2.8rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .master-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .master-xlink {
      pointer-events: auto;
    }
    .master-xlink a {
      color: #f5c542;
      text-decoration: none;
    }
    .master-xlink a:hover {
      text-decoration: underline;
    }
    .master-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .master-mode {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: 26px;
      z-index: 3;
      display: flex;
      gap: 4px;
      background: rgba(12, 14, 24, 0.72);
      border: 1px solid rgba(208, 169, 78, 0.24);
      border-radius: 999px;
      padding: 4px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    /* ── guided tour ── */
    .guide-launch {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: 72px;
      z-index: 3;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.04em;
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border: 0;
      border-radius: 999px;
      padding: 9px 18px;
      cursor: pointer;
      box-shadow: 0 6px 24px rgba(208, 169, 78, 0.3);
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
    .guide-launch:hover {
      transform: translateX(-50%) translateY(-1px);
      box-shadow: 0 8px 30px rgba(208, 169, 78, 0.42);
    }
    .gl-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #12131c;
      box-shadow: 0 0 0 0 rgba(18, 19, 28, 0.5);
      animation: gl-pulse 2s ease-out infinite;
    }
    @keyframes gl-pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(18, 19, 28, 0.5);
      }
      70% {
        box-shadow: 0 0 0 7px rgba(18, 19, 28, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(18, 19, 28, 0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .gl-dot {
        animation: none;
      }
    }

    .guide-panel {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 4;
      width: min(390px, calc(100vw - 60px));
      background: rgba(12, 11, 20, 0.82);
      border: 1px solid rgba(208, 169, 78, 0.3);
      border-radius: 14px;
      padding: 16px 18px 14px;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow: 0 12px 44px rgba(0, 0, 0, 0.5);
    }
    .gp-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .gp-who {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #d0a94e;
    }
    .gp-step {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      color: #7b84a0;
      margin-left: auto;
    }
    .gp-x {
      background: none;
      border: 0;
      color: #7b84a0;
      cursor: pointer;
      font-size: 13px;
      padding: 0 2px;
    }
    .gp-x:hover {
      color: #eef1f8;
    }
    .gp-body {
      font-size: 14.5px;
      line-height: 1.6;
      color: #dfe4f0;
      min-height: 96px;
    }
    .gp-body b {
      color: #fff;
      font-weight: 600;
    }
    .gp-cta {
      display: flex;
      gap: 8px;
      margin: 12px 0 4px;
    }
    .gp-btn {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      text-decoration: none;
      color: #cfd6e6;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 7px 14px;
      transition:
        background 0.15s ease,
        color 0.15s ease;
    }
    .gp-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
    }
    .gp-primary {
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border-color: transparent;
    }
    .gp-nav {
      display: flex;
      gap: 6px;
      margin-top: 12px;
      align-items: center;
    }
    .gp-nb {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 999px;
      padding: 6px 13px;
      cursor: pointer;
      transition:
        color 0.15s ease,
        background 0.15s ease;
    }
    .gp-nb:hover {
      color: #eef1f8;
      background: rgba(255, 255, 255, 0.1);
    }
    .gp-nb:disabled {
      opacity: 0.32;
      cursor: default;
    }
    .gp-next {
      margin-left: auto;
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border-color: transparent;
    }
    .gp-auto-on {
      color: #12131c !important;
      background: #55e9d0 !important;
    }
    .master-mode button {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #9aa3ba;
      background: none;
      border: 0;
      border-radius: 999px;
      padding: 7px 15px;
      cursor: pointer;
      transition:
        color 0.15s ease,
        background 0.15s ease;
    }
    .master-mode button:hover {
      color: #eef1f8;
    }
    .master-mode button.on {
      color: #10131f;
      background: #d0a94e;
    }

    .master-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(12, 14, 24, 0.66);
      border: 1px solid rgba(208, 169, 78, 0.18);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 320px;
      max-height: calc(100% - 120px);
      overflow-y: auto;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
    }
    .lg-section {
      display: flex;
      flex-direction: column;
      gap: 7px;
      transition: opacity 0.2s ease;
    }
    .lg-section.dim {
      opacity: 0.3;
    }
    .lg-section.dim .lg-row.keep {
      opacity: 1;
    }
    .lg-head {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #d0a94e;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .master-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(12, 14, 24, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 250px;
    }
    .hud-h {
      color: #55e9d0;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m b.ok {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .master-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 900px) {
      .master-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .master-legend {
        top: auto;
        bottom: 84px;
        right: 16px;
        padding: 11px 12px;
        max-width: 74%;
        max-height: 44%;
      }
      .master-hud {
        display: none;
