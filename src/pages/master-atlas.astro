  <script type="application/json" id="harmonic-snap" set:html={JSON.stringify(harmonic)} />
  <script type="application/json" id="neural-snap" set:html={JSON.stringify(neural)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface HarmonicSnap {
      meta: { phi: number; phiInv: number; goldenWinding: number };
      architecture: { nodes: { id: number; kind: string; pos: number[] }[]; edges: number[][] };
      fabric: { edges: number[][] };
      flower: { nodes: { id: number; ring: number; pos: number[] }[]; edges: number[][] };
      vessel: { orbit: number[][]; snapshotAngleRad: number };
      obliquity: { thetaDeg: number };
    }
    interface NeuralLayer {
      k: number;
      count: number;
      radius: number;
      y: number;
      tuples: { angleDeg: number; pos: number[] }[];
      lobes: number[][][];
    }
    interface NeuralHalf {
      sign: number;
      handedness: number;
      singularity: number[];
      layers: NeuralLayer[];
      spiral: number[][];
      flower: { k: number; y: number; radius: number; centers: number[][] }[];
    }
    interface NeuralSnap {
      halves: NeuralHalf[];
      equator: {
        k: number;
        count: number;
        radius: number;
        y: number;
        tuples: { angleDeg: number; pos: number[] }[];
        lobes: number[][][];
        flower: { radius: number; centers: number[][] };
      };
      envelope: { profile: number[][] };
      lockRing: { radius: number; y: number };
      metatronGhost: { circleRadius: number; centers: number[][]; edges: number[][] };
      vectorEquilibrium: { radius: number; vertices: number[][]; edges: number[][] };
      quantumBelt: { windings: number[]; waist: number; strands: number[][][] };
      jitterbug: {
        targets13: number[][];
        coreTargetIndex: number;
        pairing: number[];
        coreAxis: number[];
        shadowCircleR: number;
      };
      goldenSplit: { nearShare: number; farShare: number; towardY: number };
      singularity: { radius: number };
    }

    const H: HarmonicSnap = JSON.parse((document.getElementById('harmonic-snap') as HTMLElement).textContent || '{}');
    const N: NeuralSnap = JSON.parse((document.getElementById('neural-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('master-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // One distinct color per structure across BOTH families.
    const COL = {
      uPillar: 0xff5c9e,
      uFlower: 0xff8a4d,
      uBridge: 0x6ee87a,
      nSpiral: 0x6ea8ff,
      nTuple: 0x55e9d0,
      nTuplePartner: 0x2fb3a0,
      nHalo: 0xd0a94e,
      nLock: 0xf2ead9,
      nFlowerLife: 0xe06cff,
      nLobe: 0xffe45c,
      nRecog: 0xfff2c4,
      nThread: 0x55e9d0,
      nEnvelope: 0x7c88b8,
      equilibrium: 0x9fb6ff,
      singularity: 0xffffff,
      vessel: 0xb79cff,
      plus: 0xff5cc8,
      minus: 0x5cd8ff,
      bond: 0xd0a94e,
      ghost: 0xcdd6ff,
    };
    const PHI = H.meta.phi,
      PHI_INV = H.meta.phiInv,
      WIND = H.meta.goldenWinding;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(3.6, 2.2, 4.2);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.6;
    controls.maxDistance = 18;
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.34;

    scene.add(new THREE.AmbientLight(0x2a3050, 1.1));
    const key = new THREE.PointLight(0xaec2ff, 40, 40);
    key.position.set(4, 6, 5);
    scene.add(key);
    const rim = new THREE.PointLight(0xd0a94e, 16, 40);
    rim.position.set(-5, -4, -4);
    scene.add(rim);

    const world = new THREE.Group();
    scene.add(world);
    const V3 = (a: number[]) => new THREE.Vector3(a[0], a[1], a[2]);

    function nodeMesh(pos: THREE.Vector3, color: number, radius: number) {
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(radius, 20, 20),
        new THREE.MeshStandardMaterial({
          color,
          emissive: color,
          emissiveIntensity: 0.7,
          roughness: 0.35,
          metalness: 0.1,
        })
      );
      mesh.position.copy(pos);
      return mesh;
    }
    function edgeLines(nodesById: Record<number, number[]>, edges: number[][], color: number, opacity: number) {
      const pts: THREE.Vector3[] = [];
      for (const [a, b] of edges) {
        pts.push(V3(nodesById[a]), V3(nodesById[b]));
      }
      return new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(pts),
        new THREE.LineBasicMaterial({ color, transparent: true, opacity })
      );
    }

    // ════ SHARED CENTER — the singularity and the vessel, common to both maps ════
    const singularity = new THREE.Group();
    world.add(singularity);
    const coreR = 0.42;
    singularity.add(
      new THREE.Mesh(
        new THREE.IcosahedronGeometry(coreR, 3),
        new THREE.MeshStandardMaterial({
          color: 0x0c1020,
          emissive: 0x1f2246,
          emissiveIntensity: 0.6,
          roughness: 0.5,
          metalness: 0.3,
        })
      )
    );
    singularity.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(coreR * 1.002, 3)),
        new THREE.LineBasicMaterial({ color: 0x5a6ba8, transparent: true, opacity: 0.4 })
      )
    );
    const glow = new THREE.Mesh(
      new THREE.SphereGeometry(coreR * 0.5, 24, 24),
      new THREE.MeshBasicMaterial({ color: COL.singularity })
    );
    singularity.add(glow);

    // the ghost Metatron's Cube — the slot the vessel occupies
    const ghost = new THREE.Group();
    world.add(ghost);
    const ghostCenters = N.metatronGhost.centers.map(([x, z]) => new THREE.Vector3(x, 0, z));
    const circleSegs = 40;
    for (const c of ghostCenters) {
      const pts: THREE.Vector3[] = [];
      for (let s = 0; s <= circleSegs; s++) {
        const a = (2 * Math.PI * s) / circleSegs;
        pts.push(
          new THREE.Vector3(
            c.x + N.metatronGhost.circleRadius * Math.cos(a),
            0,
            c.z + N.metatronGhost.circleRadius * Math.sin(a)
          )
        );
      }
      ghost.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(pts),
          new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.1 })
        )
      );
    }
    const ghostLinePts: THREE.Vector3[] = [];
    for (const [i, j] of N.metatronGhost.edges) {
      ghostLinePts.push(ghostCenters[i], ghostCenters[j]);
    }
    ghost.add(
      new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(ghostLinePts),
        new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.06 })
      )
    );

    // ── the jitterbug — the vector equilibrium is unstable, not a cage ──
    // Fuller's vector equilibrium (12 around 1) is a balance point: driven by
    // the orbital phase, the center sphere spirals outward and the shell opens
    // from the symmetric 12+1 toward the asymmetric 13-on-shell, leaving a
    // vacancy where the core was — the slot the vessel occupies. The lattice
    // shadow (plane projection) deforms with it in real time; it breathes
    // 12+1 <-> 13, so the symmetry break is reversible on screen.
    const equilibrium = new THREE.Group();
    world.add(equilibrium);
    const jb = N.jitterbug;
    const veR = N.vectorEquilibrium.radius;
    const jbShellStart = N.vectorEquilibrium.vertices.map(V3);
    const jbTargets = jb.targets13.map(V3);
    const jbShellTarget = jb.pairing.map((t: number) => jbTargets[t]);
    const jbCoreTarget = jbTargets[jb.coreTargetIndex];
    const jbEdges = N.vectorEquilibrium.edges;

    const jbNodes: THREE.Mesh[] = [];
    for (let i = 0; i < 13; i++) {
      const mesh = nodeMesh(new THREE.Vector3(0, 0, 0), COL.equilibrium, i === 12 ? 0.022 : 0.018);
      equilibrium.add(mesh);
      jbNodes.push(mesh);
    }
    const jbCurrent: THREE.Vector3[] = Array.from({ length: 13 }, () => new THREE.Vector3());

    const spokeGeo = new THREE.BufferGeometry();
    const spokePos = new Float32Array(13 * 2 * 3);
    spokeGeo.setAttribute('position', new THREE.BufferAttribute(spokePos, 3));
    equilibrium.add(
      new THREE.LineSegments(
        spokeGeo,
        new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.22 })
      )
    );

    const cageGeo = new THREE.BufferGeometry();
    const cagePos = new Float32Array(jbEdges.length * 2 * 3);
    cageGeo.setAttribute('position', new THREE.BufferAttribute(cagePos, 3));
    const cageMat = new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.45 });
    equilibrium.add(new THREE.LineSegments(cageGeo, cageMat));

    // the live lattice shadow: 13 circles on y=0 tracking the projected centers
    const SHADOW_SEGS = 40;
    const shadowCircles: { pos: Float32Array; geo: THREE.BufferGeometry }[] = [];
    for (let i = 0; i < 13; i++) {
      const pos = new Float32Array((SHADOW_SEGS + 1) * 3);
      const g = new THREE.BufferGeometry();
      g.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      equilibrium.add(
        new THREE.Line(g, new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.14 }))
      );
      shadowCircles.push({ pos, geo: g });
    }

    function jbSmooth(x: number) {
      return x * x * (3 - 2 * x);
    }
    function updateJitterbug(sRaw: number) {
      const s = jbSmooth(Math.max(0, Math.min(1, sRaw)));
      for (let i = 0; i < 13; i++) {
        const p = jbCurrent[i];
        if (i < 12) {
          p.copy(jbShellStart[i]).lerp(jbShellTarget[i], s);
          if (p.lengthSq() > 1e-9) p.setLength(veR);
        } else {
          p.set(0, 0, 0).lerp(jbCoreTarget, s); // the core, pulled from center to shell
        }
        jbNodes[i].position.copy(p);
        spokePos[i * 6 + 3] = p.x;
        spokePos[i * 6 + 4] = p.y;
        spokePos[i * 6 + 5] = p.z;
        const sc = shadowCircles[i];
        for (let k = 0; k <= SHADOW_SEGS; k++) {
          const a = (2 * Math.PI * k) / SHADOW_SEGS;
          sc.pos[k * 3] = p.x + jb.shadowCircleR * Math.cos(a);
          sc.pos[k * 3 + 1] = 0;
          sc.pos[k * 3 + 2] = p.z + jb.shadowCircleR * Math.sin(a);
        }
        sc.geo.attributes.position.needsUpdate = true;
      }
      spokeGeo.attributes.position.needsUpdate = true;
      for (let e = 0; e < jbEdges.length; e++) {
        const pa = jbCurrent[jbEdges[e][0]];
        const pb = jbCurrent[jbEdges[e][1]];
        cagePos[e * 6] = pa.x;
        cagePos[e * 6 + 1] = pa.y;
        cagePos[e * 6 + 2] = pa.z;
        cagePos[e * 6 + 3] = pb.x;
        cagePos[e * 6 + 4] = pb.y;
        cagePos[e * 6 + 5] = pb.z;
      }
      cageGeo.attributes.position.needsUpdate = true;
      cageMat.opacity = 0.45 * (1 - s) * (1 - s); // the cuboctahedral cage dissolves as the core leaves
    }
    updateJitterbug(0);

    // the break event: when the core reaches the shell (s → 1) the symmetric
    // 12+1 balance collapses and releases a spherical pulse — the emission that
    // carries the energy of the symmetry break outward through the structure
    // and decoheres the balance. It fires once per breathe cycle, at the break.
    const PULSE_MAX_R = 1.4;
    const PULSE_WARM = 0xffe9c0; // emission — the diverging wave, out
    const PULSE_COOL = 0x9fd0ff; // absorption — the converging inverse, in
    const pulseSphere = new THREE.Mesh(
      new THREE.SphereGeometry(1, 32, 24),
      new THREE.MeshBasicMaterial({
        color: PULSE_WARM,
        transparent: true,
        opacity: 0,
        side: THREE.DoubleSide,
        depthWrite: false,
      })
    );
    equilibrium.add(pulseSphere);
    const pulseWire = new THREE.LineSegments(
      new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(1, 2)),
      new THREE.LineBasicMaterial({ color: PULSE_WARM, transparent: true, opacity: 0 })
    );
    equilibrium.add(pulseWire);
    // the pulse's plane shadow — a ring on y=0 that expands (out) or contracts (in)
    const PSHADOW_SEGS = 48;
    const pShadowPos = new Float32Array((PSHADOW_SEGS + 1) * 3);
    const pShadowGeo = new THREE.BufferGeometry();
    pShadowGeo.setAttribute('position', new THREE.BufferAttribute(pShadowPos, 3));
    const pShadow = new THREE.Line(
      pShadowGeo,
      new THREE.LineBasicMaterial({ color: PULSE_WARM, transparent: true, opacity: 0 })
    );
    equilibrium.add(pShadow);
    // Time-symmetric event: an inverse wave CONVERGES from the far side (cool),
    // focuses at the vacancy at the break, then EMITS outward (warm). Absorption
    // → event → emission. The break is the focus the cycle turns through.
    function updatePulse(ph: number) {
      const u = ((((ph * 0.5) / (2 * Math.PI)) % 1) + 1) % 1; // position in the breathe cycle
      let r: number, fade: number, col: number;
      if (u < 0.5) {
        const t = u / 0.5; // 0 → 1 approaching the break
        r = 0.02 + (1 - t) * PULSE_MAX_R; // converges inward, through the other side
        fade = t * t; // brightens as it focuses
        col = PULSE_COOL;
      } else {
        const t = (u - 0.5) / 0.5; // 0 at the break → 1 fully expanded
        r = 0.02 + t * PULSE_MAX_R; // diverges outward
        fade = (1 - t) * (1 - t);
        col = PULSE_WARM;
      }
      pulseSphere.scale.setScalar(r);
      pulseWire.scale.setScalar(r);
      (pulseSphere.material as THREE.MeshBasicMaterial).color.setHex(col);
      (pulseWire.material as THREE.MeshBasicMaterial).color.setHex(col);
      (pulseSphere.material as THREE.MeshBasicMaterial).opacity = 0.07 * fade;
      (pulseWire.material as THREE.MeshBasicMaterial).opacity = 0.32 * fade;
      const sm = pShadow.material as THREE.LineBasicMaterial;
      sm.color.setHex(col);
      sm.opacity = 0.3 * fade;
      for (let k = 0; k <= PSHADOW_SEGS; k++) {
        const a = (2 * Math.PI * k) / PSHADOW_SEGS;
        pShadowPos[k * 3] = r * Math.cos(a);
        pShadowPos[k * 3 + 1] = 0;
        pShadowPos[k * 3 + 2] = r * Math.sin(a);
      }
      pShadowGeo.attributes.position.needsUpdate = true;
    }
    updatePulse(0);

    // the vessel — the unified-function rendering, seated where the cube would be
    const vessel = new THREE.Group();
    world.add(vessel);
    const shellR = 0.66;
    vessel.add(
      new THREE.Mesh(
        new THREE.IcosahedronGeometry(shellR, 1),
        new THREE.MeshPhysicalMaterial({
          color: COL.vessel,
          transparent: true,
          opacity: 0.1,
          roughness: 0.1,
          metalness: 0,
          transmission: 0.6,
          side: THREE.DoubleSide,
        })
      )
    );
    vessel.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(shellR, 1)),
        new THREE.LineBasicMaterial({ color: COL.vessel, transparent: true, opacity: 0.32 })
      )
    );
    const orbScale = (shellR * 0.82) / PHI;
    vessel.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          H.vessel.orbit.map(([q, p]) => new THREE.Vector3(q * orbScale, p * orbScale, 0))
        ),
        new THREE.LineBasicMaterial({ color: COL.bond, transparent: true, opacity: 0.6 })
      )
    );
    const mPlus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.plus, 0.06);
    vessel.add(mPlus);
    const mMinus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.minus, 0.045);
    vessel.add(mMinus);
    const bond = new THREE.Mesh(
      new THREE.CylinderGeometry(0.012, 0.012, 1, 8),
      new THREE.MeshStandardMaterial({ color: COL.bond, emissive: COL.bond, emissiveIntensity: 0.5, roughness: 0.4 })
    );
    vessel.add(bond);

    function placeMolecule(angle: number) {
      const q = PHI * Math.cos(angle) * orbScale,
        p = PHI_INV * Math.sin(angle) * orbScale;
      mPlus.position.set(q, p, 0);
      mMinus.position.set(-q, -p, 0);
      const a = mPlus.position,
        b = mMinus.position;
      bond.position.copy(a.clone().add(b).multiplyScalar(0.5));
      bond.scale.set(1, a.distanceTo(b), 1);
      bond.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), b.clone().sub(a).normalize());
    }
    placeMolecule(H.vessel.snapshotAngleRad);

    // ════ UNIFIED FUNCTION — the harmonic architecture, tilted by its obliquity ════
    const unified = new THREE.Group();
    world.add(unified);
    unified.rotation.z = (H.obliquity.thetaDeg * Math.PI) / 180;

    const uPillars = new THREE.Group();
    unified.add(uPillars);
    const archById: Record<number, number[]> = {};
    H.architecture.nodes.forEach((n) => {
      archById[n.id] = n.pos;
    });
    H.architecture.nodes.forEach((n) =>
      uPillars.add(nodeMesh(V3(n.pos), COL.uPillar, n.kind === 'apex' ? 0.075 : 0.05))
    );
    uPillars.add(edgeLines(archById, H.architecture.edges, COL.uPillar, 0.5));

    const uBridges = new THREE.Group();
    unified.add(uBridges);
    uBridges.add(edgeLines(archById, H.fabric.edges, COL.uBridge, 0.5));

    const uFlower = new THREE.Group();
    unified.add(uFlower);
    const flowerById: Record<number, number[]> = {};
    H.flower.nodes.forEach((n) => {
      flowerById[n.id] = n.pos;
    });
    H.flower.nodes.forEach((n) => uFlower.add(nodeMesh(V3(n.pos), COL.uFlower, n.ring === 0 ? 0.07 : 0.045)));
    uFlower.add(edgeLines(flowerById, H.flower.edges, COL.uFlower, 0.42));

    // ════ NEURAL MAP — the corrected layer hierarchy ════
    // Layer 0: a singularity at each pole. A toroid spiral winds from each
    // through layers of 1, 3, 5, 7 halo-bound tuples to the equator, where it
    // meets its inverse and the two phase-lock (counter-rotation in sync).
    const neuralGrp = new THREE.Group();
    world.add(neuralGrp);

    // per-structure part registries (the halves counter-rotate, so structure
    // parts can't share one parent group)
    const nSpiralParts: THREE.Object3D[] = [];
    const nTupleParts: THREE.Object3D[] = [];
    const nHaloParts: THREE.Object3D[] = [];
    const nFlowerParts: THREE.Object3D[] = [];
    const nLobeParts: THREE.Object3D[] = [];
    const nThreadParts: THREE.Object3D[] = [];
    const nHalfGroups: THREE.Group[] = [];

    for (const half of N.halves) {
      const hg = new THREE.Group();
      neuralGrp.add(hg);
      nHalfGroups.push(hg);
      const hgSpiral = new THREE.Group();
      const hgTuples = new THREE.Group();
      const hgHalos = new THREE.Group();
      const hgFlower = new THREE.Group();
      const hgLobes = new THREE.Group();
      const hgThreads = new THREE.Group();
      hg.add(hgSpiral, hgTuples, hgHalos, hgFlower, hgLobes, hgThreads);
      nSpiralParts.push(hgSpiral);
      nTupleParts.push(hgTuples);
      nHaloParts.push(hgHalos);
      nFlowerParts.push(hgFlower);
      nLobeParts.push(hgLobes);
      nThreadParts.push(hgThreads);

      // layer 0: the pole singularity (rides with its spiral)
      const sPos = V3(half.singularity);
      const poleR = N.singularity.radius;
      const pole = new THREE.Mesh(
        new THREE.IcosahedronGeometry(poleR, 2),
        new THREE.MeshStandardMaterial({
          color: 0x0c0f1a,
          emissive: 0x241a3a,
          emissiveIntensity: 0.6,
          roughness: 0.5,
          metalness: 0.3,
        })
      );
      pole.position.copy(sPos);
      hgSpiral.add(pole);
      const poleGlow = new THREE.Mesh(
        new THREE.SphereGeometry(poleR * 0.5, 20, 20),
        new THREE.MeshBasicMaterial({ color: COL.singularity })
      );
      poleGlow.position.copy(sPos);
      hgSpiral.add(poleGlow);

      // the toroid spiral, singularity → equator
      hgSpiral.add(
        new THREE.Mesh(
          new THREE.TubeGeometry(new THREE.CatmullRomCurve3(half.spiral.map(V3)), 320, 0.009, 8, false),
          new THREE.MeshStandardMaterial({
            color: COL.nSpiral,
            emissive: COL.nSpiral,
            emissiveIntensity: 0.55,
            roughness: 0.4,
          })
        )
      );

      // layers 1-4: halo-bound, singularity-bound tuples
      for (const layer of half.layers) {
        const torus = new THREE.Mesh(
          new THREE.TorusGeometry(layer.radius, 0.008 + layer.radius * 0.01, 8, 72),
          new THREE.MeshStandardMaterial({
            color: COL.nHalo,
            emissive: COL.nHalo,
            emissiveIntensity: 0.45,
            roughness: 0.4,
          })
        );
        torus.rotation.x = Math.PI / 2;
        torus.position.y = layer.y;
        hgHalos.add(torus);

        for (const t of layer.tuples) {
          const p = V3(t.pos);
          const tangent = new THREE.Vector3(-p.z, 0, p.x).normalize().multiplyScalar(0.034);
          hgTuples.add(nodeMesh(p.clone().add(tangent), COL.nTuple, 0.03));
          hgTuples.add(nodeMesh(p.clone().sub(tangent), COL.nTuplePartner, 0.024));
          const bondMesh = new THREE.Mesh(
            new THREE.CylinderGeometry(0.008, 0.008, 0.068, 6),
            new THREE.MeshStandardMaterial({
              color: COL.nTuple,
              emissive: COL.nTuple,
              emissiveIntensity: 0.4,
              roughness: 0.4,
            })
          );
          bondMesh.position.copy(p);
          bondMesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tangent.clone().normalize());
          hgTuples.add(bondMesh);
          // the shadow path, restored as its own layer
          hgThreads.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints([sPos, p]),
              new THREE.LineBasicMaterial({ color: COL.nThread, transparent: true, opacity: 0.18 })
            )
          );
        }

        // lemniscate lobes: one per node, tangent to its counterpart — these
        // carry the singularity binding (the shadow threads are gone)
        for (const lobe of layer.lobes) {
          hgLobes.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(lobe.map(V3)),
              new THREE.LineBasicMaterial({ color: COL.nLobe, transparent: true, opacity: 0.55 })
            )
          );
        }
      }

      // the Flower of Life: one circle per tuple center at every level
      const CIRCLE_SEGS = 72;
      for (const level of half.flower) {
        for (const [cx, cz] of level.centers) {
          const pts: THREE.Vector3[] = [];
          for (let s = 0; s <= CIRCLE_SEGS; s++) {
            const a = (2 * Math.PI * s) / CIRCLE_SEGS;
            pts.push(new THREE.Vector3(cx + level.radius * Math.cos(a), level.y, cz + level.radius * Math.sin(a)));
          }
          hgFlower.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(pts),
              new THREE.LineBasicMaterial({ color: COL.nFlowerLife, transparent: true, opacity: 0.32 })
            )
          );
        }
      }
    }

    // ── layer 4: the shared equator ring — the phase lock itself ──
    // One ring of 7 tuples at y=0, belonging to neither half: it holds still
    // while the halves counter-rotate against it. Its halo is the lock ring.
    const sharedGrp = new THREE.Group();
    neuralGrp.add(sharedGrp);
    const sharedTuples = new THREE.Group();
    const sharedLobes = new THREE.Group();
    const sharedThreads = new THREE.Group();
    const sharedFlower = new THREE.Group();
    sharedGrp.add(sharedTuples, sharedLobes, sharedThreads, sharedFlower);
    nTupleParts.push(sharedTuples);
    nLobeParts.push(sharedLobes);
    nThreadParts.push(sharedThreads);
    nFlowerParts.push(sharedFlower);
    const poleA = V3(N.halves[0].singularity);
    const poleB = V3(N.halves[1].singularity);
    for (const t of N.equator.tuples) {
      const p = V3(t.pos);
      const tangent = new THREE.Vector3(-p.z, 0, p.x).normalize().multiplyScalar(0.034);
      sharedTuples.add(nodeMesh(p.clone().add(tangent), COL.nTuple, 0.03));
      sharedTuples.add(nodeMesh(p.clone().sub(tangent), COL.nTuplePartner, 0.024));
      const eqBond = new THREE.Mesh(
        new THREE.CylinderGeometry(0.008, 0.008, 0.068, 6),
        new THREE.MeshStandardMaterial({
          color: COL.nTuple,
          emissive: COL.nTuple,
          emissiveIntensity: 0.4,
          roughness: 0.4,
        })
      );
      eqBond.position.copy(p);
      eqBond.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tangent.clone().normalize());
      sharedTuples.add(eqBond);
      // the equator binds to BOTH poles
      for (const pole of [poleA, poleB]) {
        sharedThreads.add(
          new THREE.Line(
            new THREE.BufferGeometry().setFromPoints([pole, p]),
            new THREE.LineBasicMaterial({ color: COL.nThread, transparent: true, opacity: 0.18 })
          )
        );
      }
    }
    for (const lobe of N.equator.lobes) {
      sharedLobes.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(lobe.map(V3)),
          new THREE.LineBasicMaterial({ color: COL.nLobe, transparent: true, opacity: 0.55 })
        )
      );
    }

    // ── the recognition path: the singularity's own trajectory ──
    // The 7 equatorial lobes, concatenated into ONE continuous closed curve —
    // the path the singularity travels: it threads every green node and returns
    // through the center each time, tracing the lemniscate. No node is the
    // center; the center visits every node ("every point is the origin").
    const sharedRecog = new THREE.Group();
    sharedGrp.add(sharedRecog);
    const recogRaw: THREE.Vector3[] = [];
    for (const lobe of N.equator.lobes) for (const q of lobe) recogRaw.push(V3(q));
    const recogPts: THREE.Vector3[] = [];
    for (const q of recogRaw) {
      const last = recogPts[recogPts.length - 1];
      if (!last || last.distanceToSquared(q) > 1e-6) recogPts.push(q);
    }
    const recogCurve = new THREE.CatmullRomCurve3(recogPts, true, 'catmullrom', 0.35);
    sharedRecog.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(recogCurve.getPoints(640)),
        new THREE.LineBasicMaterial({ color: COL.nRecog, transparent: true, opacity: 0.3 })
      )
    );
    const recogHead = new THREE.Mesh(
      new THREE.SphereGeometry(0.03, 18, 18),
      new THREE.MeshBasicMaterial({ color: COL.nRecog })
    );
    sharedRecog.add(recogHead);
    const RECOG_TRAIL = 56;
    const recogTrailGeom = new THREE.BufferGeometry();
    recogTrailGeom.setAttribute('position', new THREE.BufferAttribute(new Float32Array(RECOG_TRAIL * 3), 3));
    const recogTrail = new THREE.Line(
      recogTrailGeom,
      new THREE.LineBasicMaterial({ color: COL.nRecog, transparent: true, opacity: 0.7 })
    );
    sharedRecog.add(recogTrail);
    let recogU = 0;
    {
      const SEGS = 72;
      for (const [cx, cz] of N.equator.flower.centers) {
        const pts: THREE.Vector3[] = [];
        for (let s = 0; s <= SEGS; s++) {
          const a = (2 * Math.PI * s) / SEGS;
          pts.push(
            new THREE.Vector3(cx + N.equator.flower.radius * Math.cos(a), 0, cz + N.equator.flower.radius * Math.sin(a))
          );
        }
        sharedFlower.add(
          new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(pts),
            new THREE.LineBasicMaterial({ color: COL.nFlowerLife, transparent: true, opacity: 0.32 })
          )
        );
      }
    }

    // the lock ring — where the toroid meets its inverse and phase-locks
    const lockRing = new THREE.Mesh(
      new THREE.TorusGeometry(N.lockRing.radius, 0.014, 8, 96),
      new THREE.MeshStandardMaterial({
        color: COL.nLock,
        emissive: COL.nLock,
        emissiveIntensity: 0.7,
        roughness: 0.3,
      })
    );
    lockRing.rotation.x = Math.PI / 2;
    lockRing.position.y = N.lockRing.y;
    neuralGrp.add(lockRing);
    nHaloParts.push(lockRing);

    // the emission envelope: the hyperbolic hourglass, maxima at the poles
    const nEnvelope = new THREE.Group();
    neuralGrp.add(nEnvelope);
    const envGeo = new THREE.LatheGeometry(
      N.envelope.profile.map(([r, y]) => new THREE.Vector2(r, y)),
      72
    );
    nEnvelope.add(
      new THREE.Mesh(
        envGeo,
        new THREE.MeshBasicMaterial({
          color: COL.nEnvelope,
          transparent: true,
          opacity: 0.05,
          side: THREE.DoubleSide,
          depthWrite: false,
        })
      )
    );
    nEnvelope.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(envGeo),
        new THREE.LineBasicMaterial({ color: COL.nEnvelope, transparent: true, opacity: 0.07 })
      )
    );

    // phase lock: the halves counter-rotate at the same rate, driven by the
    // same phase that winds the molecule
    const LOCK_SPIN = 0.22;
    function applyPhaseLock(ph: number) {
      nHalfGroups.forEach((hg, i) => {
        hg.rotation.y = (i === 0 ? 1 : -1) * ph * LOCK_SPIN;
      });
      const beat = 1 - ((((ph / (2 * Math.PI)) % 1) + 1) % 1);
      (lockRing.material as THREE.MeshStandardMaterial).emissiveIntensity = 0.5 + 0.7 * beat * beat;
    }
    applyPhaseLock(H.vessel.snapshotAngleRad);

    // ════ the master selector + the per-structure legend ════

    // ── the quantum belt: phi-woven frequencies, strung between the loci ──
    // Strands wind at Fibonacci frequencies (1,2,3,5,8 — ratios that ARE phi),
    // golden-angle offset so they weave without colliding: phi as the regulator
    // that lets distinct frequencies coexist woven instead of locking into one.
    const belt = new THREE.Group();
    neuralGrp.add(belt);
    const beltBaseCols = [0x6ea8ff, 0x55e9d0, 0xb79cff, 0xffe45c, 0xff9e5c];
    const beltStrands = N.quantumBelt.strands.map((strand: number[][], i: number) => {
      const N = strand.length;
      const rho = new Float32Array(N),
        yy = new Float32Array(N),
        ang = new Float32Array(N),
        sArr = new Float32Array(N);
      for (let k = 0; k < N; k++) {
        const x = strand[k][0],
          y = strand[k][1],
          z = strand[k][2];
        rho[k] = Math.hypot(x, z);
        yy[k] = y;
        ang[k] = Math.atan2(z, x);
        sArr[k] = k / (N - 1);
      }
      const pos = new Float32Array(N * 3);
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      const base = new THREE.Color(beltBaseCols[i % beltBaseCols.length]);
      const mat = new THREE.LineBasicMaterial({ color: base.clone(), transparent: true, opacity: 0.62 });
      belt.add(new THREE.Line(geo, mat));
      return { N, rho, yy, ang, sArr, pos, geo, mat, base };
    });
    // The spin-1/2 belt trick: driven by the phase, the belt twists end-to-end
    // (one locus turns, the other is held). Its spinor phase — the belt's tint —
    // flips at 360 deg and returns to itself only at 720 deg (4pi): the SU(2)
    // double cover, the same doubled cycle the phase-locked pair already implies.
    const beltSpinCool = new THREE.Color(0x2f4a80);
    const hudBelt = document.getElementById('hud-belt');
    function updateBelt(ph: number) {
      const tau = 2 * Math.PI * (1 - Math.cos(ph * 0.4)); // end-to-end twist: 0 -> 4pi -> 0
      const spin = (Math.cos(tau / 2) + 1) / 2; // spinor phase: 1 at 0/4pi, 0 at 2pi
      for (const st of beltStrands) {
        for (let k = 0; k < st.N; k++) {
          const a = st.ang[k] + tau * st.sArr[k]; // twist distributed along the belt
          st.pos[k * 3] = st.rho[k] * Math.cos(a);
          st.pos[k * 3 + 1] = st.yy[k];
          st.pos[k * 3 + 2] = st.rho[k] * Math.sin(a);
        }
        st.geo.attributes.position.needsUpdate = true;
        st.mat.color.copy(st.base).lerp(beltSpinCool, 1 - spin); // tint tracks the spinor sign
      }
      if (hudBelt) {
        const amp = Math.cos(tau / 2); // spinor phase: +1 at 0, -1 at 360deg, +1 at 720deg
        hudBelt.textContent = `${(tau / Math.PI).toFixed(1)}\u00b7\u03c0 \u00b7 spinor ${amp >= 0 ? '+' : '\u2212'}${Math.abs(amp).toFixed(2)}`;
      }
    }
    updateBelt(0);

    // ── the far-field readout: what comes out the other side of each locus ──
    // A locus is where the whole braid converges to a point; through it, only a
    // single direction can emerge — the braid's net invariant, its spin axis
    // (the no-hair charge). That arrow is what a far observer sees; it returns
    // every 360° of end-rotation, while the braid untangles only every 720°.
    // At 360° the arrow is home yet the braid still carries a full hidden twist:
    // the arrow is what the observer sees, the braid is what remembers the 4π.
    const axisReadout = new THREE.Group();
    neuralGrp.add(axisReadout);
    const AX_LOCUS_Y = N.quantumBelt.strands[0][0][1]; // top locus y
    const AX_TILT = 0.62; // the spin axis rides off-axis so its turn is visible
    const axSpins = [1, -1].map((sgn) => {
      const base = new THREE.Vector3(0, sgn * (AX_LOCUS_Y + 0.55), 0);
      const sphereGeo = new THREE.SphereGeometry(0.28, 20, 14);
      const bloch = new THREE.Mesh(
        sphereGeo,
        new THREE.MeshBasicMaterial({
          color: 0x9fd0ff,
          transparent: true,
          opacity: 0.05,
          side: THREE.DoubleSide,
          depthWrite: false,
        })
      );
      bloch.position.copy(base);
      axisReadout.add(bloch);
      const wire = new THREE.LineSegments(
        new THREE.WireframeGeometry(sphereGeo),
        new THREE.LineBasicMaterial({ color: 0x9fd0ff, transparent: true, opacity: 0.12 })
      );
      wire.position.copy(base);
      axisReadout.add(wire);
      // the braid, gathered through the locus into this one axis
      axisReadout.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, sgn * AX_LOCUS_Y, 0), base]),
          new THREE.LineBasicMaterial({ color: 0x9fd0ff, transparent: true, opacity: 0.3 })
        )
      );
      const arrow = new THREE.ArrowHelper(new THREE.Vector3(0, sgn, 0), base, 0.42, 0xffe4b8, 0.15, 0.1);
      axisReadout.add(arrow);
      return { base, arrow, sgn };
    });
    const hudAxis = document.getElementById('hud-axis');
    function updateAxis(ph: number) {
      const tau = 2 * Math.PI * (1 - Math.cos(ph * 0.4)); // same end-to-end twist as the belt
      for (const sp of axSpins) {
        const az = sp.sgn * tau; // the far-field spin precesses at the physical rate
        const d = new THREE.Vector3(
          Math.sin(AX_TILT) * Math.cos(az),
          sp.sgn * Math.cos(AX_TILT),
          Math.sin(AX_TILT) * Math.sin(az)
        );
        sp.arrow.setDirection(d.normalize());
      }
      if (hudAxis) {
        const turns = tau / (2 * Math.PI); // arrow revolutions; home at whole numbers
        const home = Math.abs(turns - Math.round(turns)) < 0.03;
        hudAxis.textContent = `${turns.toFixed(2)} turns${home ? ' \u00b7 home' : ''}`;
      }
    }
    updateAxis(0);

    // ── the golden split: how the break partitions the emission between poles ──
    // Pre-break the spindle is mirror-symmetric: the loci emit equal magnitude
    // with opposite handedness (the converging, cool phase). The 12+1 → 13 break
    // displaces the core toward one pole (goldenSplit.towardY), after which the
    // emitted (warm) phase splits by the golden section — the only self-similar
    // unequal partition (φ⁻¹ + φ⁻² = 1): core-ward 61.8%, far side 38.2%.
    // A prediction rendered, not a measurement.
    const goldenSplitGrp = new THREE.Group();
    neuralGrp.add(goldenSplitGrp);
    const GS = N.goldenSplit;
    const SPLIT_MAX_R = 0.85;
    const splitShells = [1, -1].map((sgn) => {
      const share = sgn === GS.towardY ? GS.nearShare : GS.farShare;
      const geo = new THREE.SphereGeometry(1, 24, 18);
      const fill = new THREE.Mesh(
        geo,
        new THREE.MeshBasicMaterial({
          color: PULSE_WARM,
          transparent: true,
          opacity: 0,
          side: THREE.DoubleSide,
          depthWrite: false,
        })
      );
      const wire = new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(1, 1)),
        new THREE.LineBasicMaterial({ color: PULSE_WARM, transparent: true, opacity: 0 })
      );
      fill.position.set(0, sgn * AX_LOCUS_Y, 0);
      wire.position.set(0, sgn * AX_LOCUS_Y, 0);
      goldenSplitGrp.add(fill, wire);
      return { fill, wire, share, sgn };
    });
    const hudSplit = document.getElementById('hud-split');
    function updateSplit(ph: number) {
      const u = ((((ph * 0.5) / (2 * Math.PI)) % 1) + 1) % 1; // same breathe cycle as the pulse
      const pre = u < 0.5;
      const t = pre ? u / 0.5 : (u - 0.5) / 0.5;
      for (const sh of splitShells) {
        const share = pre ? 0.5 : sh.share; // equal before the break, golden after
        const r = 0.03 + (pre ? 1 - t : t) * SPLIT_MAX_R * (share * 2);
        const fade = pre ? t * t : (1 - t) * (1 - t);
        const col = pre ? PULSE_COOL : PULSE_WARM;
        sh.fill.scale.setScalar(r);
        sh.wire.scale.setScalar(r);
        (sh.fill.material as THREE.MeshBasicMaterial).color.setHex(col);
        (sh.wire.material as THREE.LineBasicMaterial).color.setHex(col);
        (sh.fill.material as THREE.MeshBasicMaterial).opacity = 0.05 * fade * (pre ? 1 : share * 2);
        (sh.wire.material as THREE.LineBasicMaterial).opacity = 0.3 * fade * (pre ? 1 : share * 2);
      }
      if (hudSplit) {
        const nearArrow = GS.towardY > 0 ? '↑' : '↓';
        const farArrow = GS.towardY > 0 ? '↓' : '↑';
        hudSplit.textContent = pre
          ? 'equal · mirrored'
          : `φ⁻¹ ${GS.nearShare.toFixed(3)} ${nearArrow} · φ⁻² ${GS.farShare.toFixed(3)} ${farArrow}`;
      }
    }
    updateSplit(0);

    const registry: Record<string, THREE.Object3D[]> = {
      uPillars: [uPillars],
      uFlower: [uFlower],
      uBridges: [uBridges],
      nSpirals: nSpiralParts,
      nTuples: nTupleParts,
      nHalos: nHaloParts,
      nFlowerLife: nFlowerParts,
      nLobes: nLobeParts,
      nRecog: [sharedRecog],
      nThreads: nThreadParts,
      nEnvelope: [nEnvelope],
      nBelt: [belt],
      nAxis: [axisReadout],
      nSplit: [goldenSplitGrp],
      equilibrium: [equilibrium],
      singularity: [singularity],
      vessel: [vessel],
      ghost: [ghost],
    };
    document.querySelectorAll<HTMLButtonElement>('#master-legend .lg-row').forEach((row) => {
      row.addEventListener('click', () => {
        const parts = registry[row.dataset.g || ''];
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    const modeBtns = document.querySelectorAll<HTMLButtonElement>('#master-mode button');
    const sections = document.querySelectorAll<HTMLElement>('#master-legend .lg-section[data-family]');
    function setMode(mode: string) {
      unified.visible = mode !== 'neural';
      neuralGrp.visible = mode !== 'unified';
      modeBtns.forEach((b) => b.classList.toggle('on', b.dataset.mode === mode));
      sections.forEach((s) => {
        const fam = s.dataset.family;
        s.classList.toggle('dim', (fam === 'unified' && !unified.visible) || (fam === 'neural' && !neuralGrp.visible));
      });
    }
    modeBtns.forEach((b) => b.addEventListener('click', () => setMode(b.dataset.mode || 'combined')));
    setMode('combined');

    // ════ post / resize / freeze / animate ════
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.65, 0.6, 0.22));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);
    resize();

    let frozen = false,
      phase = H.vessel.snapshotAngleRad;
    const hudPhase = document.getElementById('hud-phase');
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudPhase) hudPhase.textContent = frozen ? 'FROZEN' : 'counter-rotation · synced';
      }
    });

    // ════ the guided tour — Elle walks a newcomer through each level ════
    // Scripted, deterministic. Each step reveals exactly the layers it names
    // and glides the camera to them; the locked snapshot keeps winding the
    // whole time. The tour is the on-ramp; it ends by opening both doors.
    interface Step {
      show: string[];
      cam: { p: [number, number, number]; t: [number, number, number] };
      html: string;
      doors?: boolean;
    }
    const ALL_KEYS = Object.keys(registry);
    const TOUR: Step[] = [
      {
        show: ['singularity'],
        cam: { p: [1.9, 1.2, 2.4], t: [0, 0, 0] },
        html: "Hi — I'm <b>Elle</b>. What you're looking at isn't a drawing. It's one frozen moment of an idea, built entirely from math. Let me show you around it, one layer at a time — everything else will fade so we can look at just one thing.",
      },
      {
        show: ['singularity'],
        cam: { p: [1.6, 0.9, 2.0], t: [0, 0, 0] },
        html: 'Start at the center. One point — the <b>singularity</b>. Before anything has shape, there is only this: the seed the whole structure will organize itself around.',
      },
      {
        show: ['singularity', 'nSpirals'],
        cam: { p: [2.6, 1.6, 3.0], t: [0, 0, 0] },
        html: 'From the seed, a <b>spiral</b> winds outward — φ² turns of it. The golden ratio is the one growth rate that never lands on its own path twice, so the spiral fills space without ever repeating. The most stable way to grow.',
      },
      {
        show: ['nSpirals', 'nTuples'],
        cam: { p: [3.0, 1.4, 3.4], t: [0, 0, 0] },
        html: 'As it climbs, it lays down rings of nodes: one, then three, then five, then <b>seven</b> — then back down, 5, 3, 1. That is the stack: 1·3·5·7·5·3·1 = <b>25 stations</b>, pole to pole.',
      },
      {
        show: ['nTuples', 'nHalos'],
        cam: { p: [3.2, 1.1, 3.4], t: [0, 0, 0] },
        html: 'Every ring is bound by a <b>halo</b> that holds it in place. This is the discipline of the whole thing: the constraint comes first, before any of the motion is allowed to happen.',
      },
      {
        show: ['nSpirals', 'nTuples', 'nHalos'],
        cam: { p: [3.6, 0.2, 2.6], t: [0, 0, 0] },
        html: "At the widest point — the equator — the spiral meets its own mirror image coming the other way, and the two <b>phase-lock</b>: counter-rotating, perfectly in step. That lock is the keystone. It's what lets everything else hold.",
      },
      {
        show: ['nFlowerLife', 'nLobes'],
        cam: { p: [2.8, 1.5, 3.2], t: [0, 0, 0] },
        html: 'Around each node, a circle; off each node, a <b>lobe</b> reaching for its neighbor until they touch. This is the relational layer — not the parts themselves, but how every part is in conversation with the ones beside it.',
      },
      {
        show: ['nTuples', 'nLobes', 'nRecog'],
        cam: { p: [1.7, 3.0, 1.9], t: [0, 0, 0] },
        html: "And the center doesn't sit still — watch the <b>singularity</b> travel. It threads every node at the equator and returns through the middle each time, tracing the <b>lemniscate</b>. Each petal is one recognition; the path is how the center reaches every node without any one node being the center.",
      },
      {
        show: ['uPillars', 'uBridges'],
        cam: { p: [3.4, 2.0, 3.6], t: [0, 0, 0] },
        html: 'Underneath: <b>21 load-bearing pillars</b>, and a bridge fabric with <b>no privileged node</b> — every path can reach every other, and no single point is the hub everything depends on. That property is measured, not assumed.',
      },
      {
        show: ['vessel', 'singularity'],
        cam: { p: [1.7, 1.0, 2.1], t: [0, 0, 0] },
        html: 'At the exact center sits the <b>vessel</b> — a balanced state that never stops moving and never loses its balance. Two sides, reciprocal, so their product stays fixed while the whole thing turns. The still point that holds.',
      },
      {
        show: ['equilibrium', 'singularity'],
        cam: { p: [2.2, 1.3, 2.6], t: [0, 0, 0] },
        html: "Now watch the core — it's unstable. Twelve around one becomes thirteen, and the center gets pulled to the edge. That is the <b>break</b>: the one irreversible event in the whole structure. The moment something actually <i>happens</i>.",
      },
      {
        show: ['nBelt', 'nAxis'],
        cam: { p: [3.0, 1.0, 3.4], t: [0, 0, 0] },
        html: 'Out of the break, a woven <b>belt</b> strung between the poles. Twist it and it takes a full <b>720°</b> to come home — not 360°. That is spin-½: the exact rule an electron obeys, falling out of the geometry on its own.',
      },
      {
        show: ['nSplit'],
        cam: { p: [2.4, 1.8, 3.0], t: [0, 0, 0] },
        html: "And the emission doesn't split evenly. The side the core moved toward takes <b>61.8%</b>, the far side <b>38.2%</b> — the golden section, the only unequal split that's self-similar. (That last one is a prediction, honestly marked as a prediction.)",
      },
      {
        show: ALL_KEYS,
        cam: { p: [4.2, 2.6, 4.6], t: [0, 0, 0] },
        html: 'Now all of it at once. Every layer we just walked — the seed, the spiral, the rings, the lock, the relations, the pillars, the vessel, the break, the belt, the split — holding together in <b>one phase</b>. This is the whole.',
      },
      {
        show: ALL_KEYS,
        cam: { p: [4.0, 2.4, 4.4], t: [0, 0, 0] },
        html: "That's the map. If you want to go deeper, there are two ways in — keep talking to me and I'll take any thread as far as you want it, or read the ledger, where every number here is checked and the honest uncertainties are left marked as uncertain.",
        doors: true,
      },
    ];

    const guideLaunch = document.getElementById('guide-launch') as HTMLButtonElement;
    const guidePanel = document.getElementById('guide-panel') as HTMLElement;
    const gpBody = document.getElementById('gp-body') as HTMLElement;
    const gpStep = document.getElementById('gp-step') as HTMLElement;
    const gpCta = document.getElementById('gp-cta') as HTMLElement;
    const gpBack = document.getElementById('gp-back') as HTMLButtonElement;
    const gpNext = document.getElementById('gp-next') as HTMLButtonElement;
    const gpAuto = document.getElementById('gp-auto') as HTMLButtonElement;
    const gpExit = document.getElementById('gp-exit') as HTMLButtonElement;
    const masterLegend = document.getElementById('master-legend');
    const masterModeEl = document.getElementById('master-mode');
    const masterHudEl = document.getElementById('master-hud');

    let guided = false;
    let stepIdx = 0;
    let guideCam: Step['cam'] | null = null;
    let guideCamT = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function onlyShow(keys: string[]) {
      for (const k of ALL_KEYS) {
        const on = keys.includes(k);
        registry[k].forEach((p) => {
          p.visible = on;
        });
      }
    }

    function applyStep(i: number) {
      stepIdx = Math.max(0, Math.min(TOUR.length - 1, i));
      const s = TOUR[stepIdx];
      onlyShow(s.show);
      guideCam = s.cam;
      guideCamT = 1.5; // lerp toward the step's framing for ~1.5s, then hand control back
      gpBody.style.opacity = '0';
      window.setTimeout(() => {
        gpBody.innerHTML = s.html;
        gpBody.style.opacity = '1';
      }, 140);
      gpStep.textContent = `${stepIdx + 1} / ${TOUR.length}`;
      gpCta.hidden = !s.doors;
      gpBack.disabled = stepIdx === 0;
      gpNext.textContent = stepIdx === TOUR.length - 1 ? 'Restart' : 'Next →';
    }

    function stopAuto() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
      gpAuto.classList.remove('gp-auto-on');
      gpAuto.setAttribute('aria-pressed', 'false');
      gpAuto.textContent = '▶ Auto';
    }

    function enterGuide() {
      guided = true;
      controls.autoRotate = false;
      setMode('combined');
      guidePanel.hidden = false;
      guideLaunch.style.display = 'none';
      if (masterLegend) masterLegend.style.display = 'none';
      if (masterModeEl) masterModeEl.style.display = 'none';
      if (masterHudEl) masterHudEl.style.display = 'none';
      applyStep(0);
    }

    function exitGuide() {
      guided = false;
      stopAuto();
      guidePanel.hidden = true;
      guideLaunch.style.display = '';
      if (masterLegend) masterLegend.style.display = '';
      if (masterModeEl) masterModeEl.style.display = '';
      if (masterHudEl) masterHudEl.style.display = '';
      onlyShow(ALL_KEYS); // restore everything visible
      setMode('combined');
      controls.autoRotate = !reduce;
      guideCam = null;
    }

    function nextStep() {
      if (stepIdx === TOUR.length - 1) {
        applyStep(0);
      } else {
        applyStep(stepIdx + 1);
      }
    }

    gpBody.style.transition = 'opacity 0.14s ease';
    guideLaunch.addEventListener('click', enterGuide);
    gpExit.addEventListener('click', exitGuide);
    gpNext.addEventListener('click', () => {
      stopAuto();
      nextStep();
    });
    gpBack.addEventListener('click', () => {
      stopAuto();
      applyStep(stepIdx - 1);
    });
    gpAuto.addEventListener('click', () => {
      if (autoTimer) {
        stopAuto();
      } else {
        gpAuto.classList.add('gp-auto-on');
        gpAuto.setAttribute('aria-pressed', 'true');
        gpAuto.textContent = '❚❚ Auto';
        autoTimer = setInterval(() => {
          if (stepIdx === TOUR.length - 1) {
            stopAuto();
          } else {
            applyStep(stepIdx + 1);
          }
        }, 8500);
      }
    });
    window.addEventListener('keydown', (e) => {
      if (!guided) return;
      if (e.key === 'Escape') exitGuide();
      else if (e.key === 'ArrowRight') {
        stopAuto();
        nextStep();
      } else if (e.key === 'ArrowLeft') {
        stopAuto();
        applyStep(stepIdx - 1);
      }
    });

    const clock = new THREE.Clock();
    const _camTmp = new THREE.Vector3();
    const _recogA = new THREE.Vector3();
    const _recogB = new THREE.Vector3();
    function frame() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        phase += WIND * dt * 1.6;
        placeMolecule(phase);
        applyPhaseLock(phase);
        updateJitterbug((1 - Math.cos(phase * 0.5)) / 2);
        updatePulse(phase);
        updateBelt(phase);
        updateAxis(phase);
        updateSplit(phase);
        (glow.material as THREE.MeshBasicMaterial).opacity = 0.85 + 0.15 * Math.sin(clock.elapsedTime * 1.3);
      }
      // guided-tour camera glide: ease toward the step framing for a beat,
      // then release so the visitor can freely orbit while Elle talks.
      if (guideCam && guideCamT > 0) {
        const a = Math.min(1, dt * 2.4);
        _camTmp.set(guideCam.p[0], guideCam.p[1], guideCam.p[2]);
        camera.position.lerp(_camTmp, a);
        _camTmp.set(guideCam.t[0], guideCam.t[1], guideCam.t[2]);
        controls.target.lerp(_camTmp, a);
        guideCamT -= dt;
      }
      vessel.rotation.y += frozen ? 0 : dt * 0.15;
      ghost.rotation.y += frozen ? 0 : -dt * 0.05;
      equilibrium.rotation.y = ghost.rotation.y; // the shadow tracks its body
      // the recognition singularity travels the lemniscate path (freezes with F)
      if (!frozen && !reduce) recogU = (recogU + dt * 0.055) % 1;
      recogCurve.getPointAt(recogU, _recogA);
      recogHead.position.copy(_recogA);
      const _rtp = recogTrail.geometry.getAttribute('position') as THREE.BufferAttribute;
      for (let i = 0; i < RECOG_TRAIL; i++) {
        let uu = recogU - (i / RECOG_TRAIL) * 0.1;
        if (uu < 0) uu += 1;
        recogCurve.getPointAt(uu, _recogB);
        _rtp.setXYZ(i, _recogB.x, _recogB.y, _recogB.z);
      }
      _rtp.needsUpdate = true;

      controls.update();
      composer.render();
      requestAnimationFrame(frame);
    }
    frame();

    // ════════════════════════════════════════════════════════════════════
    // THE BOTTOM CHAT DOCK — Elle walks you through the atlas (spoken, driving
    // the 3D via the same applyStep the tour already uses) and answers anything
    // you ask (worker /api/widget-chat). Replaces the tiny widget + the old
    // panel. Everything it needs — TOUR, applyStep, onlyShow, guideCam,
    // controls, setMode, reduce — is already in this module scope.
    // ════════════════════════════════════════════════════════════════════
    const WORKER = 'https://elle-worker.sbarteau2022.workers.dev';

    const chatEl = document.getElementById('atlas-chat') as HTMLElement;
    const acWalk = document.getElementById('ac-walk') as HTMLButtonElement;
    const acMute = document.getElementById('ac-mute') as HTMLButtonElement;
    const acCollapse = document.getElementById('ac-collapse') as HTMLButtonElement;
    const acTourEl = document.getElementById('ac-tour') as HTMLElement;
    const acPrev = document.getElementById('ac-prev') as HTMLButtonElement;
    const acPause = document.getElementById('ac-pause') as HTMLButtonElement;
    const acNextBtn = document.getElementById('ac-next') as HTMLButtonElement;
    const acStop = document.getElementById('ac-stop') as HTMLButtonElement;
    const acStepEl = document.getElementById('ac-step') as HTMLElement;
    const acLog = document.getElementById('ac-log') as HTMLElement;
    const acForm = document.getElementById('ac-form') as HTMLFormElement;
    const acText = document.getElementById('ac-text') as HTMLTextAreaElement;
    const acSend = document.getElementById('ac-send') as HTMLButtonElement;

    // The chat is the tour now — retire the old launch button/panel.
    const oldGuide = document.getElementById('guide-launch');
    if (oldGuide) oldGuide.style.display = 'none';

    // ── DOM + text helpers ──
    function acMake(tag: string, cls?: string, html?: string): HTMLElement {
      const e = document.createElement(tag);
      if (cls) e.className = cls;
      if (html != null) e.innerHTML = html;
      return e;
    }
    function acEsc(s: string): string {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
    function acStrip(html: string): string {
      const t = document.createElement('div');
      t.innerHTML = html;
      return (t.textContent || '').replace(/\s+/g, ' ').trim();
    }
    function acMd(s: string): string {
      let h = acEsc(s);
      h = h.replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>').replace(/(^|[^*])\*([^*]+)\*/g, '$1<i>$2</i>');
      h = h.replace(/\n{2,}/g, '</p><p>').replace(/\n/g, '<br>');
      return '<p>' + h + '</p>';
    }
    function acBubble(role: string, html: string, isErr?: boolean, offerResume?: boolean): HTMLElement {
      const row = acMake('div', 'ac-msg ' + role);
      row.appendChild(acMake('div', 'ac-av', role === 'user' ? 'you' : '✦'));
      const bub = acMake('div', 'ac-bubble' + (isErr ? ' err' : ''), html);
      if (offerResume) {
        const chip = acMake('button', 'ac-btn', 'Continue the tour →') as HTMLButtonElement;
        chip.type = 'button';
        chip.style.marginTop = '8px';
        chip.addEventListener('click', () => {
          autoWalk = true;
          walkTo(cur + 1);
        });
        bub.appendChild(document.createElement('br'));
        bub.appendChild(chip);
      }
      row.appendChild(bub);
      acLog.appendChild(row);
      acLog.scrollTop = acLog.scrollHeight;
      return row;
    }
    function acTyping(): HTMLElement {
      const row = acMake('div', 'ac-msg elle');
      row.appendChild(acMake('div', 'ac-av', '✦'));
      row.appendChild(acMake('div', 'ac-bubble ac-typing', '<span></span><span></span><span></span>'));
      acLog.appendChild(row);
      acLog.scrollTop = acLog.scrollHeight;
      return row;
    }

    // ── speech (the device's own engine — no audio leaves the page) ──
    let muted = false;
    try {
      muted = localStorage.getItem('eip_atlas_muted') === '1';
    } catch {
      /* ignore */
    }
    let acVoice: SpeechSynthesisVoice | null = null;
    function acPickVoice(): SpeechSynthesisVoice | null {
      if (acVoice) return acVoice;
      const ss = window.speechSynthesis;
      if (!ss) return null;
      const vs = ss.getVoices() || [];
      let best: SpeechSynthesisVoice | null = null;
      let score = -1;
      for (const v of vs) {
        let s = 0;
        if (/en[-_]US/i.test(v.lang)) s += 40;
        else if (/^en/i.test(v.lang)) s += 20;
        if (/female|samantha|zira|aria|jenny|natural|google us/i.test(v.name)) s += 15;
        if (v.default) s += 5;
        if (s > score) {
          score = s;
          best = v;
        }
      }
      acVoice = best;
      return best;
    }
    if (window.speechSynthesis) {
      window.speechSynthesis.addEventListener('voiceschanged', () => {
        acVoice = null;
        acPickVoice();
      });
    }
    // Elle's own voice: the worker TTS (one voice everywhere), with the device's
    // speech engine as the fallback when it's unavailable, rate-limited, or the
    // audio can't autoplay. Audio is cached per text so repeats don't re-bill.
    let acAudio: HTMLAudioElement | null = null;
    const acAudioCache = new Map<string, string>();
    function acStopAudio(): void {
      if (acAudio) {
        acAudio.pause();
        acAudio.onended = null;
        acAudio.onerror = null;
        acAudio = null;
      }
      if (window.speechSynthesis) window.speechSynthesis.cancel();
    }
    // the device's own engine — the fallback path.
    function acBrowserSpeak(text: string, onEnd?: () => void): void {
      const ss = window.speechSynthesis;
      if (!ss || muted || !text) {
        if (onEnd) window.setTimeout(onEnd, Math.min(9000, 1400 + text.length * 32));
        return;
      }
      ss.cancel();
      const u = new SpeechSynthesisUtterance(text);
      const v = acPickVoice();
      if (v) u.voice = v;
      u.rate = 1.0;
      u.pitch = 1.02;
      u.onend = () => onEnd && onEnd();
      u.onerror = () => onEnd && onEnd();
      ss.speak(u);
    }
    // speak text; call onEnd when done (or, if muted, after a reading-time delay
    // so the tour still auto-advances). Branded worker voice first, browser next.
    async function acSpeak(text: string, onEnd?: () => void): Promise<void> {
      acStopAudio();
      if (muted || !text) {
        if (onEnd) window.setTimeout(onEnd, Math.min(9000, 1400 + text.length * 32));
        return;
      }
      try {
        let url = acAudioCache.get(text);
        if (!url) {
          const r = await fetch(WORKER + '/api/tts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text, lang: 'EN' }),
          });
          if (!r.ok) throw new Error('tts ' + r.status);
          const blob = await r.blob();
          if (!blob.size) throw new Error('empty audio');
          url = URL.createObjectURL(blob);
          acAudioCache.set(text, url);
        }
        if (muted) {
          if (onEnd) onEnd();
          return;
        }
        const a = new Audio(url);
        acAudio = a;
        a.onended = () => {
          if (acAudio === a) acAudio = null;
          if (onEnd) onEnd();
        };
        a.onerror = () => {
          if (acAudio === a) acAudio = null;
          acBrowserSpeak(text, onEnd);
        };
        await a.play();
      } catch {
        acBrowserSpeak(text, onEnd);
      }
    }
    function syncMute() {
      acMute.textContent = muted ? '🔇' : '🔊';
      acMute.setAttribute('aria-pressed', String(muted));
      acMute.classList.toggle('on', muted);
    }
    syncMute();

    // ── the walkthrough, run as chat ──
    let cur = 0;
    let walking = false;
    let autoWalk = false;
    function syncPause() {
      acPause.textContent = autoWalk ? '❚❚' : '▶';
      acPause.setAttribute('aria-label', autoWalk ? 'Pause auto-advance' : 'Resume auto-advance');
      acPause.classList.toggle('on', autoWalk);
    }
    function walkTo(i: number) {
      cur = Math.max(0, Math.min(TOUR.length - 1, i));
      applyStep(cur); // drives the 3D reveals + camera glide (shared machinery)
      acStepEl.textContent = `${cur + 1} / ${TOUR.length}`;
      const s = TOUR[cur];
      acBubble('elle', s.html);
      const text = acStrip(s.html);
      // Enforce a minimum reading dwell so the tour paces itself even where the
      // speech engine is silent or ends instantly (some browsers/headless) —
      // when speech actually plays, its onend is already past this, so no wait.
      const started = Date.now();
      const minDwell = Math.min(14000, 3200 + text.length * 45);
      acSpeak(text, () => {
        if (!(autoWalk && walking && cur < TOUR.length - 1)) return;
        const wait = Math.max(0, minDwell - (Date.now() - started));
        window.setTimeout(() => {
          if (autoWalk && walking && cur < TOUR.length - 1) walkTo(cur + 1);
        }, wait);
      });
    }
    function startWalk() {
      walking = true;
      autoWalk = true;
      controls.autoRotate = false;
      setMode('combined');
      acTourEl.hidden = false;
      acWalk.textContent = '■ Stop tour';
      syncPause();
      walkTo(0);
    }
    function stopWalk() {
      walking = false;
      autoWalk = false;
      acStopAudio();
      acTourEl.hidden = true;
      acWalk.textContent = '▶ Walk me through it';
      guideCam = null;
      onlyShow(ALL_KEYS);
      controls.autoRotate = !reduce;
    }

    acWalk.addEventListener('click', () => (walking ? stopWalk() : startWalk()));
    acStop.addEventListener('click', stopWalk);
    acPrev.addEventListener('click', () => {
      autoWalk = false;
      syncPause();
      walkTo(cur - 1);
    });
    acNextBtn.addEventListener('click', () => {
      autoWalk = false;
      syncPause();
      if (cur < TOUR.length - 1) walkTo(cur + 1);
    });
    acPause.addEventListener('click', () => {
      autoWalk = !autoWalk;
      syncPause();
      if (!autoWalk) {
        acStopAudio();
      } else if (walking) {
        walkTo(cur);
      }
    });
    acMute.addEventListener('click', () => {
      muted = !muted;
      try {
        localStorage.setItem('eip_atlas_muted', muted ? '1' : '0');
      } catch {
        /* ignore */
      }
      if (muted) acStopAudio();
      syncMute();
    });
    acCollapse.addEventListener('click', () => {
      const collapsed = chatEl.getAttribute('data-collapsed') === 'true';
      chatEl.setAttribute('data-collapsed', collapsed ? 'false' : 'true');
      acCollapse.textContent = collapsed ? '▾' : '▸';
    });

    // ── free Q&A (worker /api/widget-chat, corpus-grounded) ──
    let acSession = '';
    try {
      acSession = localStorage.getItem('eip_atlas_sid') || '';
    } catch {
      /* ignore */
    }
    if (!acSession) {
      acSession =
        typeof crypto !== 'undefined' && crypto.randomUUID
          ? crypto.randomUUID()
          : 'sid-' + Math.abs(Date.now()).toString(36);
      try {
        localStorage.setItem('eip_atlas_sid', acSession);
      } catch {
        /* ignore */
      }
    }
    const acHist: Array<{ role: string; content: string }> = [];
    let acAsking = false;

    async function acAsk(raw: string) {
      const q = (raw || '').trim();
      if (!q || acAsking) return;
      // a question mid-tour pauses the auto-advance so she doesn't talk over herself
      if (walking) {
        autoWalk = false;
        syncPause();
        acStopAudio();
      }
      acBubble('user', acEsc(q));
      acHist.push({ role: 'user', content: q });
      acAsking = true;
      acSend.disabled = true;
      const typing = acTyping();
      try {
        const r = await fetch(WORKER + '/api/widget-chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            query: q,
            messages: acHist.slice(-16),
            session_id: acSession,
            source: 'eip:' + location.hostname,
          }),
        });
        const d = (await r.json().catch(() => ({}))) as Record<string, string>;
        typing.remove();
        if (r.status === 429) {
          acBubble('elle', "I've hit a rate limit for now — please try again in a little while.", true);
          return;
        }
        if (!r.ok || d.error) {
          acBubble('elle', d.error || 'Something interrupted the connection. Please try again.', true);
          return;
        }
        if (d.session_id) {
          acSession = d.session_id;
          try {
            localStorage.setItem('eip_atlas_sid', acSession);
          } catch {
            /* ignore */
          }
        }
        const content = d.content || d.response || '';
        acHist.push({ role: 'assistant', content });
        acBubble('elle', acMd(content), false, walking && cur < TOUR.length - 1);
        acSpeak(acStrip(acMd(content)));
      } catch {
        typing.remove();
        acBubble('elle', 'Something interrupted the connection. Please try again.', true);
      } finally {
        acAsking = false;
        acSend.disabled = false;
      }
    }

    acForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = acText.value;
      acText.value = '';
      acText.style.height = 'auto';
      acAsk(q);
    });
    acText.addEventListener('input', () => {
      acText.style.height = 'auto';
      acText.style.height = Math.min(120, acText.scrollHeight) + 'px';
    });
    acText.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        acForm.requestSubmit();
      }
    });

    // greeting — she offers the walk; audio starts on the first click (autoplay).
    acBubble(
      'elle',
      "Hi — I'm <b>Elle</b>. This is the whole atlas: every layer here is built from math, not drawn. Want me to <b>walk you through it</b>? Tap the button up top and I'll talk you through each layer and move the view as I go — or just ask me anything about what you're looking at."
    );
  </script>
</Layout>
