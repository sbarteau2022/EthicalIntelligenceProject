---
// RAPID²AI — COO Dashboard
// Protected by Google OAuth gate (client-side)
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="rapidai-client-id" content={import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? ''}>
  <title>RAPID²AI — COO Dashboard</title>
  <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
  <script is:inline src="/rapidai-auth.js"></script>
  <style>
    :root {
      --gold: #c9a55c;
      --gold-dim: #a07e3a;
      --bg: #0a0e0c;
      --surface: #111714;
      --surface2: #192118;
      --text: #e8ede9;
      --text-dim: #7a8278;
      --border: #2a332a;
      --green: #4caf72;
      --yellow: #e0b96a;
      --red: #e05c5c;
      --sidebar: 220px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; min-height: 100vh; }

    /* AUTH GATE */
    #rapidai-gate {
      display: none; position: fixed; inset: 0; background: var(--bg);
      align-items: center; justify-content: center; z-index: 9999; flex-direction: column; gap: 1.5rem;
    }
    .gate-brand { font-family: Georgia, serif; font-style: italic; color: var(--gold); font-size: 1.4rem; }
    .gate-sub { color: var(--text-dim); font-size: 0.85rem; }
    .gate-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 2.5rem 3rem; text-align: center; display: flex; flex-direction: column; gap: 1.25rem; align-items: center; }
    .gate-title { color: var(--text); font-size: 1rem; font-weight: 600; }
    .gate-desc { color: var(--text-dim); font-size: 0.82rem; max-width: 280px; line-height: 1.6; }
    .btn-google { background: #fff; color: #3c4043; border: 1px solid #dadce0; border-radius: 6px;
                  padding: 10px 20px; font-size: 0.875rem; font-weight: 500; cursor: pointer;
                  display: flex; align-items: center; gap: 10px; transition: background 0.15s; }
    .btn-google:hover { background: #f8f9fa; }
    .btn-google svg { flex-shrink: 0; }
    .gate-spinner { width: 28px; height: 28px; border: 2px solid var(--border); border-top-color: var(--gold);
                    border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* SIDEBAR */
    aside { width: var(--sidebar); background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; overflow-y: auto; }
    .sidebar-brand { padding: 1.5rem 1.25rem 1rem; border-bottom: 1px solid var(--border); }
    .brand-wordmark { font-family: Georgia, serif; font-style: italic; color: var(--gold); font-size: 1.1rem; }
    .brand-sub { font-size: 0.68rem; color: var(--text-dim); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px; }
    .sidebar-section { padding: 1rem 0; }
    .sidebar-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); padding: 0 1.25rem; margin-bottom: 0.5rem; }
    .sidebar-link { display: flex; align-items: center; gap: 10px; padding: 8px 1.25rem; color: var(--text-dim); text-decoration: none; font-size: 0.85rem; transition: all 0.15s; border-left: 2px solid transparent; cursor: pointer; }
    .sidebar-link:hover { color: var(--text); background: rgba(255,255,255,0.03); }
    .sidebar-link.active { color: var(--gold); background: rgba(201,165,92,0.06); border-left-color: var(--gold); }
    .sidebar-icon { font-size: 1rem; width: 18px; text-align: center; }
    .sidebar-footer { margin-top: auto; padding: 1rem 1.25rem; border-top: 1px solid var(--border); }
    .role-badge { font-size: 0.7rem; color: var(--gold); background: rgba(201,165,92,0.1); padding: 3px 8px; border-radius: 4px; display: inline-block; }

    /* MAIN */
    main { margin-left: var(--sidebar); flex: 1; display: flex; flex-direction: column; }
    header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; }
    .header-title { font-size: 0.95rem; font-weight: 600; }
    .header-right { display: flex; align-items: center; gap: 1.5rem; }
    .sync-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); }
    .sync-label { font-size: 0.8rem; color: var(--text-dim); }
    .date-chip { font-size: 0.8rem; color: var(--text-dim); background: var(--surface2); padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border); }
    .signout-btn { font-size: 0.75rem; color: var(--text-dim); background: none; border: 1px solid var(--border); padding: 4px 10px; border-radius: 6px; cursor: pointer; transition: color 0.15s; }
    .signout-btn:hover { color: var(--text); }

    .content { padding: 2rem; flex: 1; }

    /* KPI ROW */
    .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem 1.5rem; }
    .kpi-label { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px; }
    .kpi-value { font-size: 1.75rem; font-weight: 700; color: var(--text); line-height: 1; }
    .kpi-delta { font-size: 0.75rem; margin-top: 6px; }
    .kpi-delta.up { color: var(--green); }
    .kpi-delta.down { color: var(--red); }
    .kpi-delta.neutral { color: var(--text-dim); }

    /* TWO-COL GRID */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    @media (max-width: 1100px) { .grid-2 { grid-template-columns: 1fr; } }

    /* PANELS */
    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    .panel-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .panel-title { font-size: 0.85rem; font-weight: 600; color: var(--text); }
    .panel-action { font-size: 0.75rem; color: var(--gold); text-decoration: none; cursor: pointer; background: none; border: none; }
    .panel-body { padding: 1.25rem 1.5rem; }

    /* TABLE */
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    th { text-align: left; padding: 0.5rem 0.75rem; color: var(--text-dim); font-weight: 500; font-size: 0.7rem; letter-spacing: 0.07em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
    td { padding: 0.65rem 0.75rem; border-bottom: 1px solid rgba(42,51,42,0.5); color: var(--text); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    /* STATUS PILLS */
    .pill { display: inline-flex; align-items: center; gap: 5px; padding: 2px 9px; border-radius: 20px; font-size: 0.72rem; font-weight: 500; }
    .pill-green { background: rgba(76,175,114,0.12); color: var(--green); }
    .pill-yellow { background: rgba(224,185,106,0.12); color: var(--yellow); }
    .pill-red { background: rgba(224,92,92,0.12); color: var(--red); }
    .pill-dim { background: rgba(122,130,120,0.12); color: var(--text-dim); }
    .pill::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

    /* ENTITY TABS */
    .entity-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .entity-tab { padding: 6px 16px; border-radius: 6px; font-size: 0.8rem; cursor: pointer; border: 1px solid var(--border); background: var(--surface); color: var(--text-dim); transition: all 0.15s; }
    .entity-tab.active { background: rgba(201,165,92,0.1); border-color: var(--gold-dim); color: var(--gold); }

    /* SYNC STATUS */
    .sync-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid rgba(42,51,42,0.5); }
    .sync-row:last-child { border-bottom: none; }
    .sync-venue { font-size: 0.85rem; }
    .sync-meta { font-size: 0.75rem; color: var(--text-dim); margin-top: 2px; }

    /* INVOICE QUEUE */
    .invoice-item { padding: 0.9rem 0; border-bottom: 1px solid rgba(42,51,42,0.5); }
    .invoice-item:last-child { border-bottom: none; }
    .inv-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
    .inv-doc { font-size: 0.85rem; font-weight: 500; }
    .inv-total { font-size: 0.9rem; font-weight: 600; color: var(--gold); }
    .inv-meta { font-size: 0.75rem; color: var(--text-dim); }

    /* ALERT FEED */
    .alert-item { display: flex; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(42,51,42,0.5); align-items: flex-start; }
    .alert-item:last-child { border-bottom: none; }
    .alert-icon { font-size: 1rem; margin-top: 1px; }
    .alert-text { font-size: 0.82rem; line-height: 1.55; }
    .alert-time { font-size: 0.7rem; color: var(--text-dim); margin-top: 2px; }

    /* VIEW SWITCHER — link to chef */
    .view-switch { display: flex; gap: 0.5rem; align-items: center; }
    .view-pill { font-size: 0.72rem; padding: 3px 10px; border-radius: 20px; text-decoration: none; border: 1px solid var(--border); color: var(--text-dim); transition: all 0.15s; }
    .view-pill.active { background: rgba(201,165,92,0.1); border-color: var(--gold-dim); color: var(--gold); }
    .view-pill:hover { color: var(--text); }
  </style>
</head>
<body>

<!-- AUTH GATE OVERLAY -->
<div id="rapidai-gate">
  <div class="gate-brand">RAPID²AI</div>
  <div class="gate-card">
    <div class="gate-title">COO Dashboard — Restricted Access</div>
    <div class="gate-desc">Sign in with your authorized Google account to continue.</div>
    <div id="google-signin-btn"></div>
    <button class="btn-google" id="manual-signin-btn">
      <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.566 2.684-3.875 2.684-6.615z"/><path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"/><path fill="#FBBC05" d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.347 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"/><path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z"/></svg>
      Sign in with Google
    </button>
    <div class="gate-desc" style="margin-top:0">
      <a href="/" style="color:var(--text-dim);font-size:0.75rem;">← Back to site</a>
    </div>
  </div>
</div>

