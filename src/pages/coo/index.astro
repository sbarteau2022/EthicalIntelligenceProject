</main>

<script>
  document.getElementById('dateChip').textContent = new Date().toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});

  function setEntity(btn, entity) {
    document.querySelectorAll('.entity-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
  }

  // Auth gate
  function initAuth() {
    if (RapidAIAuth.isAuthed()) {
      // Show content
      document.getElementById('rapidai-gate').style.display = 'none';
      // Show user email if stored
      const email = sessionStorage.getItem('rapidai_email');
      if (email) document.getElementById('user-email-display').textContent = email;
      return;
    }
    // Show gate
    document.getElementById('rapidai-gate').style.display = 'flex';

    const clientId = document.querySelector('meta[name="rapidai-client-id"]')?.content;

    if (clientId) {
      // Initialize Google Identity Services
      window.onload = function() { /* GSI loads async */ };
      function initGSI() {
        if (!window.google?.accounts) return setTimeout(initGSI, 100);
        google.accounts.id.initialize({
          client_id: clientId,
          callback: function(response) {
            if (response.credential) {
              sessionStorage.setItem('rapidai_auth', response.credential);
              sessionStorage.setItem('rapidai_authed_at', Date.now().toString());
              // Decode email from JWT payload
              try {
                const payload = JSON.parse(atob(response.credential.split('.')[1]));
                if (payload.email) sessionStorage.setItem('rapidai_email', payload.email);
              } catch(e) {}
              window.location.reload();
            }
          },
          auto_select: false,
          cancel_on_tap_outside: false,
        });
        google.accounts.id.renderButton(
          document.getElementById('google-signin-btn'),
          { theme: 'outline', size: 'large', text: 'signin_with' }
        );
      }
      initGSI();
    }

    // Manual button fallback (also used when no GSI)
    document.getElementById('manual-signin-btn').addEventListener('click', function() {
      if (!clientId) {
        RapidAIAuth.signIn('/coo/');
        return;
      }
      const redirectUri = window.location.origin + '/auth/callback';
      const authUrl = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&response_type=id_token&scope=openid%20email%20profile&nonce=${Math.random().toString(36).slice(2)}`;
      sessionStorage.setItem('rapidai_return', '/coo/');
      window.location.href = authUrl;
    });
  }

  initAuth();
</script>
</body>
</html>
