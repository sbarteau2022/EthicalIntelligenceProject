---
// RAPID²AI — Chat Intelligence UI
// Protected by Google OAuth gate (client-side)
// Talks to the elle-worker "atlas" consumer door, which runs the agentic
// router scoped to the operator's hospitality data (US Foods invoices +
// Square POS via query_rapid2ai / rapid_data). This replaces the old
// standalone chat-api worker so all surfaces share one tool layer.
const chatApiUrl =
  import.meta.env.PUBLIC_RAPIDAI_CHAT_API_URL ?? 'https://elle-worker.sbarteau2022.workers.dev/api/atlas';
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="rapidai-client-id" content={googleClientId} />
    <meta name="rapidai-api-url" content={chatApiUrl} />
    <title>RAPID²AI — Intelligence</title>
    <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
    <script is:inline src="/rapidai-auth.js"></script>
    <style>
      :root {
        --bg: #0a0e0c;
        --surface: #111714;
        --surface2: #192118;
        --border: #2a332a;
        --gold: #c9a55c;
        --gold-dim: #a07e3a;
        --text: #e8ede9;
        --text-dim: #7a8278;
        --green: #4caf72;
        --user-bubble: #1a3a2a;
        --ai-bubble: #111714;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        display: flex;
        flex-direction: column;
        height: 100vh;
      }

      /* AUTH GATE */
      #rapidai-gate {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--bg);
        align-items: center;
        justify-content: center;
        z-index: 9999;
        flex-direction: column;
        gap: 1.5rem;
      }
      .gate-brand {
        font-family: Georgia, serif;
        font-style: italic;
        color: var(--gold);
        font-size: 1.4rem;
      }
      .gate-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2.5rem 3rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
      }
      .gate-title {
        color: var(--text);
        font-size: 1rem;
        font-weight: 600;
      }
      .gate-desc {
        color: var(--text-dim);
        font-size: 0.82rem;
        max-width: 280px;
        line-height: 1.6;
      }
      .btn-google {
        background: #fff;
        color: #3c4043;
        border: 1px solid #dadce0;
        border-radius: 6px;
        padding: 10px 20px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: background 0.15s;
      }
      .btn-google:hover {
        background: #f8f9fa;
      }
      .btn-google svg {
        flex-shrink: 0;
      }

      /* HEADER */
      .app-header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 0 1.5rem;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
      }
      .header-brand {
        font-family: Georgia, serif;
        font-style: italic;
        color: var(--gold);
        font-size: 1.05rem;
      }
      .header-brand span {
        font-size: 0.68rem;
        font-style: normal;
        font-family: monospace;
        color: var(--text-dim);
        letter-spacing: 4px;
        margin-left: 8px;
      }
      .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .view-switch {
        display: flex;
        gap: 0.4rem;
      }
      .view-pill {
        font-size: 0.7rem;
        padding: 3px 10px;
        border-radius: 20px;
        text-decoration: none;
        border: 1px solid var(--border);
        color: var(--text-dim);
        transition: all 0.15s;
      }
      .view-pill.active {
        background: rgba(201, 165, 92, 0.1);
        border-color: var(--gold-dim);
        color: var(--gold);
      }
      .view-pill:hover {
        color: var(--text);
      }
      .sync-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--green);
        display: inline-block;
      }
      .signout-btn {
        font-size: 0.72rem;
        color: var(--text-dim);
        background: none;
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
      }
      .signout-btn:hover {
        color: var(--text);
      }

      /* CHAT LAYOUT */
      .chat-outer {
        display: flex;
        flex: 1;
        overflow: hidden;
      }
      .chat-sidebar {
        width: 240px;
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
      }
      .chat-sidebar-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .chat-sidebar-title {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-dim);
      }
      .new-chat-btn {
        font-size: 0.72rem;
        background: rgba(201, 165, 92, 0.1);
        border: 1px solid var(--gold-dim);
        color: var(--gold);
        padding: 3px 10px;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s;
      }
      .new-chat-btn:hover {
        background: rgba(201, 165, 92, 0.18);
      }
      .chat-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem 0;
      }
      .chat-list-item {
        padding: 0.7rem 1.25rem;
        font-size: 0.8rem;
        color: var(--text-dim);
        cursor: pointer;
        transition: background 0.1s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        border-left: 2px solid transparent;
      }
      .chat-list-item:hover {
        background: rgba(255, 255, 255, 0.03);
        color: var(--text);
      }
      .chat-list-item.active {
        color: var(--gold);
        background: rgba(201, 165, 92, 0.06);
        border-left-color: var(--gold);
      }
      .chat-sidebar-footer {
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--border);
        font-size: 0.72rem;
        color: var(--text-dim);
      }

      /* CHAT MAIN */
      .chat-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .msg {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        max-width: 780px;
      }
      .msg.user {
        align-self: flex-end;
        flex-direction: row-reverse;
      }
      .msg-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
      }
      .msg-avatar-ai {
        background: rgba(201, 165, 92, 0.15);
        color: var(--gold);
        border: 1px solid var(--gold-dim);
      }
      .msg-avatar-user {
        background: var(--user-bubble);
        color: var(--green);
        border: 1px solid #2a4a3a;
      }
      .msg-body {
        background: var(--ai-bubble);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.875rem 1rem;
        font-size: 0.875rem;
        line-height: 1.65;
        color: var(--text);
        max-width: calc(100% - 42px);
      }
      .msg.user .msg-body {
        background: var(--user-bubble);
        border-color: #2a4a3a;
      }
      .msg-body p + p {
        margin-top: 0.5rem;
      }
      .msg-body strong {
        color: var(--gold);
      }
      .msg-time {
        font-size: 0.65rem;
        color: var(--text-dim);
        margin-top: 4px;
        text-align: right;
      }
      .msg.user .msg-time {
        text-align: left;
      }

      /* EMPTY STATE */
      .empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 2rem;
        text-align: center;
      }
      .empty-icon {
        font-size: 2.5rem;
      }
      .empty-title {
        font-family: Georgia, serif;
        font-style: italic;
        color: var(--gold);
        font-size: 1.25rem;
      }
      .empty-desc {
        color: var(--text-dim);
        font-size: 0.85rem;
        max-width: 420px;
        line-height: 1.7;
      }
      .empty-prompts {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.5rem;
        width: 100%;
        max-width: 400px;
      }
      .empty-prompt {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        color: var(--text-dim);
        text-align: left;
        cursor: pointer;
        transition:
          border-color 0.15s,
          color 0.15s;
      }
      .empty-prompt:hover {
        border-color: var(--gold-dim);
        color: var(--text);
      }

      /* INPUT */
      .chat-input-area {
        padding: 1rem 1.5rem;
        background: var(--surface);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
      }
      .input-row {
        display: flex;
        gap: 0.75rem;
        align-items: flex-end;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.6rem 0.75rem;
        transition: border-color 0.15s;
      }
      .input-row:focus-within {
        border-color: var(--gold-dim);
      }
      #chat-input {
        flex: 1;
        background: none;
        border: none;
        color: var(--text);
        font-size: 0.875rem;
        resize: none;
        outline: none;
        line-height: 1.5;
        min-height: 24px;
        max-height: 160px;
        font-family: inherit;
      }
      #chat-input::placeholder {
        color: var(--text-dim);
      }
      .send-btn {
        background: var(--gold);
        color: #0a0e0c;
        border: none;
        border-radius: 6px;
        width: 34px;
        height: 34px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.15s;
      }
      .send-btn:hover {
        background: #e0b96a;
      }
      .send-btn:disabled {
        background: var(--gold-dim);
        opacity: 0.5;
        cursor: not-allowed;
      }
      .send-btn svg {
        width: 16px;
        height: 16px;
      }
      .input-hint {
        font-size: 0.68rem;
        color: var(--text-dim);
        margin-top: 6px;
        text-align: center;
      }

      /* TYPING INDICATOR */
      .typing {
        display: flex;
        gap: 4px;
        align-items: center;
        padding: 4px 0;
      }
      .typing span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--text-dim);
        animation: bounce 1.2s infinite;
      }
      .typing span:nth-child(2) {
        animation-delay: 0.2s;
      }
      .typing span:nth-child(3) {
        animation-delay: 0.4s;
      }
      @keyframes bounce {
        0%,
        60%,
        100% {
          transform: translateY(0);
        }
        30% {
          transform: translateY(-5px);
        }
      }

      /* Scrollbar */
      .messages::-webkit-scrollbar {
        width: 4px;
      }
      .messages::-webkit-scrollbar-track {
        background: transparent;
      }
      .messages::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 2px;
      }
    </style>
  </head>
  <body>
    <!-- AUTH GATE OVERLAY -->
    <div id="rapidai-gate">
      <div class="gate-brand">RAPID²AI</div>
      <div class="gate-card">
        <div class="gate-title">Intelligence — Restricted Access</div>
        <div class="gate-desc">Sign in with your authorized Google account to access the full intelligence layer.</div>
        <div id="google-signin-btn"></div>
        <button class="btn-google" id="manual-signin-btn">
          <svg width="18" height="18" viewBox="0 0 18 18"
            ><path
              fill="#4285F4"
              d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.566 2.684-3.875 2.684-6.615z"
            ></path><path
              fill="#34A853"
              d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"
            ></path><path
              fill="#FBBC05"
              d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.347 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"
            ></path><path
              fill="#EA4335"
              d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z"
            ></path></svg
          >
          Sign in with Google
        </button>
        <div><a href="/" style="color:var(--text-dim);font-size:0.75rem;">← Back to site</a></div>
      </div>
    </div>

    <div class="app-header">
      <div class="header-brand">RAPID²AI <span>INTELLIGENCE</span></div>
      <div class="header-right">
        <div class="view-switch">
          <a class="view-pill" href="/coo/">COO View</a>
          <a class="view-pill" href="/chef/">Chef View</a>
          <span class="view-pill active">Chat</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
          <div class="sync-dot"></div>
          <span style="font-size:0.75rem;color:var(--text-dim)">Live</span>
        </div>
        <button class="signout-btn" onclick="RapidAIAuth.signOut()">Sign out</button>
      </div>
    </div>

    <div class="chat-outer">
      <div class="chat-sidebar">
        <div class="chat-sidebar-header">
          <span class="chat-sidebar-title">Conversations</span>
          <button class="new-chat-btn" onclick="newChat()">+ New</button>
        </div>
        <div class="chat-list" id="chat-list">
          <div class="chat-list-item active">Cost analysis — Tin Mill</div>
          <div class="chat-list-item">Ground beef pricing trend</div>
          <div class="chat-list-item">May delivery variance</div>
        </div>
        <div class="chat-sidebar-footer" id="user-email-sidebar">Hermannhof Group</div>
      </div>

      <div class="chat-main">
        <div class="messages" id="messages">
          <div class="empty-state" id="empty-state">
            <div class="empty-icon">🧠</div>
            <div class="empty-title">RAPID²AI Intelligence</div>
            <div class="empty-desc">
              Your full operational context — invoice data, price trends, ledger health, and purveyor intelligence —
              available as conversation.
            </div>
            <div class="empty-prompts">
              <div class="empty-prompt" onclick="sendPrompt(this.textContent)">
                What's driving the food cost increase this week?
              </div>
              <div class="empty-prompt" onclick="sendPrompt(this.textContent)">
                Summarize price volatility for my top 5 SKUs
              </div>
              <div class="empty-prompt" onclick="sendPrompt(this.textContent)">Which invoices still need review?</div>
              <div class="empty-prompt" onclick="sendPrompt(this.textContent)">
                Compare this month's COGS to last month
              </div>
            </div>
          </div>
        </div>

        <div class="chat-input-area">
          <div class="input-row">
            <textarea
              id="chat-input"
              placeholder="Ask about your costs, invoices, price trends…"
              rows="1"
              oninput="autoResize(this)"></textarea>
            <button class="send-btn" id="send-btn" onclick="sendMessage()">
              <svg
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 2L8 8M14 2L9 14L8 8L2 6L14 2Z"></path>
              </svg>
            </button>
          </div>
          <div class="input-hint">
            RAPID²AI has context from your invoices, POS data, and ledger. Responses reflect your operational data.
          </div>
        </div>
      </div>
    </div>

    <script>
      // @ts-nocheck
      // The elle-worker atlas door owns the system prompt + hospitality scope,
      // so the client no longer ships its own. It is a single-question agentic
      // endpoint; we keep multi-turn context via a persisted session_id.
      const CHAT_API_URL =
        document.querySelector('meta[name="rapidai-api-url"]')?.content ||
        'https://elle-worker.sbarteau2022.workers.dev/api/atlas';
      const SESSION_KEY = 'rapidai_session';
      let sessionId = (function () {
        try {
          return localStorage.getItem(SESSION_KEY) || '';
        } catch {
          return '';
        }
      })();
      let isLoading = false;

      function timeStr() {
        return new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function appendMsg(role, content, typing = false) {
        const empty = document.getElementById('empty-state');
        if (empty) empty.remove();

        const container = document.getElementById('messages');
        const div = document.createElement('div');
        div.className = `msg ${role}`;
        div.innerHTML = `
      <div class="msg-avatar ${role === 'user' ? 'msg-avatar-user' : 'msg-avatar-ai'}">${role === 'user' ? 'U' : 'R²'}</div>
      <div>
        <div class="msg-body" id="${typing ? 'typing-bubble' : ''}">${typing ? '<div class="typing"><span></span><span></span><span></span></div>' : escapeHtml(content).replace(/\n/g, '<br>')}</div>
        <div class="msg-time">${timeStr()}</div>
      </div>`;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
        return div;
      }

      function sendPrompt(text) {
        document.getElementById('chat-input').value = text;
        sendMessage();
      }

      async function sendMessage() {
        if (isLoading) return;
        const input = document.getElementById('chat-input');
        const text = input.value.trim();
        if (!text) return;

        input.value = '';
        autoResize(input);
        appendMsg('user', text);

        isLoading = true;
        document.getElementById('send-btn').disabled = true;
        appendMsg('assistant', '', true);

        try {
          const res = await fetch(CHAT_API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ query: text, session_id: sessionId || undefined }),
          });

          const bubble = document.getElementById('typing-bubble');
          const data = await res.json().catch(() => ({}));

          if (res.status === 429) {
            if (bubble) bubble.innerHTML = "You've hit the rate limit — please try again in a little while.";
          } else if (!res.ok || data.error) {
            if (bubble) bubble.innerHTML = escapeHtml(data.error || 'Sorry, something went wrong. Please try again.');
          } else {
            // atlas returns { content, session_id }; tolerate the legacy
            // Anthropic-style { content: [{ text }] } / { reply } shapes too.
            const reply =
              (typeof data.content === 'string' ? data.content : data.content?.[0]?.text) || data.reply || '';
            if (data.session_id) {
              sessionId = data.session_id;
              try {
                localStorage.setItem(SESSION_KEY, sessionId);
              } catch {
                /* ignore */
              }
            }
            if (bubble) {
              bubble.id = '';
              bubble.innerHTML = escapeHtml(reply).replace(/\n/g, '<br>');
            }
          }
        } catch (e) {
          const bubble = document.getElementById('typing-bubble');
          if (bubble) bubble.innerHTML = 'Network error — check your connection.';
        }

        isLoading = false;
        document.getElementById('send-btn').disabled = false;
        document.getElementById('messages').scrollTop = document.getElementById('messages').scrollHeight;
      }

      function handleKey(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      }

      function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 160) + 'px';
      }

      // Wired here instead of an inline onkeydown attribute — TS flags the
      // implicit inline-handler `event` global as deprecated (ts6385).
      document.getElementById('chat-input').addEventListener('keydown', handleKey);

      function newChat() {
        sessionId = '';
        try {
          localStorage.removeItem(SESSION_KEY);
        } catch {
          /* ignore */
        }
        document.getElementById('messages').innerHTML = `
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">🧠</div>
        <div class="empty-title">RAPID²AI Intelligence</div>
        <div class="empty-desc">Your full operational context — invoice data, price trends, ledger health, and purveyor intelligence — available as conversation.</div>
        <div class="empty-prompts">
          <div class="empty-prompt" onclick="sendPrompt(this.textContent)">What's driving the food cost increase this week?</div>
          <div class="empty-prompt" onclick="sendPrompt(this.textContent)">Summarize price volatility for my top 5 SKUs</div>
          <div class="empty-prompt" onclick="sendPrompt(this.textContent)">Which invoices still need review?</div>
          <div class="empty-prompt" onclick="sendPrompt(this.textContent)">Compare this month's COGS to last month</div>
        </div>
      </div>`;
      }

      // Auth gate
      function initAuth() {
        if (RapidAIAuth.isAuthed()) {
          document.getElementById('rapidai-gate').style.display = 'none';
          const email = sessionStorage.getItem('rapidai_email');
          if (email) document.getElementById('user-email-sidebar').textContent = email;
          return;
        }
        document.getElementById('rapidai-gate').style.display = 'flex';
        const clientId = document.querySelector('meta[name="rapidai-client-id"]')?.content;
        if (clientId) {
          function initGSI() {
            if (!window.google?.accounts) return setTimeout(initGSI, 100);
            google.accounts.id.initialize({
              client_id: clientId,
              callback: function (response) {
                if (response.credential) {
                  sessionStorage.setItem('rapidai_auth', response.credential);
                  sessionStorage.setItem('rapidai_authed_at', Date.now().toString());
                  try {
                    const p = JSON.parse(atob(response.credential.split('.')[1]));
                    if (p.email) sessionStorage.setItem('rapidai_email', p.email);
                  } catch (e) {}
                  window.location.reload();
                }
              },
              auto_select: false,
            });
            google.accounts.id.renderButton(document.getElementById('google-signin-btn'), {
              theme: 'outline',
              size: 'large',
            });
          }
          initGSI();
        }
        document.getElementById('manual-signin-btn').addEventListener('click', function () {
          if (!clientId) {
            RapidAIAuth.signIn('/app/');
            return;
          }
          const redirectUri = window.location.origin + '/auth/callback';
          const url = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&response_type=id_token&scope=openid%20email%20profile&nonce=${Math.random().toString(36).slice(2)}`;
          sessionStorage.setItem('rapidai_return', '/app/');
          window.location.href = url;
        });
      }
      initAuth();
    </script>
  </body>
</html>
