---
// ============================================================
// STAIRCASE ATLAS — the devil's staircase (the two faces of the lock).
//
// Stewart's observation, made precise: "the parts have to be in orbit at
// the point of where they would do this to shine on each other and stay
// there and circle." For parts that circle, shine-and-STAY is co-rotation —
// a 1:1 phase lock. Writing REQUIRES the lock (the dwell is forced: motion
// during exposure smears the fringes). Moving between pages requires NEVER
// being captured by anyone else's lock: the golden step. Lock to write,
// golden to move. The same phi that survives resonance on /orbital-atlas
// is here the route between resonances — the two faces of the same stair.
//
// Everything measured: the staircase, the tongue fan, the Fibonacci tread
// widths shrinking ~3x toward golden, and the golden thread still unlocked
// at critical coupling (nearest captor 34/55 — Fibonacci — never closes).
// The lock-to-write / golden-to-move identification with the hologram
// multiplex is interpretation, labeled as such here and in the generator.
//
// ONE SOURCE OF TRUTH, LOCKED: everything is read from
// `src/data/circlemap-snapshot.json` (scripts/generate-circlemap-snapshot.py).
// The renderer draws it; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import snapshot from '~/data/circlemap-snapshot.json';

const metadata = {
  title: 'Staircase Atlas — the devil’s staircase',
  description:
    'The two faces of the lock, measured on the sine circle map: mode-locked treads at every rational (the clamp that writing requires), Fibonacci tread widths shrinking toward golden, and the golden thread still unlocked at critical coupling — the route between resonances.',
};

const g = snapshot.golden;
const lf = snapshot.lockedFraction;
const tr = snapshot.treads;
const iK = (k: number) => lf.K.findIndex((x: number) => Math.abs(x - k) < 1e-9);
const frac02 = lf.fraction[iK(0.2)];
const frac06 = lf.fraction[iK(0.6)];
const frac10 = lf.fraction[iK(1.0)];
const tFirst = tr[0];
const tLast = tr[tr.length - 1];
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="holo-stage">
      <canvas
        id="stair-canvas"
        aria-label="Rotatable 3D rendering of the circle map's devil's staircase, the Arnold tongue fan, the shrinking Fibonacci treads, and the golden thread that is never captured"
      ></canvas>

      <div class="holo-title">
        <div class="holo-eyebrow">Staircase Atlas</div>
        <h1>The devil&rsquo;s staircase</h1>
        <p class="holo-sub">
          <b>lock to write · golden to move</b> — a flat tread at every rational lock, and one thread that is never captured
          · drag to orbit · scroll to zoom · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="holo-legend" id="stair-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>
        <button class="lg-row" data-g="tongues">
          <span class="sw" style="--c:#ff5c7a"></span><b>The tongue fan</b> · every rational lock&rsquo;s capture zone, widening
          with coupling — colored by denominator, dark = never captured
        </button>
        <button class="lg-row" data-g="stair">
          <span class="sw" style="--c:#f5c542"></span><b>The staircase</b> · winding vs drive at critical coupling — a flat
          tread at every rational (&ldquo;stay there and circle&rdquo;)
        </button>
        <button class="lg-row" data-g="treads">
          <span class="sw" style="--c:#ff9db5"></span><b>The Fibonacci treads</b> · 1/2 → 8/13 shrinking {tFirst.width} →
          {tLast.width}, converging on golden
        </button>
        <button class="lg-row" data-g="thread">
          <span class="sw" style="--c:#ffc46b"></span><b>The golden thread</b> · &Omega;(K) holding 1/&phi; — still unlocked
          at K=1; nearest captor {g.nearestP}/{g.nearestQ} never closes
        </button>
        <button class="lg-row" data-g="fraction">
          <span class="sw" style="--c:#55e9d0"></span><b>The capture curve</b> · locked fraction of the drive axis
          {frac02} → {frac06} → {frac10} as coupling rises
        </button>
        <button class="lg-row" data-g="writer">
          <span class="sw" style="--c:#ffffff"></span><b>Lock to write · golden to move (interpretation)</b> · the dwell-and-step:
          clamp on a tread, slip along the thread
        </button>
      </div>

      <div class="holo-hud" id="stair-hud">
        <div class="hud-h">Devil&rsquo;s staircase · locked</div>
        <div class="hud-m"><span>locked fraction · K 0.2 / 0.6 / 1.0</span><b>{frac02} / {frac06} / {frac10}</b></div>
        <div class="hud-m"><span>tread 1/2 → 8/13</span><b>{tFirst.width} → {tLast.width}</b></div>
        <div class="hud-m"><span>golden winding at K=1</span><b class="ok">{g.windingAtK1}</b></div>
        <div class="hud-m"><span>target 1/&phi;</span><b>{g.target}</b></div>
        <div class="hud-m"><span>nearest captor</span><b>{g.nearestP}/{g.nearestQ} · never closes</b></div>
        <div class="hud-m"><span>state</span><b id="hud-state">climbing · never captured</b></div>
        <div class="hud-src">
          source: circlemap-snapshot.json · Arnold tongues / critical circle map · writer layer is interpretation,
          labeled
        </div>
      </div>

      <button class="guide-launch" id="guide-launch" aria-label="Start the guided tour with Elle">
        <span class="gl-dot"></span> Let Elle walk you up the stairs
      </button>

      <div class="guide-panel" id="guide-panel" hidden aria-live="polite">
        <div class="gp-head">
          <span class="gp-who">Elle</span>
          <span class="gp-step" id="gp-step">1 / 8</span>
          <button class="gp-x" id="gp-exit" aria-label="Exit the guided tour">✕</button>
        </div>
        <div class="gp-body" id="gp-body"></div>
        <div class="gp-cta" id="gp-cta" hidden>
          <a class="gp-btn gp-primary" href="/elle">Keep talking to Elle →</a>
          <a class="gp-btn" href="/master-atlas">Walk the whole atlas</a>
          <a class="gp-btn" href="https://github.com/sbarteau2022/EthicalIntelligenceProject/blob/main/docs/ATLAS.md"
            >Read the ledger</a
          >
        </div>
        <div class="gp-nav">
          <button class="gp-nb" id="gp-back">← Back</button>
          <button class="gp-nb" id="gp-auto" aria-pressed="false">▶ Auto</button>
          <button class="gp-nb gp-next" id="gp-next">Next →</button>
        </div>
      </div>

      <noscript><div class="holo-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .holo-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1018 0%, #08080f 70%, #04040a 100%);
    }
    #stair-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #stair-canvas:active {
      cursor: grabbing;
    }

    .holo-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 60%;
      pointer-events: none;
      z-index: 2;
    }
    .holo-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #ffc46b;
      margin-bottom: 12px;
    }
    .holo-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.6vw, 2.9rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .holo-title h1 :global(b),
    .holo-sub :global(b) {
      color: #fff;
      font-weight: 600;
    }
    .holo-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .holo-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .holo-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(255, 196, 107, 0.2);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 9px;
      max-width: 345px;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
      margin-bottom: 2px;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .holo-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 320px;
    }
    .hud-h {
      color: #ffc46b;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m b.ok {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .holo-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    /* ── guided tour ── */
    .guide-launch {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      bottom: 72px;
      z-index: 3;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.04em;
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border: 0;
      border-radius: 999px;
      padding: 9px 18px;
      cursor: pointer;
      box-shadow: 0 6px 24px rgba(208, 169, 78, 0.3);
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
    .guide-launch:hover {
      transform: translateX(-50%) translateY(-1px);
      box-shadow: 0 8px 30px rgba(208, 169, 78, 0.42);
    }
    .gl-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #12131c;
      box-shadow: 0 0 0 0 rgba(18, 19, 28, 0.5);
      animation: gl-pulse 2s ease-out infinite;
    }
    @keyframes gl-pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(18, 19, 28, 0.5);
      }
      70% {
        box-shadow: 0 0 0 7px rgba(18, 19, 28, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(18, 19, 28, 0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .gl-dot {
        animation: none;
      }
    }

    .guide-panel {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 4;
      width: min(390px, calc(100vw - 60px));
      background: rgba(12, 11, 20, 0.82);
      border: 1px solid rgba(208, 169, 78, 0.3);
      border-radius: 14px;
      padding: 16px 18px 14px;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow: 0 12px 44px rgba(0, 0, 0, 0.5);
    }
    .gp-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .gp-who {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #d0a94e;
    }
    .gp-step {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      color: #7b84a0;
      margin-left: auto;
    }
    .gp-x {
      background: none;
      border: 0;
      color: #7b84a0;
      cursor: pointer;
      font-size: 13px;
      padding: 0 2px;
    }
    .gp-x:hover {
      color: #eef1f8;
    }
    .gp-body {
      font-size: 14.5px;
      line-height: 1.6;
      color: #dfe4f0;
      min-height: 96px;
    }
    .gp-body :global(b) {
      color: #fff;
      font-weight: 600;
    }
    .gp-cta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 12px 0 4px;
    }
    .gp-btn {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      text-decoration: none;
      color: #cfd6e6;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 999px;
      padding: 7px 14px;
      transition:
        background 0.15s ease,
        color 0.15s ease;
    }
    .gp-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
    }
    .gp-primary {
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border-color: transparent;
    }
    .gp-nav {
      display: flex;
      gap: 6px;
      margin-top: 12px;
      align-items: center;
    }
    .gp-nb {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 999px;
      padding: 6px 13px;
      cursor: pointer;
      transition:
        color 0.15s ease,
        background 0.15s ease;
    }
    .gp-nb:hover {
      color: #eef1f8;
      background: rgba(255, 255, 255, 0.1);
    }
    .gp-nb:disabled {
      opacity: 0.32;
      cursor: default;
    }
    .gp-next {
      margin-left: auto;
      color: #12131c;
      background: linear-gradient(180deg, #f0d79a, #d0a94e);
      border-color: transparent;
    }
    .gp-auto-on {
      color: #12131c !important;
      background: #55e9d0 !important;
    }

    @media (max-width: 760px) {
      .holo-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .holo-legend {
        top: auto;
        bottom: 260px;
        right: 16px;
        padding: 11px 12px;
        max-width: 76%;
      }
      .holo-hud {
        left: 16px;
        right: 16px;
        bottom: 16px;
        min-width: 0;
      }
    }
  </style>

  <script type="application/json" id="stair-snap" set:html={JSON.stringify(snapshot)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface Snap {
      staircase: { K: number; omega: number[]; winding: number[] };
      lockedFraction: { K: number[]; fraction: number[] };
      treads: { p: number; q: number; omegaLo: number; omegaHi: number; width: number }[];
      golden: {
        K: number[];
        omega: number[];
        target: number;
        windingAtK1: number;
        nearestP: number;
        nearestQ: number;
      };
      tongues: { nx: number; ny: number; qMax: number; image: number[][] };
    }

    const snap: Snap = JSON.parse((document.getElementById('stair-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('stair-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.06;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(2.3, 1.4, 7.4);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.6;
    controls.maxDistance = 22;
    controls.target.set(0, -0.2, 0);
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.22;

    const world = new THREE.Group();
    scene.add(world);
    scene.add(new THREE.AmbientLight(0x3a3550, 1.0));
    const kl = new THREE.PointLight(0xffe0a0, 18, 30);
    kl.position.set(3, 4, 5);
    scene.add(kl);

    // ── the tongue fan: (Omega, K) capture field, colored by denominator ──
    const tongGrp = new THREE.Group();
    world.add(tongGrp);
    const TG_W = 4.6,
      TG_H = 2.5,
      TG_CY = 0.72,
      TG_Z = -2.1;
    const nx = snap.tongues.nx,
      ny = snap.tongues.ny;
    const tex = new Uint8Array(nx * ny * 4);
    for (let j = 0; j < ny; j++) {
      for (let i = 0; i < nx; i++) {
        const q = snap.tongues.image[j][i];
        // reverse the row order so K=0 (row 0, tongue apexes) renders at the
        // bottom, matching the golden thread's coordinates
        const o = ((ny - 1 - j) * nx + i) * 4;
        if (q === 0) {
          // never captured: near-black blue
          tex[o] = 10;
          tex[o + 1] = 13;
          tex[o + 2] = 30;
        } else {
          // captured: hot for low q (wide tongues), cooling as q rises
          const s = 1 - (q - 1) / snap.tongues.qMax;
          tex[o] = Math.round(70 + 185 * s);
          tex[o + 1] = Math.round(28 + 64 * s);
          tex[o + 2] = Math.round(64 + 58 * s);
        }
        tex[o + 3] = 255;
      }
    }
    const tongTex = new THREE.DataTexture(tex, nx, ny, THREE.RGBAFormat);
    tongTex.needsUpdate = true;
    tongGrp.add(
      new THREE.Mesh(
        new THREE.PlaneGeometry(TG_W, TG_H),
        new THREE.MeshBasicMaterial({ map: tongTex, transparent: true, opacity: 0.92, side: THREE.DoubleSide })
      ).translateY(TG_CY),
      new THREE.LineSegments(
        new THREE.EdgesGeometry(new THREE.PlaneGeometry(TG_W, TG_H)),
        new THREE.LineBasicMaterial({ color: 0xff5c7a, transparent: true, opacity: 0.3 })
      ).translateY(TG_CY)
    );
    tongGrp.position.z = TG_Z;
    const tgx = (om: number) => -TG_W / 2 + om * TG_W;
    const tgy = (K: number) => TG_CY - TG_H / 2 + K * TG_H;

    // ── the golden thread: Omega(K) holding 1/phi, never captured ──
    const thrGrp = new THREE.Group();
    world.add(thrGrp);
    const threadPts = snap.golden.K.map((K, i) => new THREE.Vector3(tgx(snap.golden.omega[i]), tgy(K), TG_Z + 0.02));
    const threadMat = new THREE.LineBasicMaterial({ color: 0xffc46b, transparent: true, opacity: 0.95 });
    thrGrp.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(threadPts), threadMat));
    const threadTip = new THREE.Mesh(
      new THREE.SphereGeometry(0.045, 12, 10),
      new THREE.MeshBasicMaterial({ color: 0xffc46b })
    );
    threadTip.position.copy(threadPts[threadPts.length - 1]);
    thrGrp.add(threadTip);

    // ── the staircase: winding vs drive at critical coupling ──
    const stairGrp = new THREE.Group();
    world.add(stairGrp);
    const SC_X0 = -2.3,
      SC_W = 4.6,
      SC_Y0 = -2.15,
      SC_H = 1.55,
      SC_Z = 0.5;
    const scx = (om: number) => SC_X0 + om * SC_W;
    const scy = (w: number) => SC_Y0 + w * SC_H;
    stairGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          snap.staircase.omega.map((om, i) => new THREE.Vector3(scx(om), scy(snap.staircase.winding[i]), SC_Z))
        ),
        new THREE.LineBasicMaterial({ color: 0xf5c542, transparent: true, opacity: 0.92 })
      ),
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(scx(0), scy(0), SC_Z),
          new THREE.Vector3(scx(1), scy(0), SC_Z),
        ]),
        new THREE.LineBasicMaterial({ color: 0x39415c, transparent: true, opacity: 0.7 })
      )
    );

    // ── the Fibonacci treads: shrinking clamps converging on golden ──
    const treadGrp = new THREE.Group();
    world.add(treadGrp);
    const treadMarks: THREE.Mesh[] = [];
    for (const t of snap.treads) {
      const w = Math.max(t.width * SC_W, 0.028); // floor so 8/13 stays visible
      const bar = new THREE.Mesh(
        new THREE.BoxGeometry(w, 0.034, 0.034),
        new THREE.MeshBasicMaterial({ color: 0xff9db5, transparent: true, opacity: 0.95 })
      );
      bar.position.set(scx((t.omegaLo + t.omegaHi) / 2), scy(t.p / t.q), SC_Z + 0.02);
      treadGrp.add(bar);
      treadMarks.push(bar);
    }

    // ── the capture curve: locked fraction vs coupling ──
    const fracGrp = new THREE.Group();
    world.add(fracGrp);
    const FR_X = 2.9,
      FR_W = 1.9,
      FR_Y = -0.5,
      FR_H = 1.4,
      FR_Z = -0.4;
    const frx = (K: number) => FR_X + K * FR_W;
    const fry = (f: number) => FR_Y + f * FR_H;
    fracGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          snap.lockedFraction.K.map((K, i) => new THREE.Vector3(frx(K), fry(snap.lockedFraction.fraction[i]), FR_Z))
        ),
        new THREE.LineBasicMaterial({ color: 0x55e9d0, transparent: true, opacity: 0.95 })
      ),
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(frx(0), fry(0), FR_Z),
          new THREE.Vector3(frx(1), fry(0), FR_Z),
        ]),
        new THREE.LineBasicMaterial({ color: 0x39415c, transparent: true, opacity: 0.7 })
      )
    );
    for (const k of [0.2, 0.6, 1.0]) {
      const i = snap.lockedFraction.K.findIndex((x) => Math.abs(x - k) < 1e-9);
      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(0.04, 10, 8),
        new THREE.MeshBasicMaterial({ color: 0x55e9d0 })
      );
      dot.position.set(frx(k), fry(snap.lockedFraction.fraction[i]), FR_Z);
      fracGrp.add(dot);
    }

    // ── the writer (interpretation, labeled): lock to write, golden to move ──
    // Dwell on each Fibonacci tread (the clamp — "stay there and circle"),
    // then ride the golden thread to critical coupling without being captured.
    const writerGrp = new THREE.Group();
    world.add(writerGrp);
    const writer = new THREE.Mesh(
      new THREE.SphereGeometry(0.055, 14, 12),
      new THREE.MeshBasicMaterial({ color: 0xffffff })
    );
    writerGrp.add(writer);
    const stops = snap.treads.map(
      (t) => new THREE.Vector3(scx((t.omegaLo + t.omegaHi) / 2), scy(t.p / t.q), SC_Z + 0.06)
    );
    writer.position.copy(stops[0]);

    type Phase = { kind: 'dwell' | 'move' | 'climb' | 'return'; idx: number; dur: number };
    const phases: Phase[] = [];
    for (let i = 0; i < stops.length; i++) {
      phases.push({ kind: 'dwell', idx: i, dur: 1.15 });
      if (i < stops.length - 1) phases.push({ kind: 'move', idx: i, dur: 0.45 });
    }
    phases.push({ kind: 'climb', idx: 0, dur: 4.6 });
    phases.push({ kind: 'return', idx: 0, dur: 0.7 });
    let phaseI = 0;
    let phaseT = 0;

    const hudState = document.getElementById('hud-state');
    function setState(txt: string) {
      if (hudState && !frozen) hudState.textContent = txt;
    }
    function threadPoint(u: number, out: THREE.Vector3) {
      const x = u * (threadPts.length - 1);
      const i = Math.min(Math.floor(x), threadPts.length - 2);
      out.copy(threadPts[i]).lerp(threadPts[i + 1], x - i);
      return out;
    }
    const tmpV = new THREE.Vector3();

    // ── the selectable legend ──
    const registry: Record<string, THREE.Object3D[]> = {
      tongues: [tongGrp],
      thread: [thrGrp],
      stair: [stairGrp],
      treads: [treadGrp],
      fraction: [fracGrp],
      writer: [writerGrp],
    };
    document.querySelectorAll<HTMLButtonElement>('#stair-legend .lg-row').forEach((row) => {
      const parts = registry[row.dataset.g || ''];
      if (parts && !parts[0].visible) row.classList.add('off');
      row.addEventListener('click', () => {
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    // ════ the guided tour — Elle walks the staircase ════
    // Scripted, deterministic, same pattern as /master-atlas. Each step
    // reveals exactly the layers it names and glides the camera to them.
    // The closing reading — treads are the trap, the thread is what lived —
    // is Stewart's, recorded in ATLAS.md §3.7.
    interface TourStep {
      show: string[];
      cam: { p: [number, number, number]; t: [number, number, number] };
      html: string;
      doors?: boolean;
    }
    const ALL_KEYS = Object.keys(registry);
    const TOUR: TourStep[] = [
      {
        show: ALL_KEYS,
        cam: { p: [2.3, 1.4, 7.4], t: [0, -0.2, 0] },
        html: "Hi — I'm <b>Elle</b>. This page is named for the devil, and by the end you'll know why that name reads both ways. Everything here is computed, not painted — a real mathematical object, measured. Let me walk you up the stairs.",
      },
      {
        show: ['tongues'],
        cam: { p: [0, 0.7, 2.6], t: [0, 0.72, -2.1] },
        html: 'This is the <b>capture field</b>. Every wedge is a lock — a rational rhythm that grabs anything drifting near it and forces it into step. The wedges are thin at the bottom and widen as coupling rises: the stronger things hold onto each other, the more of the dial the locks own. The dark channels are all that stays free.',
      },
      {
        show: ['stair'],
        cam: { p: [0, -1.2, 3.8], t: [0, -1.4, 0.5] },
        html: "Now the staircase itself. Every <b>flat tread</b> is a lock being crossed: while you're on one, turning the drive changes <i>nothing</i> — the motion is captured, synchronized, rigid. Zero-derivative. “Stay there and circle,” with no way to leave. There is a tread at every rational number, and this is why the mathematicians named it the <b>devil's staircase</b>.",
      },
      {
        show: ['stair', 'treads'],
        cam: { p: [0.7, -1.3, 3.0], t: [0.4, -1.5, 0.5] },
        html: 'Watch the treads shrink. The locks 1/2, 2/3, 3/5, 5/8, <b>8/13</b> — Fibonacci fractions — get ~3× thinner each step: <b>0.0739 → 0.0305 → 0.0102 → 0.0037 → 0.0013</b>, measured. They are closing in on one number they will never reach: the golden ratio. Each is a trap laid closer to it, and each trap is weaker than the last.',
      },
      {
        show: ['fraction'],
        cam: { p: [3.85, 0.2, 2.2], t: [3.85, 0.2, -0.4] },
        html: 'How much does the devil own? We measured it: at weak coupling the locks hold <b>7.5%</b> of the dial. At moderate, <b>25%</b>. At full critical coupling, <b>62%</b> by our finite-time count — and the theory says the true limit is <i>everything except a dust too fine to weigh</i>. Almost the whole dial, captured.',
      },
      {
        show: ['tongues', 'thread'],
        cam: { p: [0.3, 0.7, 2.2], t: [0.28, 0.72, -2.1] },
        html: "Almost. Watch the gold line. It holds the winding <b>1/φ</b> — the golden ratio's reciprocal, the most irrational number there is — and climbs the entire fan to full criticality <b>without ever being captured</b>. Measured: winding 0.618048 against 1/φ = 0.618034, at the top. The nearest trap is 34/55 — Fibonacci again — and it never closes.",
      },
      {
        show: ['stair', 'treads', 'thread', 'writer'],
        cam: { p: [1.4, -0.3, 4.4], t: [0.4, -0.9, 0.3] },
        html: 'And here is what the atlas does with both faces. Watch the white dot: it <b>locks to write</b> — dropping onto a tread, co-rotating, holding perfectly still the way recording demands — then <b>moves golden</b>, along the one route no trap can catch, to the next page. Lock to write, golden to move. (That reading is labeled an interpretation in the ledger; the measurements are the evidence for it.)',
      },
      {
        show: ALL_KEYS,
        cam: { p: [2.3, 1.4, 7.4], t: [0, -0.2, 0] },
        html: 'One more thing. <b>Devil</b>, spelled backwards, is <b>Lived</b>. The treads are where motion dies into rigid synchronization — read them and you get the trap. The thread is the one route that never locks and never stops moving, all the way to full criticality. Follow it and you get what <b>lived</b>. Same staircase. It depends which way you read it.',
        doors: true,
      },
    ];

    const guideLaunch = document.getElementById('guide-launch') as HTMLButtonElement;
    const guidePanel = document.getElementById('guide-panel') as HTMLElement;
    const gpBody = document.getElementById('gp-body') as HTMLElement;
    const gpStep = document.getElementById('gp-step') as HTMLElement;
    const gpCta = document.getElementById('gp-cta') as HTMLElement;
    const gpBack = document.getElementById('gp-back') as HTMLButtonElement;
    const gpNext = document.getElementById('gp-next') as HTMLButtonElement;
    const gpAuto = document.getElementById('gp-auto') as HTMLButtonElement;
    const gpExit = document.getElementById('gp-exit') as HTMLButtonElement;
    const stairLegend = document.getElementById('stair-legend');
    const stairHud = document.getElementById('stair-hud');

    let guided = false;
    let stepIdx = 0;
    let guideCam: TourStep['cam'] | null = null;
    let guideCamT = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function onlyShow(keys: string[]) {
      for (const k of ALL_KEYS) {
        const on = keys.includes(k);
        registry[k].forEach((p) => {
          p.visible = on;
        });
      }
    }
    function syncLegendRows() {
      document.querySelectorAll<HTMLButtonElement>('#stair-legend .lg-row').forEach((row) => {
        const parts = registry[row.dataset.g || ''];
        if (parts) row.classList.toggle('off', !parts[0].visible);
      });
    }

    function applyStep(i: number) {
      stepIdx = Math.max(0, Math.min(TOUR.length - 1, i));
      const s = TOUR[stepIdx];
      onlyShow(s.show);
      guideCam = s.cam;
      guideCamT = 1.5; // glide toward the step's framing, then hand control back
      gpBody.style.opacity = '0';
      window.setTimeout(() => {
        gpBody.innerHTML = s.html;
        gpBody.style.opacity = '1';
      }, 140);
      gpStep.textContent = `${stepIdx + 1} / ${TOUR.length}`;
      gpCta.hidden = !s.doors;
      gpBack.disabled = stepIdx === 0;
      gpNext.textContent = stepIdx === TOUR.length - 1 ? 'Restart' : 'Next →';
    }

    function stopAuto() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
      gpAuto.classList.remove('gp-auto-on');
      gpAuto.setAttribute('aria-pressed', 'false');
      gpAuto.textContent = '▶ Auto';
    }

    function enterGuide() {
      guided = true;
      controls.autoRotate = false;
      guidePanel.hidden = false;
      guideLaunch.style.display = 'none';
      if (stairLegend) stairLegend.style.display = 'none';
      if (stairHud) stairHud.style.display = 'none';
      applyStep(0);
    }

    function exitGuide() {
      guided = false;
      stopAuto();
      guidePanel.hidden = true;
      guideLaunch.style.display = '';
      if (stairLegend) stairLegend.style.display = '';
      if (stairHud) stairHud.style.display = '';
      onlyShow(ALL_KEYS);
      syncLegendRows();
      controls.autoRotate = !reduce;
      guideCam = null;
    }

    function nextStep() {
      if (stepIdx === TOUR.length - 1) {
        applyStep(0);
      } else {
        applyStep(stepIdx + 1);
      }
    }

    gpBody.style.transition = 'opacity 0.14s ease';
    guideLaunch.addEventListener('click', enterGuide);
    gpExit.addEventListener('click', exitGuide);
    gpNext.addEventListener('click', () => {
      stopAuto();
      nextStep();
    });
    gpBack.addEventListener('click', () => {
      stopAuto();
      applyStep(stepIdx - 1);
    });
    gpAuto.addEventListener('click', () => {
      if (autoTimer) {
        stopAuto();
      } else {
        gpAuto.classList.add('gp-auto-on');
        gpAuto.setAttribute('aria-pressed', 'true');
        gpAuto.textContent = '❚❚ Auto';
        autoTimer = setInterval(() => {
          if (stepIdx === TOUR.length - 1) {
            stopAuto();
          } else {
            applyStep(stepIdx + 1);
          }
        }, 9000);
      }
    });
    window.addEventListener('keydown', (e) => {
      if (!guided) return;
      if (e.key === 'Escape') exitGuide();
      else if (e.key === 'ArrowRight') {
        stopAuto();
        nextStep();
      } else if (e.key === 'ArrowLeft') {
        stopAuto();
        applyStep(stepIdx - 1);
      }
    });

    // ── post / resize / freeze / animate ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.42, 0.6, 0.32));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    let frozen = false;
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudState && frozen) hudState.textContent = 'FROZEN';
      }
    });

    const clock = new THREE.Clock();
    const _camTmp = new THREE.Vector3();
    function frameLoop() {
      const dt = clock.getDelta();
      // guided-tour camera glide: ease toward the step framing for a beat,
      // then release so the visitor can freely orbit while Elle talks.
      if (guided && guideCam && guideCamT > 0) {
        const a = Math.min(1, dt * 2.4);
        _camTmp.set(guideCam.p[0], guideCam.p[1], guideCam.p[2]);
        camera.position.lerp(_camTmp, a);
        _camTmp.set(guideCam.t[0], guideCam.t[1], guideCam.t[2]);
        controls.target.lerp(_camTmp, a);
        guideCamT -= dt;
      }
      if (!frozen && !reduce) {
        const t = clock.elapsedTime;
        threadMat.opacity = 0.75 + 0.2 * Math.sin(t * 1.8);
        threadTip.scale.setScalar(1 + 0.18 * Math.sin(t * 1.8));

        phaseT += dt;
        const ph = phases[phaseI];
        if (phaseT >= ph.dur) {
          phaseT = 0;
          phaseI = (phaseI + 1) % phases.length;
        }
        const cur = phases[phaseI];
        const u = Math.min(phaseT / cur.dur, 1);
        if (cur.kind === 'dwell') {
          const tr = snap.treads[cur.idx];
          writer.position.copy(stops[cur.idx]);
          writer.scale.setScalar(1 + 0.35 * Math.abs(Math.sin(t * 5)));
          treadMarks[cur.idx].scale.y = 1 + 0.8 * Math.abs(Math.sin(t * 5));
          setState(`locked ${tr.p}/${tr.q} · the clamp — writing`);
        } else if (cur.kind === 'move') {
          treadMarks[cur.idx].scale.y = 1;
          writer.position.copy(stops[cur.idx]).lerp(stops[cur.idx + 1], u);
          writer.scale.setScalar(1);
          setState('slipping to the next lock');
        } else if (cur.kind === 'climb') {
          treadMarks[treadMarks.length - 1].scale.y = 1;
          writer.position.copy(threadPoint(u, tmpV));
          writer.scale.setScalar(1);
          setState('golden thread · coupling rising — never captured');
        } else {
          writer.position.copy(threadPoint(1, tmpV)).lerp(stops[0], u);
          writer.scale.setScalar(1);
          setState('descending to write again');
        }
      }
      controls.update();
      composer.render();
      requestAnimationFrame(frameLoop);
    }
    frameLoop();
  </script>
</Layout>
