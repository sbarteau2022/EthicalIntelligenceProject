---
import Layout from '~/layouts/Layout.astro';

const metadata = {
  title: 'Atlas — 90-second demo | The Ethical Intelligence Project',
  description:
    'Sign in, drop your POS export, and ask Atlas five real questions about your restaurant. No card. No contract. 90 seconds.',
};
---

<Layout metadata={metadata}>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Instrument+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');
    #atlas-start * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    #atlas-start {
      --base: #0b0b11;
      --raised: #101018;
      --float: #16161f;
      --gold: #c9a84c;
      --gold-l: #e8cc88;
      --ivory: #f5f0e8;
      --t1: #eee8d8;
      --t2: #9a9480;
      --t3: #5a5448;
      --b1: rgba(201, 168, 76, 0.18);
      --b2: rgba(255, 255, 255, 0.06);
      --font-display: 'Cormorant Garamond', serif;
      --font-ui: 'Instrument Sans', system-ui, sans-serif;
      --font-mono: 'DM Mono', monospace;
      min-height: 100vh;
      background: var(--base);
      color: var(--t1);
      font-family: var(--font-ui);
      padding: 48px 16px 80px;
    }
    #atlas-start .wrap {
      max-width: 720px;
      margin: 0 auto;
    }
    #atlas-start h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3rem);
      color: var(--ivory);
      font-weight: 500;
    }
    #atlas-start .sub {
      color: var(--t2);
      margin: 10px 0 6px;
      font-size: 1.02rem;
      line-height: 1.5;
    }
    #atlas-start .pledge {
      font-family: var(--font-mono);
      color: var(--gold);
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 34px;
    }
    #atlas-start .steps {
      display: flex;
      gap: 8px;
      margin-bottom: 26px;
    }
    #atlas-start .step-dot {
      flex: 1;
      height: 3px;
      border-radius: 2px;
      background: var(--b2);
      transition: background 0.3s;
    }
    #atlas-start .step-dot.on {
      background: var(--gold);
    }
    #atlas-start .card {
      background: var(--raised);
      border: 1px solid var(--b1);
      border-radius: 14px;
      padding: 26px;
      margin-bottom: 18px;
    }
    #atlas-start .card h2 {
      font-family: var(--font-display);
      font-size: 1.45rem;
      color: var(--ivory);
      font-weight: 500;
      margin-bottom: 6px;
    }
    #atlas-start .hint {
      color: var(--t2);
      font-size: 0.9rem;
      line-height: 1.5;
      margin-bottom: 16px;
    }
    #atlas-start label {
      display: block;
      font-size: 0.78rem;
      color: var(--t2);
      margin: 12px 0 4px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-family: var(--font-mono);
    }
    #atlas-start input[type='text'],
    #atlas-start select {
      width: 100%;
      background: var(--float);
      border: 1px solid var(--b2);
      border-radius: 8px;
      color: var(--t1);
      padding: 10px 12px;
      font-size: 0.95rem;
      font-family: var(--font-ui);
      outline: none;
    }
    #atlas-start input[type='text']:focus,
    #atlas-start select:focus {
      border-color: var(--gold);
    }
    #atlas-start .btn {
      display: inline-block;
      background: var(--gold);
      color: #14120a;
      border: none;
      border-radius: 999px;
      padding: 11px 26px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 18px;
      font-family: var(--font-ui);
    }
    #atlas-start .btn:disabled {
      opacity: 0.45;
      cursor: default;
    }
    #atlas-start .btn.ghost {
      background: transparent;
      color: var(--gold);
      border: 1px solid var(--b1);
    }
    #atlas-start .note {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--t2);
      margin-top: 12px;
      line-height: 1.5;
    }
    #atlas-start .note.ok {
      color: #9ec98b;
    }
    #atlas-start .note.err {
      color: #d98b8b;
    }
    #atlas-start .drop {
      border: 1.5px dashed var(--b1);
      border-radius: 10px;
      padding: 30px 16px;
      text-align: center;
      color: var(--t2);
      cursor: pointer;
      transition:
        border-color 0.2s,
        background 0.2s;
      font-size: 0.92rem;
    }
    #atlas-start .drop.hover {
      border-color: var(--gold);
      background: rgba(201, 168, 76, 0.05);
    }
    #atlas-start .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 14px 0;
    }
    #atlas-start .chip {
      background: var(--float);
      border: 1px solid var(--b1);
      color: var(--t1);
      border-radius: 999px;
      padding: 7px 14px;
      font-size: 0.83rem;
      cursor: pointer;
      font-family: var(--font-ui);
    }
    #atlas-start .chip:hover {
      border-color: var(--gold);
    }
    #atlas-start .qrow {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }
    #atlas-start .qrow input {
      flex: 1;
    }
    #atlas-start .qrow .btn {
      margin-top: 0;
    }
    #atlas-start .thread {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 16px;
    }
    #atlas-start .msg {
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 0.93rem;
      line-height: 1.55;
      white-space: pre-wrap;
    }
    #atlas-start .msg.you {
      background: var(--float);
      border: 1px solid var(--b2);
      align-self: flex-end;
      max-width: 85%;
    }
    #atlas-start .msg.atlas {
      background: rgba(201, 168, 76, 0.07);
      border: 1px solid var(--b1);
      align-self: flex-start;
      max-width: 92%;
    }
    #atlas-start .counter {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--gold);
      letter-spacing: 0.06em;
    }
    #atlas-start .hidden {
      display: none;
    }
    #atlas-start .gwrap {
      min-height: 48px;
      margin-top: 8px;
    }
  </style>

  <div id="atlas-start">
    <div class="wrap">
      <h1>See your restaurant the way Atlas does.</h1>
      <p class="sub">
        Sign in, drop the sales export your POS already makes, and ask five real questions about your costs, menu, and
        vendors — answered from <em>your</em> numbers, not a canned demo.
      </p>
      <p class="pledge">No card · No contract · 90 seconds</p>

      <div class="steps">
        <div class="step-dot on" id="dot1"></div>
        <div class="step-dot" id="dot2"></div>
        <div class="step-dot" id="dot3"></div>
        <div class="step-dot" id="dot4"></div>
      </div>

      <!-- 1 · sign in -->
      <div class="card" id="card-signin">
        <h2>1 · Sign in</h2>
        <p class="hint">Google only — one click, and it's the only account you'll ever need here.</p>
        <div class="gwrap" id="gbtn"></div>
        <p class="note" id="signin-note"></p>
      </div>

      <!-- 2 · company profile -->
      <div class="card hidden" id="card-profile">
        <h2>2 · Your place</h2>
        <p class="hint">
          Just enough to stand your account up. Everything else — vendors, menu, cost structure — Atlas aggregates from
          your own paperwork later. One field is required. It's the name.
        </p>
        <label for="f-company">Company / restaurant name *</label>
        <input type="text" id="f-company" placeholder="The Copper Kettle" />
        <label for="f-venue">Venue name (if different)</label>
        <input type="text" id="f-venue" placeholder="Copper Kettle — Downtown" />
        <label for="f-pos">POS</label>
        <select id="f-pos">
          <option value="">Select…</option>
          <option>Toast</option><option>Square</option><option>Clover</option>
          <option>TouchBistro</option><option>Lightspeed</option><option>Other</option>
        </select>
        <label for="f-vendors">Main vendors (optional)</label>
        <input type="text" id="f-vendors" placeholder="US Foods, Sysco…" />
        <button class="btn" id="profile-btn">Create my account</button>
        <p class="note" id="profile-note"></p>
      </div>

      <!-- 3 · data drop -->
      <div class="card hidden" id="card-data">
        <h2>3 · Drop your numbers</h2>
        <p class="hint">
          Export a daily-sales or item-sales CSV from your POS (Toast, Square, Clover formats all work) and drop it
          here. It's parsed in the moment — the raw file is never stored — and your dashboard data goes live under your
          venue only.
        </p>
        <div class="drop" id="drop">Drop a CSV here, or click to choose a file</div>
        <input type="file" id="file" accept=".csv,text/csv" class="hidden" />
        <p class="note" id="data-note"></p>
        <button class="btn ghost" id="skip-btn">Skip for now — straight to questions</button>
      </div>

      <!-- 4 · five questions -->
      <div class="card hidden" id="card-ask">
        <h2>4 · Ask Atlas</h2>
        <p class="hint">Five questions on the house. Ask what you'd actually ask a sharp operations partner.</p>
        <div class="chips">
          <button class="chip">What did we gross in the last two weeks?</button>
          <button class="chip">Which menu items carry the revenue?</button>
          <button class="chip">Where are my vendor prices moving?</button>
          <button class="chip">What's my biggest price swing this quarter?</button>
        </div>
        <div class="qrow">
          <input type="text" id="q" placeholder="Ask about your costs, menu, sales…" />
          <button class="btn" id="ask-btn">Ask</button>
        </div>
        <p class="counter" id="counter">question 1 of 5</p>
        <div class="thread" id="thread"></div>
        <p class="note hidden" id="done-note">
          That's the five — and that was your own data talking. Want Atlas on every shift?
          <a href="/contact" style="color: var(--gold)">Talk to us</a> and we'll wire your feeds in properly.
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (window.__atlasStart) return;
      window.__atlasStart = true;

      const WORKER = 'https://elle-worker.sbarteau2022.workers.dev';
      // Same convention as elle.astro: empty → the Google button hides and a
      // configuration note shows instead of a broken sign-in.
      const GOOGLE_CLIENT_ID = '';
      const TOKEN_KEY = 'eip_atlas_jwt';
      const DEMO_LIMIT = 5;

      let token = null,
        session = null,
        asked = 0;
      try {
        token = localStorage.getItem(TOKEN_KEY) || null;
      } catch {
        /* private mode */
      }

      function $(id) {
        return document.getElementById(id);
      }
      function show(id) {
        $(id).classList.remove('hidden');
      }
      function hide(id) {
        $(id).classList.add('hidden');
      }
      function step(n) {
        for (let i = 1; i <= 4; i++) $('dot' + i).classList.toggle('on', i <= n);
      }
      function post(path, body, authed) {
        const headers = { 'Content-Type': 'application/json' };
        if (authed && token) headers['Authorization'] = 'Bearer ' + token;
        return fetch(WORKER + path, { method: 'POST', headers: headers, body: JSON.stringify(body) }).then(
          function (r) {
            return r.json().then(function (d) {
              return { ok: r.ok, d: d };
            });
          }
        );
      }

      // ── 1 · sign in ────────────────────────────────────────
      function onGoogle(resp) {
        post('/api/atlas/signup', { credential: resp.credential }, false)
          .then(function (res) {
            if (!res.ok) {
              $('signin-note').textContent = res.d.error || 'Sign-in failed.';
              $('signin-note').className = 'note err';
              return;
            }
            token = res.d.access_token;
            try {
              localStorage.setItem(TOKEN_KEY, token);
            } catch {
              /* private mode */
            }
            hide('card-signin');
            if (res.d.client) {
              step(3);
              show('card-data');
              show('card-ask');
            } else {
              step(2);
              show('card-profile');
            }
          })
          .catch(function () {
            $('signin-note').textContent = 'Sign-in failed — try again.';
            $('signin-note').className = 'note err';
          });
      }
      function initGoogle() {
        if (!GOOGLE_CLIENT_ID) {
          $('signin-note').textContent =
            'Google sign-in is not configured on this deploy yet (set GOOGLE_CLIENT_ID in atlas-start.astro and on the worker).';
          return;
        }
        const s = document.createElement('script');
        s.src = 'https://accounts.google.com/gsi/client';
        s.async = true;
        s.defer = true;
        s.onload = function () {
          try {
            window.google.accounts.id.initialize({ client_id: GOOGLE_CLIENT_ID, callback: onGoogle });
            window.google.accounts.id.renderButton($('gbtn'), {
              theme: 'filled_black',
              size: 'large',
              shape: 'pill',
              text: 'continue_with',
              width: 320,
            });
          } catch {
            $('signin-note').textContent = 'Google sign-in failed to load.';
          }
        };
        s.onerror = function () {
          $('signin-note').textContent = 'Google sign-in failed to load.';
        };
        document.head.appendChild(s);
      }

      // Returning visitor with a token: resume where they left off.
      function resume() {
        if (!token) {
          initGoogle();
          return;
        }
        fetch(WORKER + '/api/atlas/profile', { headers: { Authorization: 'Bearer ' + token } })
          .then(function (r) {
            return r.ok ? r.json() : Promise.reject();
          })
          .then(function (d) {
            hide('card-signin');
            if (d.client) {
              step(3);
              show('card-data');
              show('card-ask');
            } else {
              step(2);
              show('card-profile');
            }
          })
          .catch(function () {
            token = null;
            try {
              localStorage.removeItem(TOKEN_KEY);
            } catch {
              /* */
            }
            initGoogle();
          });
      }

      // ── 2 · profile ────────────────────────────────────────
      $('profile-btn').addEventListener('click', function () {
        const company = $('f-company').value.trim();
        if (!company) {
          $('profile-note').textContent = 'Company name is the one required field.';
          $('profile-note').className = 'note err';
          return;
        }
        $('profile-btn').disabled = true;
        post(
          '/api/atlas/profile',
          {
            company_name: company,
            venue_name: $('f-venue').value.trim(),
            pos_provider: $('f-pos').value,
            vendors: $('f-vendors').value.trim(),
          },
          true
        ).then(function (res) {
          $('profile-btn').disabled = false;
          if (!res.ok) {
            $('profile-note').textContent = res.d.error || 'Could not create the account.';
            $('profile-note').className = 'note err';
            return;
          }
          $('profile-note').textContent = 'Account created — onboarding already running on our side.';
          $('profile-note').className = 'note ok';
          hide('card-profile');
          step(3);
          show('card-data');
          show('card-ask');
        });
      });

      // ── 3 · data drop ──────────────────────────────────────
      const drop = $('drop'),
        file = $('file');
      drop.addEventListener('click', function () {
        file.click();
      });
      drop.addEventListener('dragover', function (e) {
        e.preventDefault();
        drop.classList.add('hover');
      });
      drop.addEventListener('dragleave', function () {
        drop.classList.remove('hover');
      });
      drop.addEventListener('drop', function (e) {
        e.preventDefault();
        drop.classList.remove('hover');
        if (e.dataTransfer.files && e.dataTransfer.files[0]) upload(e.dataTransfer.files[0]);
      });
      file.addEventListener('change', function () {
        if (file.files[0]) upload(file.files[0]);
      });
      function upload(f) {
        const note = $('data-note');
        note.textContent = 'Parsing ' + f.name + '…';
        note.className = 'note';
        f.text()
          .then(function (csv) {
            return post('/api/atlas/upload', { csv: csv }, true);
          })
          .then(function (res) {
            if (!res.ok) {
              note.textContent = res.d.error || 'Upload failed.';
              note.className = 'note err';
              return;
            }
            note.textContent =
              'Live: ' +
              res.d.rows +
              ' ' +
              (res.d.kind === 'pos_items' ? 'item-sale' : 'daily-close') +
              ' rows across ' +
              res.d.replaced_dates +
              ' day(s)' +
              (res.d.skipped ? ' (' + res.d.skipped + ' summary/blank rows skipped)' : '') +
              '. Drop another export, or ask away below.';
            note.className = 'note ok';
            step(4);
          })
          .catch(function () {
            note.textContent = 'Upload failed — try again.';
            note.className = 'note err';
          });
      }
      $('skip-btn').addEventListener('click', function () {
        step(4);
        $('q').focus();
      });

      // ── 4 · five questions ─────────────────────────────────
      function addMsg(cls, text) {
        const el = document.createElement('div');
        el.className = 'msg ' + cls;
        el.textContent = text;
        $('thread').appendChild(el);
        el.scrollIntoView({ block: 'nearest' });
      }
      function ask(q) {
        q = (q || $('q').value).trim();
        if (!q || asked >= DEMO_LIMIT || $('ask-btn').disabled) return;
        $('q').value = '';
        $('ask-btn').disabled = true;
        addMsg('you', q);
        addMsg('atlas', '…');
        const pending = $('thread').lastChild;
        post('/api/atlas', { query: q, session_id: session }, true)
          .then(function (res) {
            $('ask-btn').disabled = false;
            if (!res.ok) {
              pending.textContent = res.d.error || 'Atlas could not answer that one.';
              return;
            }
            session = res.d.session_id || session;
            pending.textContent = res.d.content || '(no answer)';
            asked++;
            if (asked >= DEMO_LIMIT) {
              $('counter').textContent = 'that was five';
              $('q').disabled = true;
              $('ask-btn').disabled = true;
              show('done-note');
            } else {
              $('counter').textContent = 'question ' + (asked + 1) + ' of ' + DEMO_LIMIT;
            }
          })
          .catch(function () {
            $('ask-btn').disabled = false;
            pending.textContent = 'Network hiccup — ask again.';
          });
      }
      $('ask-btn').addEventListener('click', function () {
        ask();
      });
      $('q').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') ask();
      });
      Array.prototype.forEach.call(document.querySelectorAll('#atlas-start .chip'), function (c) {
        c.addEventListener('click', function () {
          ask(c.textContent);
        });
      });

      resume();
    })();
  </script>
</Layout>
