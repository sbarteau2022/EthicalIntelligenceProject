  <!-- Elle chat widget -->
  <script
    is:inline
    src="https://elle-worker.sbarteau2022.workers.dev/widget.js"
    data-title="Elle"
    data-accent="#f59e0b"
    defer></script>

  <script is:inline>
    (function () {
      // Engine tab switching + auto-rotate
      const tabs = Array.from(document.querySelectorAll('.tep-engine-tab'));
      const panels = Array.from(document.querySelectorAll('.tep-engine-panel'));
      let active = 0;
      let timer;
      function show(idx) {
        active = idx;
        tabs.forEach((t, i) => t.classList.toggle('active', i === idx));
        panels.forEach((p, i) => p.classList.toggle('active', i === idx));
      }
      function startAuto() {
        stopAuto();
        timer = setInterval(() => show((active + 1) % tabs.length), 3600);
      }
      function stopAuto() {
        if (timer) clearInterval(timer);
      }
      tabs.forEach((t, i) =>
        t.addEventListener('click', () => {
          show(i);
          startAuto();
        })
      );
      if (tabs.length) startAuto();

      // Nav background on scroll
      const nav = document.getElementById('tep-nav');
      function onScroll() {
        if (nav) nav.classList.toggle('scrolled', window.scrollY > 80);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Mobile drawer
      const burger = document.getElementById('tep-burger');
      const drawer = document.getElementById('tep-drawer');
      if (burger && drawer) {
        burger.addEventListener('click', () => {
          burger.classList.toggle('open');
          drawer.classList.toggle('open');
        });
        drawer.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => {
            burger.classList.remove('open');
            drawer.classList.remove('open');
          })
        );
      }

      // Scroll reveals
      const reveals = Array.from(document.querySelectorAll('.reveal'));
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const d = e.target.getAttribute('data-delay') || 0;
                e.target.style.transitionDelay = d + 'ms';
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        reveals.forEach((r) => io.observe(r));
      } else {
        reveals.forEach((r) => r.classList.add('in'));
      }
    })();
  </script>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400;600;700&display=swap');

  #tep {
    --void: #050709;
    --panel: #07090c;
    --card: #0a0d10;
    --gold: #f59e0b;
    --ivory: #f5f0e8;
    --t1: #e8e4dc;
    --t2: #9ca3af;
    --t3: #6b7280;
    --t4: #4b5563;
    --line: rgba(255, 255, 255, 0.05);
    --display: 'Playfair Display', Georgia, serif;
    --serif: 'Libre Baskerville', Georgia, serif;
    --mono: 'JetBrains Mono', monospace;
    background: var(--void);
    color: var(--t1);
    font-family: var(--serif);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  #tep *,
  #tep *::before,
  #tep *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  #tep a {
    color: inherit;
    text-decoration: none;
  }
  #tep ::selection {
    background: rgba(245, 158, 11, 0.3);
    color: var(--ivory);
  }

  #tep .tep-wrap {
    max-width: 1200px;
    margin: 0 auto;
  }
  #tep .tep-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.5;
  }
  #tep .tep-kicker {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--gold);
    opacity: 0.85;
    margin-bottom: 18px;
  }
  #tep .tep-center {
    text-align: center;
  }
  #tep .tep-h2 {
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--ivory);
  }
  #tep .tep-h2 em {
    font-style: italic;
    color: var(--gold);
  }
  #tep .tep-italic-gold {
    font-style: italic;
    color: var(--gold);
  }

  /* reveals */
  #tep .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #tep .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    #tep .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* NAV */
  #tep .tep-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: transparent;
    transition: all 0.4s ease;
  }
  #tep .tep-nav.scrolled {
    background: rgba(5, 7, 9, 0.95);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(12px);
  }
  #tep .tep-brand {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #tep .tep-brand-name {
    font-family: var(--display);
    font-size: 18px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.01em;
    line-height: 1;
  }
  #tep .tep-brand-sub {
    font-family: var(--mono);
    font-size: 8.5px;
    letter-spacing: 0.22em;
    color: var(--t3);
  }
  #tep .tep-nav-links {
    display: flex;
    gap: 32px;
    align-items: center;
  }
  #tep .tep-nav-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--t2);
