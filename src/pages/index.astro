            <div class="tep-footer-col-h">PLATFORM</div>
            <a href="https://harmonizer-two.vercel.app">Harmonizer</a>
            <a href="https://elle-law.pages.dev">Elle Law</a>
            <a href="https://rapidai.pages.dev/coo/">RAPID²AI</a>
            <a href="/elle">Talk to Elle</a>
          </div>
          <div class="tep-footer-col">
            <div class="tep-footer-col-h">FRAMEWORK</div>
            <a href="https://philpeople.org/profiles/stewart-barteau">Corpus</a>
            <a href="/observer">The Observer</a>
            <a href="/about">NECAI-F</a>
            <a href="/about">About</a>
          </div>
          <div class="tep-footer-col">
            <div class="tep-footer-col-h">CONNECT</div>
            <a href="/contact">Contact</a>
            <a href="/pricing">Pricing</a>
            <a href="/donate">Donate</a>
