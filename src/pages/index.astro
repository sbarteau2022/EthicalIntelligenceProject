---
// ============================================================
// THE ETHICAL INTELLIGENCE PROJECT — Landing
// Blue · Gold · White marble palette · Light/Dark toggle
// ============================================================
import Layout from '~/layouts/Layout.astro';
const chatApiUrl = import.meta.env.PUBLIC_RAPIDAI_CHAT_API_URL ?? '';

const metadata = {
  title: 'The Ethical Intelligence Project — Community-Based Intelligence',
  description:
    'Community-based intelligence infrastructure that transforms complexity into action. Intelligence should serve the people doing the work.',
};

const programs = [
  {
    name: 'Agricultural Intelligence',
    body: 'Plain-language navigation for USDA programs, conservation initiatives, agricultural funding, crop insurance, and farm resources.',
    because: 'Because access should not require a lawyer and an accountant.',
    href: '/programs/agriculture',
    icon: 'leaf',
  },
  {
    name: 'Healthcare Navigation',
    body: 'Guided support for healthcare access, benefits eligibility, assistance programs, and patient rights.',
    because: 'Because understanding healthcare should not be a full-time job.',
    href: '/programs/healthcare',
    icon: 'cross',
  },
  {
    name: 'Small Business Resource Hub',
    body: 'Licensing, compliance, legal literacy, grants, funding pathways, and operational guidance for rural entrepreneurs and local businesses.',
    because: 'Because opportunity should not belong only to those who can afford consultants.',
    href: '/programs/business',
    icon: 'briefcase',
  },
  {
    name: 'Civic Intelligence',
    body: 'Government documents translated into language people can actually use.',
    because: 'Because participation requires understanding.',
    href: '/programs/civic',
    icon: 'people',
  },
];

const principles = [
  { name: 'Transparent', body: 'Our methods, data, and models are open to review.', icon: 'eye' },
  { name: 'Auditable', body: 'Systems are designed for independent audit.', icon: 'shield' },
  { name: 'Human-Centered', body: 'Technology serves people. Not the other way around.', icon: 'people' },
  { name: 'Non-Extractive', body: 'We do not sell data. We build trust.', icon: 'hands' },
  { name: 'Community Governed', body: 'Guided by the communities we exist to serve.', icon: 'people' },
];
---

<Layout metadata={metadata}>
  <div class="eip" data-theme="light">
    <!-- NAV -->
    <header class="eip-nav">
      <div class="eip-nav-inner">
        <a href="/" class="eip-brand">
          <svg class="eip-compass" viewBox="0 0 48 48" fill="none">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.2" opacity="0.5"></circle>
            <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="0.8" opacity="0.3"></circle>
            <path d="M24 4 L27 21 L44 24 L27 27 L24 44 L21 27 L4 24 L21 21 Z" fill="currentColor"></path>
            <circle cx="24" cy="24" r="2.5" fill="var(--bg)"></circle>
          </svg>
          <span class="eip-brand-text">THE ETHICAL<br />INTELLIGENCE PROJECT</span>
        </a>

        <!-- Desktop nav -->
        <nav class="eip-links">
          <a href="#mission">MISSION</a>
          <div class="eip-dropdown">
            <a href="#build" class="eip-dropdown-trigger"
              >WHAT WE BUILD <svg viewBox="0 0 12 12" class="eip-caret"
                ><path d="M2 4l4 4 4-4" stroke="currentColor" fill="none" stroke-width="1.4"></path></svg
              ></a
            >
            <div class="eip-dropdown-menu">
              <a href="https://elle-law.pages.dev"
                ><span class="eip-dd-name">Elle Law</span><span class="eip-dd-sub">LSAT tactical reasoning</span></a
              >
              <a href="https://harmonizer-two.vercel.app"
                ><span class="eip-dd-name">Peer Support</span><span class="eip-dd-sub"
                  >Harmonizer — recovery & support</span
                ></a
              >
              <a href="/programs/atlas-edu"
                ><span class="eip-dd-name">Atlas Edu</span><span class="eip-dd-sub">Learning & navigation</span></a
              >
              <a href="/programs/madmind"
                ><span class="eip-dd-name">MadMind Journal</span><span class="eip-dd-sub"
                  >Structural diagnosis from outside the frame</span
                ></a
              >
              <a href="https://rapidai.pages.dev/coo/"
                ><span class="eip-dd-name">RAPID</span><span class="eip-dd-sub">Operational intelligence</span></a
              >
              <a href="/observer"
                ><span class="eip-dd-name">The Observer</span><span class="eip-dd-sub"
                  >Research & testimony platform</span
                ></a
              >
              <div class="eip-dd-divider"></div>
              <a href="#build" class="eip-dd-all">See all programs →</a>
            </div>
          </div>
          <a href="#observer">THE OBSERVER</a>
          <a href="#principles">PRINCIPLES</a>
          <a href="#involved">GET INVOLVED</a>
          <a href="/about">ABOUT</a>
          <button class="eip-theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <svg class="eip-sun-icon" viewBox="0 0 24 24"
              ><circle cx="12" cy="12" r="5" stroke="currentColor" fill="none" stroke-width="1.5"></circle><path
                d="M12 1v3M12 20v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M1 12h3M20 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"
                stroke="currentColor"
                stroke-width="1.5"></path></svg
            >
            <svg class="eip-moon-icon" viewBox="0 0 24 24"
              ><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z" stroke="currentColor" fill="none" stroke-width="1.5"
              ></path></svg
            >
          </button>
          <a href="/donate" class="eip-donate">DONATE</a>
        </nav>

        <!-- Mobile controls -->
        <div class="eip-mobile-controls">
          <button class="eip-theme-toggle" id="themeToggleM" aria-label="Toggle theme">
            <svg class="eip-sun-icon" viewBox="0 0 24 24"
              ><circle cx="12" cy="12" r="5" stroke="currentColor" fill="none" stroke-width="1.5"></circle><path
                d="M12 1v3M12 20v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M1 12h3M20 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"
                stroke="currentColor"
                stroke-width="1.5"></path></svg
            >
            <svg class="eip-moon-icon" viewBox="0 0 24 24"
              ><path d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z" stroke="currentColor" fill="none" stroke-width="1.5"
              ></path></svg
            >
          </button>
          <button class="eip-burger" id="burger" aria-label="Menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>

      <!-- Mobile drawer -->
      <div class="eip-drawer" id="drawer">
        <a href="#mission" class="eip-drawer-link">MISSION</a>
        <div class="eip-drawer-group">
          <button class="eip-drawer-acc" id="accBtn"
            >WHAT WE BUILD <svg viewBox="0 0 12 12" class="eip-caret"
              ><path d="M2 4l4 4 4-4" stroke="currentColor" fill="none" stroke-width="1.4"></path></svg
            ></button
          >
          <div class="eip-drawer-sub" id="accSub">
            <a href="https://elle-law.pages.dev">Elle Law</a>
            <a href="https://harmonizer-two.vercel.app">Peer Support</a>
            <a href="/programs/atlas-edu">Atlas Edu</a>
            <a href="/programs/madmind">MadMind Journal</a>
            <a href="https://rapidai.pages.dev/coo/">RAPID</a>
            <a href="/observer">The Observer</a>
          </div>
        </div>
        <a href="#observer" class="eip-drawer-link">THE OBSERVER</a>
        <a href="#principles" class="eip-drawer-link">PRINCIPLES</a>
        <a href="#involved" class="eip-drawer-link">GET INVOLVED</a>
        <a href="/about" class="eip-drawer-link">ABOUT</a>
        <a href="/donate" class="eip-drawer-link eip-drawer-donate">DONATE</a>
      </div>
    </header>

    <!-- HERO -->
    <section class="eip-hero">
      <div class="eip-hero-grid">
        <div class="eip-hero-left">
          <h1 class="eip-h1">Community-Based<br />Intelligence</h1>
          <p class="eip-h1-sub"><em>for the People Doing the Work.</em></p>
          <div class="eip-rule"></div>
          <div class="eip-exists">
            <div class="eip-exists-item">
              <svg viewBox="0 0 24 24" class="eip-ei-icon"
                ><path d="M4 3h12l4 4v14H4z" stroke="currentColor" fill="none" stroke-width="1.3"></path><path
                  d="M8 9h8M8 13h8M8 17h5"
                  stroke="currentColor"
                  stroke-width="1.3"></path></svg
              >
              <span>THE INFORMATION<br />EXISTS.</span>
            </div>
            <div class="eip-exists-item">
              <svg viewBox="0 0 24 24" class="eip-ei-icon"
                ><circle cx="9" cy="8" r="3" stroke="currentColor" fill="none" stroke-width="1.3"></circle><circle
                  cx="16"
                  cy="9"
                  r="2.4"
                  stroke="currentColor"
                  fill="none"
                  stroke-width="1.3"></circle><path
                  d="M3 19c0-3 3-5 6-5s6 2 6 5M14 14c3 0 6 1.6 6 4.4"
                  stroke="currentColor"
                  fill="none"
                  stroke-width="1.3"></path></svg
              >
              <span>THE RESOURCES<br />EXIST.</span>
            </div>
            <div class="eip-exists-item">
              <svg viewBox="0 0 24 24" class="eip-ei-icon"
                ><circle cx="12" cy="12" r="9" stroke="currentColor" fill="none" stroke-width="1.3"></circle><circle
                  cx="12"
                  cy="12"
                  r="5"
                  stroke="currentColor"
                  fill="none"
                  stroke-width="1.3"></circle><circle cx="12" cy="12" r="1.4" fill="currentColor"></circle></svg
              >
              <span>THE OPPORTUNITIES<br />EXIST.</span>
            </div>
          </div>
          <p class="eip-lead">For millions of working people, the problem is access.</p>
          <p class="eip-body">
            Government programs, healthcare systems, legal processes, grant opportunities, and civic institutions are
            often written for specialists, consultants, and organizations with resources most communities do not have.
          </p>
          <p class="eip-accent-line">The Ethical Intelligence Project exists to close that gap.</p>
          <p class="eip-body">
            We build community-based intelligence infrastructure that transforms complexity into action.
          </p>
          <div class="eip-cta-row">
            <a href="#build" class="eip-btn eip-btn-primary">LEARN MORE →</a>
            <a href="/donate" class="eip-btn eip-btn-ghost">SUPPORT THE MISSION</a>
          </div>
        </div>
        <div class="eip-hero-right">
          <div class="marble-hero">
            <div class="marble-layer m1"></div>
            <div class="marble-layer m2"></div>
            <div class="marble-layer m3"></div>
            <div class="marble-veins"></div>
            <div class="marble-glow"></div>
            <div class="eip-constellation">
              <span class="eip-c-label" style="top:14%;left:28%">COMMUNITIES</span>
              <span class="eip-c-label" style="top:16%;right:8%">OPPORTUNITIES</span>
              <span class="eip-c-label" style="top:46%;left:7%">RESOURCES</span>
              <span class="eip-c-label" style="bottom:20%;right:16%">UNDERSTANDING</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MISSION -->
    <section id="mission" class="eip-band">
      <div class="eip-band-inner">
        <div class="eip-band-title">
          <svg viewBox="0 0 48 48" class="eip-band-icon"
            ><path
              d="M24 6v36M12 18h24M14 42h20M16 18l-4 24M32 18l4 24"
              stroke="currentColor"
              fill="none"
              stroke-width="1.2"></path><circle cx="24" cy="6" r="2.5" fill="currentColor"></circle></svg
          >
          <h2>A New Kind of<br />Public Infrastructure</h2>
        </div>
        <div class="eip-band-col">
          <p class="eip-band-strong">The internet gave people information.</p>
          <p class="eip-band-accent"><em>We are building understanding.</em></p>
          <p class="eip-band-body">
            The Ethical Intelligence Project combines human expertise, transparent research, and accountable artificial
            intelligence to help people find resources, understand institutions, and make informed decisions.
          </p>
        </div>
        <div class="eip-band-col eip-band-divider">
          <p class="eip-band-body">Every system we build follows a simple principle:</p>
          <p class="eip-band-accent eip-band-accent-lg">
            <em>Intelligence should serve the people doing the work.</em>
          </p>
        </div>
      </div>
    </section>

    <!-- WHAT WE BUILD -->
    <section id="build" class="eip-build">
      <div class="eip-section-label">WHAT WE BUILD</div>
      <div class="eip-programs">
        {
          programs.map((p) => (
            <a href={p.href} class="eip-card">
              <div class="eip-card-img">
                <div class="eip-card-icon">
                  {p.icon === 'leaf' && (
                    <svg viewBox="0 0 24 24">
                      <path
                        d="M12 21c-5-3-8-7-8-12a8 8 0 0116 0c0 5-3 9-8 12z"
                        stroke="currentColor"
                        fill="none"
                        stroke-width="1.3"
                      />
                      <path d="M12 21V9M12 13l4-3M12 16l-3-2" stroke="currentColor" fill="none" stroke-width="1.3" />
                    </svg>
                  )}
                  {p.icon === 'cross' && (
                    <svg viewBox="0 0 24 24">
                      <path d="M10 4h4v6h6v4h-6v6h-4v-6H4v-4h6z" stroke="currentColor" fill="none" stroke-width="1.3" />
                    </svg>
                  )}
                  {p.icon === 'briefcase' && (
                    <svg viewBox="0 0 24 24">
                      <rect
                        x="3"
                        y="8"
                        width="18"
                        height="12"
                        rx="1.5"
                        stroke="currentColor"
                        fill="none"
                        stroke-width="1.3"
                      />
                      <path
                        d="M8 8V6a2 2 0 012-2h4a2 2 0 012 2v2M3 13h18"
                        stroke="currentColor"
                        fill="none"
                        stroke-width="1.3"
                      />
                    </svg>
                  )}
                  {p.icon === 'people' && (
                    <svg viewBox="0 0 24 24">
                      <circle cx="9" cy="8" r="3" stroke="currentColor" fill="none" stroke-width="1.3" />
                      <circle cx="16" cy="9" r="2.4" stroke="currentColor" fill="none" stroke-width="1.3" />
                      <path
                        d="M3 19c0-3 3-5 6-5s6 2 6 5M14 14c3 0 6 1.6 6 4.4"
                        stroke="currentColor"
                        fill="none"
                        stroke-width="1.3"
                      />
                    </svg>
                  )}
                </div>
              </div>
              <h3 class="eip-card-title">{p.name}</h3>
              <p class="eip-card-body">{p.body}</p>
              <p class="eip-card-because">
                <em>{p.because}</em>
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- OBSERVER -->
    <section id="observer" class="eip-observer">
      <div class="eip-observer-inner">
        <div class="eip-observer-left">
          <h2 class="eip-observer-title">THE OBSERVER</h2>
          <p class="eip-observer-lead">
            The Observer is the research and testimony platform operated by the Foundation.
          </p>
          <p class="eip-observer-body">
            It preserves public records, analyzes institutional systems, documents structural patterns, and creates
            permanent space for witness testimony from people living inside the events shaping our world.
          </p>
          <a href="/observer" class="eip-btn eip-btn-ghost">EXPLORE THE OBSERVER →</a>
        </div>
        <div class="eip-observer-mid"><div class="eip-globe"></div></div>
        <div class="eip-observer-right">
          <div class="eip-observer-claim"><span class="eip-check">▣</span> Every claim is sourced.</div>
          <div class="eip-observer-claim"><span class="eip-check">▣</span> Every revision is documented.</div>
          <div class="eip-observer-claim"><span class="eip-check">▣</span> Every disclosure is public.</div>
          <div class="eip-observer-rule"></div>
          <p class="eip-observer-strong">Transparency is not a feature.</p>
          <p class="eip-observer-accent"><em>It is the foundation.</em></p>
        </div>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section id="principles" class="eip-principles">
      <div class="eip-section-label">OUR AI PRINCIPLES</div>
      <div class="eip-principles-row">
        {
          principles.map((pr) => (
            <div class="eip-principle">
              <div class="eip-principle-icon">
                {pr.icon === 'eye' && (
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z"
                      stroke="currentColor"
                      fill="none"
                      stroke-width="1.3"
                    />
                    <circle cx="12" cy="12" r="3" stroke="currentColor" fill="none" stroke-width="1.3" />
                  </svg>
                )}
                {pr.icon === 'shield' && (
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"
                      stroke="currentColor"
                      fill="none"
                      stroke-width="1.3"
                    />
                    <path d="M9 12l2 2 4-4" stroke="currentColor" fill="none" stroke-width="1.3" />
                  </svg>
                )}
                {pr.icon === 'people' && (
                  <svg viewBox="0 0 24 24">
                    <circle cx="9" cy="8" r="3" stroke="currentColor" fill="none" stroke-width="1.3" />
                    <circle cx="16" cy="9" r="2.4" stroke="currentColor" fill="none" stroke-width="1.3" />
                    <path
                      d="M3 19c0-3 3-5 6-5s6 2 6 5M14 14c3 0 6 1.6 6 4.4"
                      stroke="currentColor"
                      fill="none"
                      stroke-width="1.3"
                    />
                  </svg>
                )}
                {pr.icon === 'hands' && (
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 21c-5-3-8-6-8-10a4 4 0 018-1 4 4 0 018 1c0 4-3 7-8 10z"
                      stroke="currentColor"
                      fill="none"
                      stroke-width="1.3"
                    />
                  </svg>
                )}
              </div>
              <h4>{pr.name}</h4>
              <p>{pr.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- WHY + JOIN -->
    <section id="involved" class="eip-why">
      <div class="eip-why-inner">
        <div class="eip-why-left">
          <div class="eip-section-label eip-label-left">WHY THIS MATTERS</div>
          <p class="eip-why-strong">A resource nobody can understand is not a resource.</p>
          <p class="eip-why-strong">A right nobody can access is not a right.</p>
          <p class="eip-why-strong">Information that cannot be used is exclusion.</p>
          <p class="eip-why-body">
            The future will be shaped by intelligence systems. The question is whether those systems serve institutions
            — or the people living inside them.
          </p>
          <p class="eip-why-accent"><em>We know our answer.</em></p>
        </div>
        <div class="eip-why-right">
          <div class="eip-section-label eip-label-left">JOIN THE PROJECT</div>
          <p class="eip-join-body">
            Whether you're a farmer, educator, veteran, community leader, researcher, donor, developer, or citizen,
            there is a place for you here.
          </p>
          <p class="eip-join-body">Help build intelligence infrastructure that belongs to the public.</p>
          <div class="eip-join-grid">
            <a href="/volunteer" class="eip-join-btn">VOLUNTEER</a>
            <a href="/partner" class="eip-join-btn">PARTNER</a>
            <a href="/donate" class="eip-join-btn eip-join-btn-gold">DONATE</a>
            <a href="/subscribe" class="eip-join-btn">STAY INFORMED</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="eip-footer">
      <div class="eip-footer-inner">
        <div class="eip-footer-brand">
          <svg class="eip-compass" viewBox="0 0 48 48" fill="none" style="width:28px;height:28px">
            <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.2" opacity="0.5"></circle>
            <path d="M24 4 L27 21 L44 24 L27 27 L24 44 L21 27 L4 24 L21 21 Z" fill="currentColor"></path>
          </svg>
          <span>THE ETHICAL INTELLIGENCE PROJECT<br /><span class="eip-footer-loc">Hermann, Missouri</span></span>
        </div>
        <nav class="eip-footer-links">
          <a href="/about">ABOUT</a><a href="/transparency">TRANSPARENCY</a><a href="/observer">NECAI-F v2</a><a
            href="/contact">CONTACT</a
          ><a href="/careers">CAREERS</a>
        </nav>
        <div class="eip-footer-social">
          <a href="#" aria-label="X">𝕏</a><a href="#" aria-label="Facebook">f</a><a href="#" aria-label="LinkedIn">in</a
          ><a href="#" aria-label="YouTube">▶</a>
        </div>
      </div>
    </footer>
  </div>

  <script src="https://elle-worker.sbarteau2022.workers.dev/widget.js" data-title="Elle" data-accent="#A8893A" defer
  ></script>

  <script is:inline>
    (function () {
      const root = document.querySelector('.eip');
      const saved = localStorage.getItem('eip-theme') || 'light';
      root.setAttribute('data-theme', saved);
      function toggleTheme() {
        const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        root.setAttribute('data-theme', next);
        localStorage.setItem('eip-theme', next);
      }
      const t1 = document.getElementById('themeToggle');
      const t2 = document.getElementById('themeToggleM');
      if (t1) t1.addEventListener('click', toggleTheme);
      if (t2) t2.addEventListener('click', toggleTheme);

      // Mobile drawer
      const burger = document.getElementById('burger');
      const drawer = document.getElementById('drawer');
      if (burger && drawer) {
        burger.addEventListener('click', function () {
          burger.classList.toggle('open');
          drawer.classList.toggle('open');
        });
        // Close drawer when a link is tapped
        drawer.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () {
            burger.classList.remove('open');
            drawer.classList.remove('open');
          });
        });
      }

      // Mobile accordion
      const accBtn = document.getElementById('accBtn');
      const accSub = document.getElementById('accSub');
      if (accBtn && accSub) {
        accBtn.addEventListener('click', function () {
          accBtn.classList.toggle('open');
          accSub.classList.toggle('open');
        });
      }
    })();
  </script>

  <!-- RAPID²AI Marketing Chat Widget -->
  <style>
    /* Chat widget bubble */
    #rapidai-widget-btn {
      position: fixed; bottom: 24px; right: 24px; z-index: 1000;
      width: 52px; height: 52px; border-radius: 50%;
      background: #c9a55c; color: #0a0e0c; border: none; cursor: pointer;
      box-shadow: 0 4px 20px rgba(201,165,92,0.35);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; transition: transform 0.2s, background 0.2s;
    }
    #rapidai-widget-btn:hover { transform: scale(1.08); background: #e0b96a; }
    #rapidai-widget-panel {
      position: fixed; bottom: 88px; right: 24px; z-index: 1000;
      width: 360px; max-height: 520px;
      background: #111714; border: 1px solid #2a332a; border-radius: 14px;
      display: none; flex-direction: column;
      box-shadow: 0 8px 40px rgba(0,0,0,0.6);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      overflow: hidden;
    }
    #rapidai-widget-panel.open { display: flex; }
    .rwp-header {
