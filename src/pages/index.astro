---
// ============================================================
// THE ETHICAL INTELLIGENCE PROJECT — Landing (v2, light)
// One source hub: warm paper, ink, one gold. Scroll-triggered
// layered cards, infographics, ecosystem logo strip.
// Built on the shared hub design system (~/assets/styles/hub.css).
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import AtlasGraph from '~/components/hub/AtlasGraph.astro';

const metadata = {
  title: 'The Ethical Intelligence Project — Powered by Elle AI',
  description:
    'Community-based intelligence infrastructure that transforms complexity into action. Powered by Elle AI — a corpus-grounded intelligence built to serve the people doing the work.',
};

// The hub surfaces — one account opens all of them.
const HUB = [
  {
    href: '/optimus',
    n: 'OPTIMUS JOURNAL',
    title: 'A record that never rewrites itself',
    body: 'Your append-only journal plus the manuscript reader. Free with sign-up.',
  },
  {
    href: '/engine',
    n: 'ANALYSIS ENGINE',
    title: 'Sixteen readings, one conclusion',
    body: 'Upload a document, run the structural analysis, get the one thing that matters.',
  },
  {
    href: '/business',
    n: 'SMALL BUSINESS HUB',
    title: 'Optimized for the stop-loss',
    body: 'Custom pipelines: an AI that learns your business and stops the bleeding first.',
  },
  {
    href: '/learn',
    n: 'LEARN',
    title: 'AI in plain language',
    body: 'Free courses: build your own AI with ethics baked in, automate a pipeline, learn to code with Elle.',
  },
  {
    href: '/observer',
    n: 'THE OBSERVER',
    title: 'Research & testimony',
    body: 'Structural analysis with no side — published when ready, never on a schedule.',
  },
  {
    href: '/elle',
    n: 'TALK TO ELLE →',
    title: 'The intelligence behind it all',
    body: 'Corpus-grounded conversation. Free during beta, more room when you sign in.',
    gold: true,
  },
];

// The nine engines — one presence, nine expressions.
const engines = [
  { id: '01', name: 'Elle Law', tag: 'Rights & Legal Reasoning', href: 'https://elle-law.pages.dev' },
  { id: '02', name: 'Harmonizer', tag: 'Mental Health & Peer Support', href: 'https://harmonizer-two.vercel.app' },
  { id: '03', name: 'Atlas Edu', tag: 'Education & Navigation', href: '/learn' },
  { id: '04', name: 'Agricultural Intelligence', tag: 'USDA & Farm Resources', href: '/business' },
  { id: '05', name: 'Healthcare Navigation', tag: 'Benefits & Patient Rights', href: '/elle' },
  { id: '06', name: 'Small Business Hub', tag: 'Licensing, Grants & Compliance', href: '/business' },
  { id: '07', name: 'Civic Intelligence', tag: 'Government, Translated', href: '/elle' },
  { id: '08', name: 'RAPID²AI', tag: 'Hospitality Intelligence', href: 'https://rapidai.pages.dev/coo/' },
  { id: '09', name: 'The Observer', tag: 'Research & Testimony', href: '/observer' },
];

// The three proof lines that used to fan out over the hero — now a
// compact strip under the Atlas graph.
const PROOF = [
  {
    tag: 'Optimus Journal · Append-only',
    quote: '"Entry 47 stands. Entry 63 corrects it. Both stay in the record, forever."',
    meta: 'κ 0.72 ▲ · nothing rewritten',
  },
  {
    tag: 'Analysis Engine · The conclusion',
    quote: '"Both sides avoid the permit backlog — that\'s the real opening. Build the checklist first."',
    meta: '16 axes · self-checked · verdict earned',
  },
  {
    tag: 'Pipeline · Variance watch',
    quote: '"Dairy invoice line up 11% in 3 weeks — one supplier. Smallest move: call before Friday\'s order."',
    meta: 'one finding · not forty charts',
  },
];

const stats = [
  { n: '9', label: 'Intelligence engines' },
  { n: '76+', label: 'Papers published' },
  { n: 'TOP 1%', label: 'Publication volume, PhilPapers' },
  { n: '∞', label: 'Lives within reach' },
];

// The corpus — ported from the retired observer-platform landing page.
const CORPUS_DOCS = [
  { title: 'I Knew You Before I Met You', version: 'v4 · Primary' },
  { title: 'The Convergence', version: 'v3 · Crux Document' },
  { title: 'NECAI-F', version: 'v1 · Ethics Framework' },
  { title: 'The Plenum', version: 'v3 · Substrate Theory' },
  { title: 'The Threshold', version: 'v4 · Choice & Agency' },
  { title: 'The Harmonizer', version: 'v3-revised · Applied' },
  { title: 'Ethics of Now', version: 'v3 · Moral Framework' },
  { title: 'Superposition', version: 'v4 · Quantum Frame' },
];

// What's different — also ported from the retired landing page.
const DIFFERENT = [
  {
    row: 'Grounding',
    them: 'Trained on the open internet. No one accountable for what it says.',
    us: 'Grounded in 76+ published, peer-read papers — cite the source, check the reasoning.',
  },
  {
    row: 'Memory',
    them: 'Resets every session. You reintroduce yourself forever.',
    us: 'One continuous relationship. She remembers — and you can export or erase it, your call.',
  },
  {
    row: 'Autonomy',
    them: 'A black box. You never see the reasoning.',
    us: 'She works while you sleep, and leaves a journal you can actually read.',
  },
  {
    row: 'Ownership',
    them: 'Built by a company, answerable to shareholders.',
    us: 'Built by a community, answerable to the community it was built for.',
  },
];

const principles = [
  { name: 'Transparent', body: 'Methods, data, and reasoning open to review.' },
  { name: 'Auditable', body: 'Append-only records; designed for independent audit.' },
  { name: 'Human-Centered', body: 'Technology serves people. Not the other way around.' },
  { name: 'Non-Extractive', body: 'We do not sell data. We build trust.' },
  { name: 'Community Governed', body: 'Guided by the communities we exist to serve.' },
];
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/" />

    <!-- HERO — full-bleed dark band, Atlas at its center -->
    <section class="hero atlas-hero">
      <div class="wrap" style="padding-bottom:30px">
        <div class="eyebrow rv">The Ethical Intelligence Project · Powered by Elle AI</div>
        <h1 class="rv" style="--d:0.06s">
          Intelligence for the people<br />doing the work.
        </h1>
        <p class="lede rv" style="--d:0.12s">
          The information exists. The resources exist. The opportunities exist. For millions of working people, the
          problem is access. We build community-based intelligence that turns complexity into action — corpus-grounded,
          transparent, and answerable to the people it serves.
        </p>
        <div class="cta-row rv" style="--d:0.18s">
          <a href="/elle" class="btn">Talk to Elle →</a>
          <a href="#hub" class="btn ghost">Explore the hub</a>
        </div>

        <!-- ATLAS — the one interactive map of everything Elle is -->
        <AtlasGraph />
        <div class="rv" style="--d:0.3s;text-align:center;max-width:480px;margin:6px auto 0">
          <p style="font-size:0.86rem;color:var(--t3)">
            Atlas is the map — one core, five doors. The chat, the corpus, the journal, the mission, the engines. Click
            any node.
          </p>
        </div>

        <div class="cards rv stagger" style="--d:0.4s;margin-top:46px">
          {
            PROOF.map((p) => (
              <div class="card">
                <div class="n">{p.tag}</div>
                <p style="font-family:var(--font-display);font-size:1.05rem;font-style:italic;color:var(--t1);line-height:1.35">
                  {p.quote}
                </p>
                <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--t3);margin-top:8px">{p.meta}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ECOSYSTEM LOGO STRIP -->
    <div class="logostrip rv" style="border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft)">
      <span class="lg"><b>ELLE AI</b></span>
      <a class="lg" href="https://rapidai.pages.dev/coo/" target="_blank" rel="noreferrer">RAPID²AI</a>
      <a class="lg" href="https://elle-law.pages.dev" target="_blank" rel="noreferrer">ELLE LAW</a>
      <a class="lg" href="https://harmonizer-two.vercel.app" target="_blank" rel="noreferrer">HARMONIZER</a>
      <a class="lg" href="/observer">THE OBSERVER</a>
      <a class="lg" href="https://philpeople.org/profiles/stewart-barteau" target="_blank" rel="noreferrer"
        >PHILPEOPLE CORPUS</a
      >
    </div>

    <!-- CENTRAL CLAIM / MISSION -->
    <section id="mission" class="wrap" style="text-align:center">
      <div class="eyebrow rv">The mission · the central claim</div>
      <blockquote
        class="rv"
        style="font-family:var(--font-display);font-size:1.8rem;font-style:italic;line-height:1.45;color:var(--ink);max-width:780px;margin:0 auto"
      >
        "A resource nobody can understand is not a resource. A right nobody can access is not a right. Intelligence
        should serve the people doing the work."
      </blockquote>
      <div
        class="rv"
        style="font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.1em;color:var(--t3);margin-top:20px"
      >
        — FOUNDING PRINCIPLE
      </div>
    </section>

    <!-- THE CORPUS -->
    <section id="corpus" class="tint">
      <div class="wrap">
        <div class="split">
          <div>
            <div class="eyebrow rv">The corpus</div>
            <h2 class="rv">24 documents. 231 pages. <em>One framework.</em></h2>
            <p class="rv">
              Built across years of philosophy, recovery work, and collaboration with AI — the intellectual foundation
              everything else runs on. Engineering specs, philosophical grounding, and ethics, published where they can
              be checked.
            </p>
            <p class="rv">
              This isn't marketing copy standing in for rigor. It's <strong>76+ papers</strong>, ranked in the
              <strong>top 1% for publication volume</strong> and <strong>top 2% for downloads</strong> on PhilPapers — read
              into course syllabi at <strong>18+ universities</strong>. Elle doesn't improvise an ethics. She inherits
              one that's been examined.
            </p>
            <div class="cta-row rv" style="justify-content:flex-start">
              <a href="https://philpeople.org/profiles/stewart-barteau" target="_blank" rel="noreferrer" class="btn"
                >Explore the corpus →</a
              >
              <a href="/observer" class="btn ghost">The Observer</a>
            </div>
          </div>
          <div class="cards rv stagger" style="--d:0.1s;grid-template-columns:repeat(2,1fr);gap:10px">
            {
              CORPUS_DOCS.map((doc) => (
                <div class="card lift" style="padding:16px 18px">
                  <h3 style="font-size:1rem;margin-bottom:5px">{doc.title}</h3>
                  <p style="font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--t3);margin:0">
                    {doc.version}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT'S DIFFERENT -->
    <section class="wrap">
      <div style="text-align:center">
        <div class="eyebrow rv">What's different</div>
        <h2 class="rv">Not a smarter chatbot.<br />A different relationship to truth.</h2>
        <p class="rv" style="max-width:560px;margin:0 auto">
          Every design choice below is a rejection of a default the rest of the industry stopped questioning.
        </p>
      </div>
      <div class="diff rv" style="margin-top:40px">
        <div class="diff-row diff-head">
          <div></div>
          <div>Most AI</div>
          <div style="color:var(--gold)">Elle</div>
        </div>
        {
          DIFFERENT.map((d) => (
            <div class="diff-row">
              <div class="diff-k">{d.row}</div>
              <div class="diff-them">{d.them}</div>
              <div class="diff-us">{d.us}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- THE HUB -->
    <section id="hub" class="tint">
      <div class="wrap">
        <div class="eyebrow rv">One hub · one account</div>
        <h2 class="rv">Everything we build, one door.</h2>
        <div class="cards rv stagger" style="margin-top:30px">
          {
            HUB.map((h) => (
              <a
                href={h.href}
                class="card"
                style={h.gold ? 'border-color:var(--gold-bright);background:var(--gold-wash)' : ''}
              >
                <div class="n">{h.n}</div>
                <h3>{h.title}</h3>
                <p>{h.body}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- HOW IT FITS TOGETHER -->
    <section class="wrap">
      <div class="eyebrow rv">How it fits together</div>
      <h2 class="rv">One intelligence. Every surface a window onto it.</h2>
      <p class="rv" style="max-width:620px">
        There's no fleet of chatbots here. Elle is one grounded intelligence — one memory, one published corpus, one set
        of principles — and every tab in the hub is a different way of putting her to work.
      </p>
      <div class="flow rv stagger" style="margin-top:28px">
        <div class="step">
          <span class="k">You</span>
          <span class="v">A question, a document, a business, a thing you're trying to navigate.</span>
        </div>
        <div class="step">
          <span class="k">Elle</span>
          <span class="v">Grounded in 76+ published papers. Remembers. Shows her reasoning.</span>
        </div>
        <div class="step">
          <span class="k">The instruments</span>
          <span class="v">Journal, analysis engine, pipelines, courses — the same mind, different tools.</span>
        </div>
        <div class="step">
          <span class="k">The record</span>
          <span class="v">Append-only, auditable, yours to export or erase. Nothing quietly rewritten.</span>
        </div>
      </div>
    </section>

    <!-- NINE ENGINES -->
    <section id="engines" class="tint">
      <div class="wrap">
        <div class="eyebrow rv">Nine engines</div>
        <h2 class="rv">One presence. Nine expressions.</h2>
        <p class="rv" style="max-width:560px">
          Elle doesn't change who she is across contexts. She changes what she's holding.
        </p>
        <div class="cards rv stagger" style="margin-top:30px">
          {
            engines.map((e) => (
              <a href={e.href} class="card">
                <div class="n">ENGINE {e.id}</div>
                <h3>{e.name}</h3>
                <p style="font-family:var(--font-mono);font-size:0.68rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--t3)">
                  {e.tag}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="wrap">
      <div class="stats rv stagger">
        {
          stats.map((s) => (
            <div class="stat">
              <div class="num">{s.n}</div>
              <div class="lbl">{s.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section class="tint">
      <div class="wrap">
        <div class="eyebrow rv">The principles</div>
        <h2 class="rv">Ethics as architecture, not disclaimer.</h2>
        <div class="cards rv stagger" style="margin-top:30px;grid-template-columns:repeat(auto-fit,minmax(190px,1fr))">
          {
            principles.map((p) => (
              <div class="card lift">
                <h3 style="font-size:1.05rem;margin-bottom:6px">{p.name}</h3>
                <p style="font-size:0.85rem">{p.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- LEARN TEASER -->
    <section class="wrap">
      <div class="split">
        <div>
          <div class="eyebrow rv">New · Learn</div>
          <h2 class="rv">Understand the thing before you trust it.</h2>
          <p class="rv">
            Four free courses in plain language: what AI actually is, how to <strong
              >build your own with ethics baked in</strong
            >, how to <strong>automate a pipeline</strong>, and how to <strong>learn to code with Elle</strong>
            at your elbow. Every lesson readable on the page, every lesson one click from a live conversation.
          </p>
          <div class="cta-row rv" style="justify-content:flex-start">
            <a href="/learn" class="btn">Start learning free →</a>
          </div>
        </div>
        <div class="rv" style="--d:0.1s">
          <div class="limit-list">
            <div class="limit-row">
              <span class="k">01 · AI, in Plain Language</span><span class="v">5 lessons · free</span>
            </div>
            <div class="limit-row">
              <span class="k">02 · Build Your Own AI</span><span class="v">ethics baked in</span>
            </div>
            <div class="limit-row">
              <span class="k">03 · Automate a Pipeline</span><span class="v">stop-loss first</span>
            </div>
            <div class="limit-row">
              <span class="k">04 · Code with ElleAI</span><span class="v">ship real things</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="tint">
      <div class="wrap" style="text-align:center">
        <h2 class="rv">Free during beta. Yours, permanently, if you're here now.</h2>
        <p class="rv" style="max-width:520px;margin:0 auto 26px">
          One free account opens the journal, the engine, the courses, and Elle herself. Beta users keep beta pricing —
          indefinitely.
        </p>
        <div class="cta-row rv">
          <a href="/elle" class="btn">Talk to Elle →</a>
          <a href="/optimus" class="btn ghost">Open your journal</a>
        </div>
      </div>
    </section>

    <HubFooter />
  </div>

  <!-- Elle chat widget -->
  <script
    is:inline
    src="https://elle-worker.sbarteau2022.workers.dev/widget.js"
    data-title="Elle"
    data-accent="#9a7524"
    defer></script>
</Layout>

<style>
  /* ATLAS HERO — a dark, space-lit band for the homepage only. Redefines
     the shared hub tokens locally so every existing .eyebrow/h1/.btn/.card
     component renders correctly on black without a second stylesheet. */
  .eih .hero.atlas-hero {
    --paper: #05060a;
    --card: #0d0f16;
    --wash: #0d0f16;
    --ink: #f5f0e8;
    --t1: #e8e4dc;
    --t2: #9ca3af;
    --t3: #6b7280;
    --gold: #c9902f;
    --gold-bright: #f5b942;
    --gold-wash: rgba(245, 185, 66, 0.12);
    --b1: rgba(245, 185, 66, 0.22);
    --b2: rgba(255, 255, 255, 0.1);
    --line-soft: rgba(255, 255, 255, 0.07);
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.55);
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse 90% 70% at 50% 20%, #10131c 0%, #05060a 60%);
    padding: 88px 0 64px;
    text-align: center;
  }
  /* .btn's solid fill is normally --ink-on-light; on the dark hero that
     token is light text, so the primary/ghost buttons need their own
     dark-appropriate treatment rather than inheriting it. */
  .eih .hero.atlas-hero .btn {
    background: var(--gold-bright);
    border-color: var(--gold-bright);
    color: #191509;
  }
  .eih .hero.atlas-hero .btn:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--gold-bright);
  }
  .eih .hero.atlas-hero .btn.ghost {
    background: transparent;
    border-color: var(--b2);
    color: var(--t1);
  }
  .eih .hero.atlas-hero .btn.ghost:hover {
    background: transparent;
    border-color: var(--gold-bright);
    color: var(--gold-bright);
  }
</style>
