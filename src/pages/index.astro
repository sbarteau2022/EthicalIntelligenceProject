// Powered by Elle AI
// Tone: The Observer — dark newspaper aesthetic.
//   Playfair Display · Libre Baskerville · JetBrains Mono
//   Gold (#f59e0b) on near-black (#050709)
// ============================================================
import Layout from '~/layouts/Layout.astro';

const metadata = {
  title: 'The Ethical Intelligence Project — Powered by Elle AI',
  description:
    'Community-based intelligence infrastructure that transforms complexity into action. Powered by Elle AI — a corpus-grounded intelligence built to serve the people doing the work.',
};

// The nine engines — one presence, nine expressions.
const engines = [
  {
    id: '01',
    name: 'Elle Law',
    tag: 'Rights & Legal Reasoning',
    desc: 'Give people the legal literacy the system assumed they already had. LSAT-grade tactical reasoning, plain-language navigation of rights. Not a lawyer — a guide.',
    href: 'https://elle-law.pages.dev',
  },
  {
    id: '02',
    name: 'Harmonizer',
    tag: 'Mental Health & Peer Support',
    desc: 'Not okay is okay. A presence that holds without fixing — built from recovery work and fifteen years of kitchen wisdom.',
    href: 'https://harmonizer-two.vercel.app',
  },
  {
    id: '03',
    name: 'Atlas Edu',
    tag: 'Education & Navigation',
    desc: 'Every mind learns differently. Atlas finds the form knowledge needs to take to actually land — and stick.',
    href: '/programs/atlas-edu',
  },
  {
    id: '04',
    name: 'Agricultural Intelligence',
    tag: 'USDA & Farm Resources',
    desc: 'USDA programs, conservation initiatives, crop insurance, agricultural funding. The resources exist — finding and receiving them is the work.',
    href: '/programs/agriculture',
  },
  {
    id: '05',
    name: 'Healthcare Navigation',
    tag: 'Benefits & Patient Rights',
    desc: 'Guided support for healthcare access, benefits eligibility, assistance programs, and patient rights. Because understanding healthcare should not be a full-time job.',
    href: '/programs/healthcare',
  },
  {
    id: '06',
    name: 'Small Business Hub',
    tag: 'Licensing, Grants & Compliance',
    desc: 'Licensing, compliance, legal literacy, grants and funding pathways for rural entrepreneurs and local operators. Opportunity should not belong only to those who can afford consultants.',
    href: '/programs/business',
  },
  {
    id: '07',
    name: 'Civic Intelligence',
    tag: 'Government, Translated',
    desc: 'Government documents translated into language people can actually use. Because participation requires understanding.',
    href: '/programs/civic',
  },
  {
    id: '08',
    name: 'RAPID²AI',
