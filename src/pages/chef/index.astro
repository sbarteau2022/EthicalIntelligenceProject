---
// RAPID²AI — Chef View
// Protected by Google OAuth gate (client-side)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="rapidai-client-id" content={import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? ''} />
    <title>RAPID²AI — Chef View</title>
    <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
    <script is:inline src="/rapidai-auth.js"></script>
    <style>
      :root {
        --bg: #0a0e0c;
        --surface: #111612;
        --border: #1e2820;
        --gold: #c9a55c;
        --gold-dim: #7a5e28;
        --green: #2ecc71;
        --red: #e74c3c;
        --yellow: #f1c40f;
        --text: #d4d9d5;
        --text-dim: #6b7368;
        --accent: #1a3a2a;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        min-height: 100vh;
      }

      /* AUTH GATE */
      #rapidai-gate {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--bg);
        align-items: center;
        justify-content: center;
        z-index: 9999;
        flex-direction: column;
        gap: 1.5rem;
      }
      .gate-brand {
        font-family: Georgia, serif;
        font-style: italic;
        color: var(--gold);
        font-size: 1.4rem;
      }
      .gate-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2.5rem 3rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
      }
      .gate-title {
        color: var(--text);
        font-size: 1rem;
        font-weight: 600;
      }
      .gate-desc {
        color: var(--text-dim);
        font-size: 0.82rem;
        max-width: 280px;
        line-height: 1.6;
      }
      .btn-google {
        background: #fff;
        color: #3c4043;
        border: 1px solid #dadce0;
        border-radius: 6px;
        padding: 10px 20px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: background 0.15s;
      }
      .btn-google:hover {
        background: #f8f9fa;
      }
      .btn-google svg {
        flex-shrink: 0;
      }

      /* Layout */
      .shell {
        display: grid;
        grid-template-columns: 220px 1fr;
        grid-template-rows: 56px 1fr;
        min-height: 100vh;
      }
      .topbar {
        grid-column: 1 / -1;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        padding: 0 24px;
        gap: 16px;
      }
      .logo {
        font-family: Georgia, serif;
        font-style: italic;
        color: var(--gold);
        font-size: 20px;
        letter-spacing: 1px;
      }
      .logo span {
        font-size: 11px;
        font-style: normal;
        font-family: monospace;
        color: var(--text-dim);
        letter-spacing: 4px;
        margin-left: 8px;
      }
      .topbar-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 20px;
        font-size: 13px;
        color: var(--text-dim);
      }
      .venue-badge {
        background: var(--accent);
        border: 1px solid var(--gold-dim);
        color: var(--gold);
        padding: 3px 10px;
        border-radius: 4px;
        font-size: 11px;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .sync-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--green);
        display: inline-block;
        margin-right: 5px;
      }
      .signout-btn {
        font-size: 12px;
        color: var(--text-dim);
        background: none;
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
      }
      .signout-btn:hover {
        color: var(--text);
      }

      .sidebar {
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 20px 0;
      }
      .nav-section {
        padding: 0 16px;
        margin-bottom: 24px;
      }
      .nav-label {
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 8px;
        padding: 0 8px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        color: var(--text-dim);
        transition: background 0.15s;
        margin-bottom: 2px;
      }
      .nav-item:hover {
        background: var(--accent);
        color: var(--text);
      }
      .nav-item.active {
        background: var(--accent);
        color: var(--gold);
        border-left: 2px solid var(--gold);
      }
      .nav-icon {
        font-size: 15px;
        width: 18px;
        text-align: center;
      }

      .main {
        padding: 28px 32px;
        overflow-y: auto;
      }
      .page-title {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
      }
      .page-sub {
        font-size: 13px;
        color: var(--text-dim);
        margin-bottom: 28px;
      }

      /* Stat cards */
      .stat-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 28px;
      }
      @media (max-width: 900px) {
        .stat-row {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 18px 20px;
      }
      .stat-label {
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 8px;
      }
      .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
      }
      .stat-delta {
        font-size: 12px;
        margin-top: 6px;
      }
      .delta-up {
        color: var(--red);
      }
      .delta-down {
        color: var(--green);
      }
      .delta-neutral {
        color: var(--text-dim);
      }

      /* Section */
      .section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 20px;
      }
      .section-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .section-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
      }
      .section-action {
        font-size: 12px;
        color: var(--gold);
        cursor: pointer;
      }

      /* Table */
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th {
        text-align: left;
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-dim);
        padding: 12px 20px;
        border-bottom: 1px solid var(--border);
      }
      td {
        padding: 13px 20px;
        font-size: 13px;
        border-bottom: 1px solid var(--border);
      }
      tr:last-child td {
        border-bottom: none;
      }
      tr:hover td {
        background: rgba(255, 255, 255, 0.015);
      }

      /* Badges */
      .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.5px;
      }
      .badge-ok {
        background: rgba(46, 204, 113, 0.12);
        color: var(--green);
      }
      .badge-warn {
        background: rgba(241, 196, 15, 0.12);
        color: var(--yellow);
      }
      .badge-alert {
        background: rgba(231, 76, 60, 0.12);
        color: var(--red);
      }
      .badge-info {
        background: rgba(201, 165, 92, 0.12);
        color: var(--gold);
      }

      /* Variance bar */
      .var-bar {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .bar-track {
        flex: 1;
        height: 4px;
        background: var(--border);
        border-radius: 2px;
      }
      .bar-fill {
        height: 4px;
        border-radius: 2px;
      }
      .bar-ok {
        background: var(--green);
      }
      .bar-warn {
        background: var(--yellow);
      }
      .bar-alert {
        background: var(--red);
      }

      /* Upload zone */
      .upload-zone {
        border: 1.5px dashed var(--border);
        border-radius: 8px;
        padding: 28px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s;
        margin: 16px 20px 20px;
      }
      .upload-zone:hover {
        border-color: var(--gold-dim);
      }
      .upload-icon {
        font-size: 28px;
        margin-bottom: 8px;
      }
      .upload-text {
        font-size: 13px;
        color: var(--text-dim);
      }
      .upload-text strong {
        color: var(--gold);
      }

      /* Two-col */
      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
      }
      @media (max-width: 900px) {
        .two-col {
          grid-template-columns: 1fr;
        }
      }

      /* Alert item */
      .alert-item {
        display: flex;
        gap: 12px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        align-items: flex-start;
      }
      .alert-item:last-child {
        border-bottom: none;
      }
      .alert-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-top: 4px;
        flex-shrink: 0;
      }
      .alert-dot-red {
        background: var(--red);
      }
      .alert-dot-yellow {
        background: var(--yellow);
      }
      .alert-dot-gold {
        background: var(--gold);
      }
      .alert-body {
        flex: 1;
      }
      .alert-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
      }
      .alert-sub {
        font-size: 12px;
        color: var(--text-dim);
        margin-top: 2px;
      }
      .alert-time {
        font-size: 11px;
        color: var(--text-dim);
        white-space: nowrap;
      }

      /* View switch pills */
      .view-switch {
        display: flex;
        gap: 0.5rem;
      }
      .view-pill {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        text-decoration: none;
        border: 1px solid var(--border);
        color: var(--text-dim);
        transition: all 0.15s;
      }
      .view-pill.active {
        background: var(--accent);
        border-color: var(--gold-dim);
        color: var(--gold);
      }
      .view-pill:hover {
        color: var(--text);
      }
    </style>
  </head>
  <body>
    <!-- AUTH GATE OVERLAY -->
    <div id="rapidai-gate">
      <div class="gate-brand">RAPID²AI</div>
      <div class="gate-card">
        <div class="gate-title">Chef View — Restricted Access</div>
        <div class="gate-desc">Sign in with your authorized Google account to continue.</div>
        <div id="google-signin-btn"></div>
        <button class="btn-google" id="manual-signin-btn">
          <svg width="18" height="18" viewBox="0 0 18 18"
            ><path
              fill="#4285F4"
              d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.566 2.684-3.875 2.684-6.615z"
            ></path><path
              fill="#34A853"
              d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z"
            ></path><path
              fill="#FBBC05"
              d="M3.964 10.707c-.18-.54-.282-1.117-.282-1.707s.102-1.167.282-1.707V4.961H.957C.347 6.175 0 7.55 0 9s.348 2.825.957 4.039l3.007-2.332z"
            ></path><path
              fill="#EA4335"
              d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.961L3.964 7.293C4.672 5.166 6.656 3.58 9 3.58z"
            ></path></svg
          >
          Sign in with Google
        </button>
        <div><a href="/" style="color:var(--text-dim);font-size:12px;">← Back to site</a></div>
      </div>
    </div>

    <div class="shell">
      <header class="topbar">
        <div class="logo">RAPID²AI <span>CHEF VIEW</span></div>
        <div class="venue-badge">Tin Mill Restaurant</div>
        <div class="topbar-right">
          <div class="view-switch">
            <a class="view-pill" href="/coo/">COO View</a>
            <span class="view-pill active">Chef View</span>
            <a class="view-pill" href="/app/">Chat</a>
          </div>
          <span><span class="sync-dot"></span>Live</span>
          <span id="clock">—</span>
          <button class="signout-btn" onclick="RapidAIAuth.signOut()">Sign out</button>
        </div>
      </header>

      <nav class="sidebar">
        <div class="nav-section">
          <div class="nav-label">Operations</div>
          <div class="nav-item active" onclick="showPage('costs',this)"><span class="nav-icon">📊</span>Cost Pulse</div>
          <div class="nav-item" onclick="showPage('orders',this)"><span class="nav-icon">📦</span>Vendor Orders</div>
          <div class="nav-item" onclick="showPage('par',this)"><span class="nav-icon">⚖️</span>Par & Alerts</div>
          <div class="nav-item" onclick="showPage('upload',this)"><span class="nav-icon">⬆️</span>Upload Invoice</div>
        </div>
        <div class="nav-section">
          <div class="nav-label">Intelligence</div>
          <div class="nav-item" onclick="showPage('variance',this)"><span class="nav-icon">📈</span>Price Variance</div>
          <div class="nav-item" onclick="showPage('credits',this)">
            <span class="nav-icon">🔄</span>Credits & Returns
          </div>
        </div>
      </nav>

      <main class="main" id="main-content">
        <!-- COST PULSE PAGE -->
        <div id="page-costs">
          <div class="page-title">Cost Pulse</div>
          <div class="page-sub">Week of May 26, 2026 · Last invoice: May 28 · US Foods #8841092</div>

          <div class="stat-row">
            <div class="stat-card">
              <div class="stat-label">Food Cost %</div>
              <div class="stat-value">28.4%</div>
              <div class="stat-delta delta-up">▲ 1.2 pts vs last week</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Invoice Total</div>
              <div class="stat-value">$4,218</div>
              <div class="stat-delta delta-up">▲ $312 vs prior delivery</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Credits Pending</div>
              <div class="stat-value">$47.20</div>
              <div class="stat-delta delta-neutral">2 items · awaiting CM</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">Price Alerts</div>
              <div class="stat-value" style="color:var(--yellow)">3</div>
              <div class="stat-delta delta-neutral">SKUs moved &gt;5% this week</div>
            </div>
          </div>

          <div class="two-col">
            <div class="section">
              <div class="section-header"><div class="section-title">Top Cost Movers — This Delivery</div></div>
              <table>
                <thead><tr><th>Item</th><th>Last Price</th><th>This Price</th><th>Δ</th></tr></thead>
                <tbody>
                  <tr><td>Chicken Breast 40lb</td><td>$65.94</td><td>$71.20</td><td class="delta-up">+8.0%</td></tr>
                  <tr><td>Ground Beef 80/20 10lb</td><td>$42.10</td><td>$45.60</td><td class="delta-up">+8.3%</td></tr>
                  <tr><td>Romaine Hearts 24ct</td><td>$18.50</td><td>$17.80</td><td class="delta-down">-3.8%</td></tr>
                  <tr><td>Canola Oil 35lb</td><td>$38.00</td><td>$38.00</td><td class="delta-neutral">—</td></tr>
                  <tr><td>Cheddar Shredded 5lb</td><td>$22.40</td><td>$24.10</td><td class="delta-up">+7.6%</td></tr>
                </tbody>
              </table>
            </div>

            <div class="section">
              <div class="section-header"><div class="section-title">Predictive Alerts</div></div>
              <div class="alert-item">
                <div class="alert-dot alert-dot-yellow"></div>
                <div class="alert-body">
                  <div class="alert-title">Chicken Breast — price move likely in 2–3 wks</div>
                  <div class="alert-sub">Based on 6-invoice pattern from US Foods. Consider adjusting par.</div>
                </div>
                <div class="alert-time">Today</div>
              </div>
              <div class="alert-item">
                <div class="alert-dot alert-dot-red"></div>
                <div class="alert-body">
                  <div class="alert-title">Ground Beef 80/20 — 3rd consecutive increase</div>
                  <div class="alert-sub">+18.4% cumulative over 6 weeks. Review menu pricing.</div>
                </div>
                <div class="alert-time">Today</div>
              </div>
              <div class="alert-item">
                <div class="alert-dot alert-dot-gold"></div>
                <div class="alert-body">
                  <div class="alert-title">Cheddar — seasonal volatility window opening</div>
                  <div class="alert-sub">Dairy typically moves July–August. Pattern suggests +5–12%.</div>
                </div>
                <div class="alert-time">2 days ago</div>
              </div>
            </div>
          </div>

          <div class="section">
            <div class="section-header">
              <div class="section-title">Last Delivery — Full Line Detail</div>
              <div class="section-action">Export CSV</div>
            </div>
            <table>
              <thead
                ><tr><th>Product</th><th>Pack</th><th>Qty Ship</th><th>Unit Price</th><th>Extended</th><th>Gate</th></tr
                ></thead
              >
              <tbody>
                <tr
                  ><td>Chicken Breast Boneless 40lb</td><td>1/40 LB</td><td>4</td><td>$71.20</td><td>$284.80</td><td
                    ><span class="badge badge-ok">✓ Passed</span></td
                  ></tr
                >
                <tr
                  ><td>Ground Beef 80/20 10lb</td><td>2/10 LB</td><td>6</td><td>$45.60</td><td>$273.60</td><td
                    ><span class="badge badge-ok">✓ Passed</span></td
                  ></tr
                >
                <tr
                  ><td>Romaine Hearts 24ct</td><td>3/8 CT</td><td>3</td><td>$17.80</td><td>$53.40</td><td
                    ><span class="badge badge-ok">✓ Passed</span></td
                  ></tr
                >
                <tr
                  ><td>Canola Oil 35lb Jug</td><td>1/35 LB</td><td>2</td><td>$38.00</td><td>$76.00</td><td
                    ><span class="badge badge-ok">✓ Passed</span></td
                  ></tr
                >
                <tr
                  ><td>Cheddar Shredded 5lb</td><td>4/5 LB</td><td>4</td><td>$24.10</td><td>$96.40</td><td
                    ><span class="badge badge-ok">✓ Passed</span></td
                  ></tr
                >
                <tr
                  ><td>Fuel Surcharge</td><td>—</td><td>—</td><td>—</td><td>$10.00</td><td
                    ><span class="badge badge-info">Fee</span></td
                  ></tr
                >
              </tbody>
            </table>
          </div>
        </div>

        <!-- UPLOAD PAGE -->
        <div id="page-upload" style="display:none">
          <div class="page-title">Upload Invoice</div>
          <div class="page-sub">Drop a US Foods CSV export or PDF — two-gate verification runs automatically.</div>
          <div class="section" style="max-width:600px">
            <div class="section-header"><div class="section-title">US Foods Document Upload</div></div>
            <div class="upload-zone" onclick="document.getElementById('csv-input').click()">
              <div class="upload-icon">📄</div>
              <div class="upload-text">
                <strong>Click to select CSV</strong> or drag and drop<br />INVOICE · VEND_SHIP · CREDIT_MEMO
              </div>
              <input type="file" id="csv-input" accept=".csv" style="display:none" onchange="handleFileSelect(this)" />
            </div>
            <div style="padding:0 20px 20px">
              <div id="upload-status" style="font-size:13px;color:var(--text-dim);min-height:40px"></div>
              <button
                onclick="submitUpload()"
                style="background:var(--gold);color:#000;border:none;padding:10px 22px;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;margin-top:8px"
              >
                Run Two-Gate Verification
              </button>
            </div>
          </div>
          <div class="section" style="max-width:600px">
            <div class="section-header"><div class="section-title">Recent Uploads</div></div>
            <table>
              <thead><tr><th>Document</th><th>Type</th><th>Total</th><th>Status</th></tr></thead>
              <tbody>
                <tr
                  ><td>INV-8841092</td><td>INVOICE</td><td>$4,218.40</td><td
                    ><span class="badge badge-ok">Ingested</span></td
                  ></tr
                >
                <tr
                  ><td>CM-0012844</td><td>CREDIT_MEMO</td><td>-$47.20</td><td
                    ><span class="badge badge-warn">Pending Review</span></td
                  ></tr
                >
                <tr
                  ><td>INV-8829301</td><td>INVOICE</td><td>$3,906.10</td><td
                    ><span class="badge badge-ok">Ingested</span></td
                  ></tr
                >
              </tbody>
            </table>
          </div>
        </div>

        <!-- PRICE VARIANCE PAGE -->
        <div id="page-variance" style="display:none">
          <div class="page-title">Price Variance</div>
          <div class="page-sub">Rolling 90-day view · US Foods · Tin Mill Restaurant</div>
          <div class="section">
            <div class="section-header"><div class="section-title">SKU Variance vs 90-Day Average</div></div>
            <table>
              <thead><tr><th>Product</th><th>90-Day Avg</th><th>Current</th><th>Variance</th><th>Trend</th></tr></thead>
