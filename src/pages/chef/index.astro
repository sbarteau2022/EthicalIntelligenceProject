    <script>
      // @ts-nocheck
      // Clock
      function tick() {
        const now = new Date();
        document.getElementById('clock').textContent =
          now.toLocaleTimeString('en-US', {
            hour: '2-digit',
            minute: '2-digit',
            timeZone: 'America/Chicago',
          }) + ' CT';
      }
      tick();
      setInterval(tick, 1000);

      // Nav
      const pages = ['costs', 'upload', 'variance', 'credits', 'par', 'orders'];
      function showPage(id, el) {
        pages.forEach((p) => {
          document.getElementById('page-' + p).style.display = p === id ? '' : 'none';
        });
        document.querySelectorAll('.nav-item').forEach((n) => n.classList.remove('active'));
        el.classList.add('active');
      }

      // Upload
      let selectedFile = null;
      function handleFileSelect(input) {
        selectedFile = input.files[0];
        if (selectedFile) {
          document.getElementById('upload-status').textContent =
            `Selected: ${selectedFile.name} (${(selectedFile.size / 1024).toFixed(1)} KB)`;
        }
      }
      function submitUpload() {
        if (!selectedFile) {
          document.getElementById('upload-status').textContent = 'Please select a CSV file first.';
          return;
        }
        const status = document.getElementById('upload-status');
        status.innerHTML = '<span style="color:var(--gold)">⟳ Running Gate One — SHA-256 integrity...</span>';
        setTimeout(() => {
          status.innerHTML = '<span style="color:var(--gold)">⟳ Running Gate Two — arithmetic verification...</span>';
          setTimeout(() => {
            status.innerHTML = '<span style="color:var(--green)">✓ Both gates passed — document ingested.</span>';
          }, 1200);
        }, 900);
      }

      // Auth gate
      function initAuth() {
        if (RapidAIAuth.isAuthed()) {
          document.getElementById('rapidai-gate').style.display = 'none';
          return;
        }
        document.getElementById('rapidai-gate').style.display = 'flex';
        const clientId = document.querySelector('meta[name="rapidai-client-id"]')?.content;
        if (clientId) {
          function initGSI() {
            if (!window.google?.accounts) return setTimeout(initGSI, 100);
            google.accounts.id.initialize({
              client_id: clientId,
              callback: function (response) {
                if (response.credential) {
                  sessionStorage.setItem('rapidai_auth', response.credential);
                  sessionStorage.setItem('rapidai_authed_at', Date.now().toString());
                  try {
                    const p = JSON.parse(atob(response.credential.split('.')[1]));
                    if (p.email) sessionStorage.setItem('rapidai_email', p.email);
                  } catch (e) {}
                  window.location.reload();
                }
              },
              auto_select: false,
              cancel_on_tap_outside: false,
            });
            google.accounts.id.renderButton(document.getElementById('google-signin-btn'), {
              theme: 'outline',
              size: 'large',
            });
          }
          initGSI();
        }
        document.getElementById('manual-signin-btn').addEventListener('click', function () {
          if (!clientId) {
            RapidAIAuth.signIn('/chef/');
            return;
          }
          const redirectUri = window.location.origin + '/auth/callback';
          const url = `https://accounts.google.com/o/oauth2/v2/auth?client_id=${clientId}&redirect_uri=${encodeURIComponent(redirectUri)}&response_type=id_token&scope=openid%20email%20profile&nonce=${Math.random().toString(36).slice(2)}`;
          sessionStorage.setItem('rapidai_return', '/chef/');
          window.location.href = url;
        });
      }
      initAuth();
    </script>
  </body>
