---
// ============================================================
// FRACTURE ATLAS — past the gate: the collapse of invertibility,
// and what gets made.
//
// Stewart's framing, verified then measured: past full criticality the
// map folds over itself (min f' = 1 - K goes negative — forced), the
// rotation number becomes an interval (x22 opening, measured), tongues
// overlap into multi-stability and hysteresis (measured), chaos becomes
// possible only past the gate (measured), and the old golden route is
// captured — first by 13/21, Fibonacci, then down the mediants to 2/3
// (measured). The thread lives exactly to the gate, not one step past.
// And generation, at the smallest true scale: a ring of 64 oscillators
// whose integer winding charge is frozen forever at strong coupling and
// changes ONLY in discrete integer jumps at weak coupling — topological
// defect creation, quantized, measured. The 2D/3D lift (BKT vortex
// pairs, knot lines, knotted solitons) is literature-typed, not
// simulated; the traversal-to-generation reading is interpretation,
// labeled, with the ring as its evidence.
//
// ONE SOURCE OF TRUTH, LOCKED: everything is read from
// `src/data/fracture-snapshot.json` (scripts/generate-fracture-snapshot.py).
// The renderer draws it; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import snapshot from '~/data/fracture-snapshot.json';

const metadata = {
  title: 'Fracture Atlas — past the gate',
  description:
    'Past critical coupling the circle map folds: the rotation interval opens ×22, tongues overlap into multi-stability and hysteresis, chaos becomes possible only past the gate, the old golden route is captured by Fibonacci locks — and a ring of oscillators shows topological charge changing only in discrete integer jumps. The collapse of invertibility, measured.',
};

const iv = snapshot.interval;
const wBelow = Math.max(...iv.filter((r: { K: number }) => r.K <= 1).map((r: { width: number }) => r.width));
const wAbove = iv.find((r: { K: number }) => r.K === 1.05)!.width;
const ly = snapshot.chaos;
const lyBelow = Math.max(...ly.filter((r: { K: number }) => r.K <= 1).map((r: { maxLyap: number }) => r.maxLyap));
const lyAbove = Math.max(...ly.filter((r: { K: number }) => r.K > 1).map((r: { maxLyap: number }) => r.maxLyap));
const trail = snapshot.capture.filter((c: { captor: string | null }) => c.captor);
const firstCaptor = trail[0];
const lastCaptor = trail[trail.length - 1];
const ov = snapshot.overlap;
const hys = snapshot.hysteresis;
const ring = snapshot.ring;
const slips = ring.fractured.slips.length;
const hist = ring.fractured.jumpHistogram as Record<string, number>;
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="holo-stage">
      <canvas
        id="frac-canvas"
        aria-label="Rotatable 3D rendering of the circle map past critical coupling: the fold, the opening rotation interval, the chaos boundary, the capture of the golden route, overlapping tongues, hysteresis, and a ring of oscillators whose topological charge changes only in discrete jumps"
      ></canvas>

      <div class="holo-title">
        <div class="holo-eyebrow">Fracture Atlas</div>
        <h1>Past the gate</h1>
        <p class="holo-sub">
          at K=1 the map stops being invertible — <b>the fold</b> · past it: interval, overlap, memory, chaos, capture · and
          a ring where <b>defects are born in integer jumps</b> · drag to orbit · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="holo-legend" id="frac-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>
        <button class="lg-row" data-g="gate">
          <span class="sw" style="--c:#ff5c7a"></span><b>The gate</b> · min f&prime; = 1&minus;K crosses zero exactly at K=1
          — the collapse of invertibility is the boundary (forced)
        </button>
        <button class="lg-row" data-g="interval">
          <span class="sw" style="--c:#9fd0ff"></span><b>The interval</b> · winding spread at the golden dial: {wBelow} below
          the gate → {wAbove} just past it — ×22
        </button>
        <button class="lg-row" data-g="chaos">
          <span class="sw" style="--c:#f5c542"></span><b>The chaos boundary</b> · max Lyapunov over the whole dial:
          {lyBelow} below the gate (finite-time zero) → {lyAbove} above — chaos only past K=1
        </button>
        <button class="lg-row" data-g="capture">
          <span class="sw" style="--c:#b79cff"></span><b>The capture</b> · the old golden route swallowed — first captor
          {firstCaptor.captor} (Fibonacci) at K={firstCaptor.K}, down the mediants to {lastCaptor.captor}
        </button>
        <button class="lg-row" data-g="overlap">
          <span class="sw" style="--c:#ff9db5"></span><b>The overlap</b> · at K={ov.K}, {ov.multiCount}/{
            ov.points.length
          } dial settings hold two coexisting states · up/down sweeps disagree at {hys.disagree}/61 (hysteresis)
        </button>
        <button class="lg-row" data-g="ring">
          <span class="sw" style="--c:#55e9d0"></span><b>The ring (generation)</b> · 64 oscillators · strong coupling: charge
          frozen ({ring.locked.slipCount} slips) · weak: {slips} slips, every change an integer jump
        </button>
      </div>

      <div class="holo-hud" id="frac-hud">
        <div class="hud-h">Past the gate · locked</div>
        <div class="hud-m"><span>the fold (forced)</span><b>min f&prime; = 1&minus;K &lt; 0 iff K &gt; 1</b></div>
        <div class="hud-m"><span>interval · below → K=1.05</span><b>{wBelow} → {wAbove} (×22)</b></div>
        <div class="hud-m">
          <span>max Lyapunov · below → above</span><b>{lyBelow} → <span class="ok-inline">{lyAbove}</span></b>
        </div>
        <div class="hud-m">
          <span>first captor of the golden route</span><b>{firstCaptor.captor} at K={firstCaptor.K}</b>
        </div>
        <div class="hud-m">
          <span>multi-stable dial settings</span><b>{ov.multiCount}/{ov.points.length} at K={ov.K}</b>
        </div>
        <div class="hud-m">
          <span>ring charge jumps · |ΔM| histogram</span><b>1×{hist['1']} · 2×{hist['2'] ?? 0} · frozen foil: 0</b>
        </div>
        <div class="hud-m"><span>state</span><b id="hud-state">ring running · charge +1</b></div>
        <div class="hud-src">
          source: fracture-snapshot.json · 2D/3D lift literature-typed · generation reading is interpretation, labeled
        </div>
      </div>

      <noscript><div class="holo-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .holo-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1018 0%, #08080f 70%, #04040a 100%);
    }
    #frac-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #frac-canvas:active {
      cursor: grabbing;
    }

    .holo-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 60%;
      pointer-events: none;
      z-index: 2;
    }
    .holo-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #ff5c7a;
      margin-bottom: 12px;
    }
    .holo-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.6vw, 2.9rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .holo-title h1 :global(b),
    .holo-sub :global(b) {
      color: #fff;
      font-weight: 600;
    }
    .holo-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .holo-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .holo-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(255, 92, 122, 0.22);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 9px;
      max-width: 345px;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
      margin-bottom: 2px;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .holo-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 320px;
    }
    .hud-h {
      color: #ff5c7a;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m :global(.ok-inline) {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .holo-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 760px) {
      .holo-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .holo-legend {
        top: auto;
        bottom: 260px;
        right: 16px;
        padding: 11px 12px;
        max-width: 76%;
      }
      .holo-hud {
        left: 16px;
        right: 16px;
        bottom: 16px;
        min-width: 0;
      }
    }
  </style>

  <script type="application/json" id="frac-snap" is:inline set:html={JSON.stringify(snapshot)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface Snap {
      gate: { K: number[]; minDeriv: number[] };
      interval: { K: number; min: number; max: number; width: number }[];
      chaos: { K: number; maxLyap: number }[];
      capture: { K: number; winding: number; captor: string | null }[];
      overlap: { K: number; points: { omega: number; states: number }[] };
      hysteresis: { omega: number[]; up: number[]; down: number[] };
      ring: {
        n: number;
        frameEvery: number;
        fractured: { charges: number[]; slips: { t: number; dM: number }[]; frames: number[][] };
      };
    }

    const snap: Snap = JSON.parse((document.getElementById('frac-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('frac-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.06;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(2.4, 1.6, 7.6);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.6;
    controls.maxDistance = 22;
    controls.target.set(0, 0, 0);
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.22;

    const world = new THREE.Group();
    scene.add(world);
    scene.add(new THREE.AmbientLight(0x3a3550, 1.0));
    const kl = new THREE.PointLight(0xffe0a0, 18, 30);
    kl.position.set(3, 4, 5);
    scene.add(kl);

    function line(pts: THREE.Vector3[], color: number, opacity: number) {
      return new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(pts),
        new THREE.LineBasicMaterial({ color, transparent: true, opacity })
      );
    }
    function dot(x: number, y: number, z: number, color: number, r = 0.04) {
      const d = new THREE.Mesh(new THREE.SphereGeometry(r, 10, 8), new THREE.MeshBasicMaterial({ color }));
      d.position.set(x, y, z);
      return d;
    }

    // shared K axis for the three left panels: K in [0.5, 1.5], the gate at K=1
    const KX0 = -4.3,
      KW = 3.4;
    const kx = (K: number) => KX0 + ((K - 0.5) / 1.0) * KW;

    // ── the gate: min f' = 1-K crossing zero at K=1 (forced) ──
    const gateGrp = new THREE.Group();
    world.add(gateGrp);
    const G_Y = 1.7,
      G_H = 0.9;
    gateGrp.add(
      line(
        snap.gate.K.map((K, i) => new THREE.Vector3(kx(K), G_Y + snap.gate.minDeriv[i] * G_H, 0)),
        0xff5c7a,
        0.95
      ),
      line([new THREE.Vector3(kx(0.5), G_Y, 0), new THREE.Vector3(kx(1.5), G_Y, 0)], 0x39415c, 0.7)
    );
    // the gate itself: a vertical line at K=1 spanning all three panels
    gateGrp.add(line([new THREE.Vector3(kx(1), -2.4, 0), new THREE.Vector3(kx(1), 2.7, 0)], 0xffffff, 0.35));
    gateGrp.add(dot(kx(1), G_Y, 0, 0xffffff, 0.05));

    // ── the interval: winding spread at the golden dial, opening past the gate ──
    const intGrp = new THREE.Group();
    world.add(intGrp);
    const I_Y = 0.1,
      I_H = 260; // width is tiny; scale up, stated as presentation
    for (const r of snap.interval) {
      intGrp.add(
        line([new THREE.Vector3(kx(r.K), I_Y, 0), new THREE.Vector3(kx(r.K), I_Y + r.width * I_H, 0)], 0x9fd0ff, 0.9),
        dot(kx(r.K), I_Y + r.width * I_H, 0, 0x9fd0ff, 0.03)
      );
    }
    intGrp.add(line([new THREE.Vector3(kx(0.75), I_Y, 0), new THREE.Vector3(kx(1.45), I_Y, 0)], 0x39415c, 0.7));

    // ── the chaos boundary: max Lyapunov over the dial vs K ──
    const chGrp = new THREE.Group();
    world.add(chGrp);
    const C_Y = -1.5,
      C_H = 2.2;
    chGrp.add(
      line(
        snap.chaos.map((r) => new THREE.Vector3(kx(r.K), C_Y + r.maxLyap * C_H, 0)),
        0xf5c542,
        0.95
      ),
      line([new THREE.Vector3(kx(0.5), C_Y, 0), new THREE.Vector3(kx(1.5), C_Y, 0)], 0x39415c, 0.7)
    );
    for (const r of snap.chaos)
      chGrp.add(dot(kx(r.K), C_Y + r.maxLyap * C_H, 0, r.maxLyap > 0.01 ? 0xff5c7a : 0xf5c542, 0.035));

    // ── the capture: the old golden route swallowed, K=1 → 1.45 ──
    const capGrp = new THREE.Group();
    world.add(capGrp);
    const CP_X0 = -0.2,
      CP_W = 3.2,
      CP_Y = 1.1,
      CP_H = 14; // winding 0.615..0.67 → scaled
    const cpx = (K: number) => CP_X0 + ((K - 1.0) / 0.45) * CP_W;
    const cpy = (w: number) => CP_Y + (w - 0.615) * CP_H;
    capGrp.add(
      line(
        snap.capture.map((c) => new THREE.Vector3(cpx(c.K), cpy(c.winding), 0)),
        0xb79cff,
        0.9
      )
    );
    let lastCap = '';
    for (const c of snap.capture) {
      if (c.captor && c.captor !== lastCap) {
        lastCap = c.captor;
        capGrp.add(dot(cpx(c.K), cpy(c.winding), 0, 0xff9db5, 0.05));
      }
    }
    capGrp.add(dot(cpx(1.0), cpy(0.618048), 0, 0xffc46b, 0.055)); // the thread's last point, at the gate

    // ── the overlap + hysteresis: multi-stability band and the two sweeps ──
    const ovGrp = new THREE.Group();
    world.add(ovGrp);
    const OV_X0 = -0.2,
      OV_W = 3.2,
      OV_Y = -0.6;
    for (const p of snap.overlap.points) {
      if (p.states > 1) {
        const x = OV_X0 + ((p.omega - 0.25) / 0.2) * OV_W;
        ovGrp.add(dot(x, OV_Y, 0, 0xff9db5, 0.022));
      }
    }
    ovGrp.add(line([new THREE.Vector3(OV_X0, OV_Y, 0), new THREE.Vector3(OV_X0 + OV_W, OV_Y, 0)], 0x39415c, 0.7));
    const HY_Y = -1.9,
      HY_H = 2.4;
    const hyx = (om: number) => OV_X0 + ((om - 0.3) / 0.4) * OV_W;
    ovGrp.add(
      line(
        snap.hysteresis.omega.map((om, i) => new THREE.Vector3(hyx(om), HY_Y + snap.hysteresis.up[i] * HY_H, 0)),
        0x9fd0ff,
        0.8
      ),
      line(
        snap.hysteresis.omega.map((om, i) => new THREE.Vector3(hyx(om), HY_Y + snap.hysteresis.down[i] * HY_H, 0)),
        0xff9db5,
        0.8
      )
    );

    // ── the ring: generation — charge changes only in integer jumps ──
    const ringGrp = new THREE.Group();
    world.add(ringGrp);
    const R_CX = 2.1,
      R_CY = 0.2,
      R_CZ = -1.6,
      R_R = 1.35;
    const N = snap.ring.n;
    const ringDots: THREE.Mesh[] = [];
    for (let i = 0; i < N; i++) {
      const a = (i / N) * Math.PI * 2;
      const d = new THREE.Mesh(
        new THREE.SphereGeometry(0.045, 10, 8),
        new THREE.MeshBasicMaterial({ color: 0x55e9d0 })
      );
      d.position.set(R_CX + Math.cos(a) * R_R, R_CY + Math.sin(a) * R_R, R_CZ);
      ringGrp.add(d);
      ringDots.push(d);
    }
    const chargeArc = new THREE.Mesh(
      new THREE.TorusGeometry(R_R + 0.16, 0.012, 8, 96),
      new THREE.MeshBasicMaterial({ color: 0x55e9d0, transparent: true, opacity: 0.3 })
    );
    chargeArc.position.set(R_CX, R_CY, R_CZ);
    ringGrp.add(chargeArc);

    const frames = snap.ring.fractured.frames;
    const charges = snap.ring.fractured.charges;
    const frameEvery = snap.ring.frameEvery;
    let framePos = 0;
    const hudState = document.getElementById('hud-state');
    const _c = new THREE.Color();
    function paintFrame(fi: number) {
      const fr = frames[fi];
      for (let i = 0; i < N; i++) {
        _c.setHSL(fr[i], 0.75, 0.55);
        (ringDots[i].material as THREE.MeshBasicMaterial).color.copy(_c);
        const a = (i / N) * Math.PI * 2;
        const lift = Math.sin(fr[i] * Math.PI * 2) * 0.14;
        ringDots[i].position.set(R_CX + Math.cos(a) * (R_R + lift), R_CY + Math.sin(a) * (R_R + lift), R_CZ);
      }
      const t = fi * frameEvery;
      const m = charges[Math.min(t, charges.length - 1)];
      const slipped = t > 0 && charges[Math.min(t, charges.length - 1)] !== charges[Math.max(0, t - frameEvery)];
      (chargeArc.material as THREE.MeshBasicMaterial).opacity = slipped ? 0.85 : 0.3;
      (chargeArc.material as THREE.MeshBasicMaterial).color.set(slipped ? 0xff5c7a : 0x55e9d0);
      if (hudState)
        hudState.textContent = slipped
          ? `SLIP · charge → ${m >= 0 ? '+' : ''}${m}`
          : `ring running · charge ${m >= 0 ? '+' : ''}${m}`;
    }
    paintFrame(0);

    // ── the selectable legend ──
    const registry: Record<string, THREE.Object3D[]> = {
      gate: [gateGrp],
      interval: [intGrp],
      chaos: [chGrp],
      capture: [capGrp],
      overlap: [ovGrp],
      ring: [ringGrp],
    };
    document.querySelectorAll<HTMLButtonElement>('#frac-legend .lg-row').forEach((row) => {
      const parts = registry[row.dataset.g || ''];
      if (parts && !parts[0].visible) row.classList.add('off');
      row.addEventListener('click', () => {
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    // ── post / resize / freeze / animate ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.42, 0.6, 0.32));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    let frozen = false;
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudState && frozen) hudState.textContent = 'FROZEN';
      }
    });

    const clock = new THREE.Clock();
    let frameAcc = 0;
    function frameLoop() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        frameAcc += dt * 18; // replay speed: ~18 stored frames/second
        if (frameAcc >= 1) {
          framePos = (framePos + Math.floor(frameAcc)) % frames.length;
          frameAcc -= Math.floor(frameAcc);
          paintFrame(framePos);
        }
      }
      controls.update();
      composer.render();
      requestAnimationFrame(frameLoop);
    }
    frameLoop();
  </script>
</Layout>
