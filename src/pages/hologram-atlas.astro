---
// ============================================================
// HOLOGRAPHIC ATLAS — the off-axis cross (the X).
//
// Stewart's correction: the two halves don't project straight out and record
// inline — they separate, angle toward each other, and cross in an X, reflecting
// off the central rotating knot, and THAT is what writes the hologram. He was
// right, and it is a known upgrade: Gabor INLINE (1948) → Leith–Upatnieks
// OFF-AXIS (1962). The X is the fix for the twin-image flaw the inline version
// carried. Demonstrated, not asserted: recovery correlation jumps from ~0.24
// (inline, twin-contaminated) to ~1.00 (off-axis) exactly at the Leith angle.
// The knot's rotation angle-multiplexes pages; the golden step packs the most
// (proposed, labeled). φ spaces the fan of X's — it does not tilt any single X.
//
// ONE SOURCE OF TRUTH, LOCKED: everything is read from
// `src/data/hologram-snapshot.json` (scripts/generate-hologram-snapshot.py).
// The renderer draws it; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import snapshot from '~/data/hologram-snapshot.json';

const metadata = {
  title: 'Holographic Atlas — the off-axis cross',
  description:
    'The two beams cross in an X, reflecting off the rotating knot; the crossing angle carries the twin image away from the real one — Leith–Upatnieks off-axis holography, with the twin-image separation measured as recovery correlation jumps from 0.24 to 1.00 at the Leith angle.',
};

const m = snapshot.meta;
const r = snapshot.recovery;
const t = snapshot.twin;
const mx = snapshot.multiplex;
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="holo-stage">
      <canvas
        id="holo-canvas"
        aria-label="Rotatable 3D rendering of two beams crossing in an X at a rotating knot, the off-axis hologram they write, and the twin-image separation"
      ></canvas>

      <div class="holo-title">
        <div class="holo-eyebrow">Holographic Atlas</div>
        <h1>The off-axis cross</h1>
        <p class="holo-sub">
          the two beams split to the sides, face each other, and fold off the rotating knot into the <b>X</b> · the crossing
          angle carries the twin image away · drag to orbit · scroll to zoom · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="holo-legend" id="holo-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>
        <button class="lg-row" data-g="knot">
          <span class="sw" style="--c:#ffd28f"></span><b>The knot</b> · the rotating reflector the beams cross off — it takes
          the recoil, so the two arms can point toward each other
        </button>
        <button class="lg-row" data-g="arms">
          <span class="sw" style="--c:#ff5cc8"></span><b>The X</b> · the arms split wide, face each other, and fold at the
          knot — crossing at {m.crossingAngleDeg}°, carrier f_c = {m.carrier}, fringe {m.fringePeriod}λ
        </button>
        <button class="lg-row" data-g="plate">
          <span class="sw" style="--c:#55e9d0"></span><b>The plate</b> · the recorded off-axis fringes — the hologram itself,
          tilted by the crossing angle, computed not painted
        </button>
        <button class="lg-row" data-g="spectrum">
          <span class="sw" style="--c:#9fd0ff"></span><b>The three bands</b> · inline: real, twin & zero-order piled together
          · off-axis: the twin carried out to −f_c, separated
        </button>
        <button class="lg-row" data-g="recovery">
          <span class="sw" style="--c:#f5c542"></span><b>The proof</b> · recovery correlation vs crossing angle — jumps
          {r.inlineCorr} → {r.offaxisCorr} at the Leith angle {r.leithAngleDeg}°
        </button>
        <button class="lg-row" data-g="multiplex">
          <span class="sw" style="--c:#b79cff"></span><b>Golden multiplex (proposed)</b> · the knot's rotation writes pages
          — golden step keeps {mx.distinctGolden}/{mx.pages} distinct, the rational control only {mx.distinctUniform}
        </button>
      </div>

      <div class="holo-hud" id="holo-hud">
        <div class="hud-h">Off-axis hologram · locked</div>
        <div class="hud-m"><span>crossing angle (the X)</span><b>{m.crossingAngleDeg}°</b></div>
        <div class="hud-m"><span>carrier f_c · fringe</span><b>{m.carrier} · {m.fringePeriod}λ</b></div>
        <div class="hud-m"><span>Leith threshold angle</span><b>{r.leithAngleDeg}°</b></div>
        <div class="hud-m"><span>recovery · inline (twin ghost)</span><b>{r.inlineCorr}</b></div>
        <div class="hud-m"><span>recovery · off-axis (twin gone)</span><b class="ok">{r.offaxisCorr}</b></div>
        <div class="hud-m"><span>twin separation · 2·f_c</span><b>{t.separationCarrier} (0 inline)</b></div>
        <div class="hud-m"><span>state</span><b id="hud-state">knot turning · writing pages</b></div>
        <div class="hud-src">
          source: hologram-snapshot.json · Leith–Upatnieks off-axis · multiplex proposed, labeled
        </div>
      </div>

      <noscript><div class="holo-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .holo-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1018 0%, #08080f 70%, #04040a 100%);
    }
    #holo-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #holo-canvas:active {
      cursor: grabbing;
    }

    .holo-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 60%;
      pointer-events: none;
      z-index: 2;
    }
    .holo-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #ffc46b;
      margin-bottom: 12px;
    }
    .holo-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.6vw, 2.9rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .holo-title h1 :global(b),
    .holo-sub :global(b) {
      color: #fff;
      font-weight: 600;
    }
    .holo-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .holo-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .holo-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(255, 196, 107, 0.2);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 9px;
      max-width: 345px;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
      margin-bottom: 2px;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .holo-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 320px;
    }
    .hud-h {
      color: #ffc46b;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m b.ok {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .holo-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 760px) {
      .holo-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .holo-legend {
        top: auto;
        bottom: 260px;
        right: 16px;
        padding: 11px 12px;
        max-width: 76%;
      }
      .holo-hud {
        left: 16px;
        right: 16px;
        bottom: 16px;
        min-width: 0;
      }
    }
  </style>

  <script type="application/json" id="holo-snap" set:html={JSON.stringify(snapshot)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface Snap {
      meta: { crossingAngleDeg: number; carrier: number; fringePeriod: number };
      geometry: { armAngleDeg: number; crossingAngleDeg: number };
      recording: { n: number; extent: number; image: number[][] };
      spectrum: { f: number[]; inline: number[]; offaxis: number[]; carrier: number };
      recovery: {
        angleDeg: number[];
        corr: number[];
        leithAngleDeg: number;
        workingAngleDeg: number;
        offaxisCorr: number;
      };
      multiplex: { goldenDirs: number[]; uniformDirs: number[] };
    }

    const snap: Snap = JSON.parse((document.getElementById('holo-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('holo-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.06;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(3.6, 2.0, 6.2);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.6;
    controls.maxDistance = 22;
    controls.target.set(0, 0, 0.6);
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.28;

    const world = new THREE.Group();
    scene.add(world);

    // ── the knot: the rotating reflector at the crossing ──
    const knotGrp = new THREE.Group();
    world.add(knotGrp);
    const knot = new THREE.Mesh(
      new THREE.TorusKnotGeometry(0.19, 0.058, 128, 16, 2, 3),
      new THREE.MeshStandardMaterial({ color: 0xffd28f, emissive: 0x6a4a12, roughness: 0.35, metalness: 0.6 })
    );
    knotGrp.add(knot);
    scene.add(new THREE.AmbientLight(0x3a3550, 1.0));
    const kl = new THREE.PointLight(0xffe0a0, 22, 30);
    kl.position.set(3, 4, 4);
    scene.add(kl);

    // ── the X: two arms folding off the knot ──
    // Stewart's geometry correction #2: the arms don't hide behind the knot
    // nearly parallel — they SPLIT OUT TO THE SIDES and point toward each other,
    // two lights facing each other across the axis, exactly like a real
    // Leith–Upatnieks table (beamsplitter → wide arms → mirrors fold them back
    // inward). Each arm folds AT the knot (the reflector) into the narrow X that
    // lands on the plate. Both legs still arrive on the same side of the plate —
    // the transmission requirement. (Fully face-to-face THROUGH the plate would
    // be Denisyuk reflection holography — real, but a different geometry than
    // the one this snapshot measures.)
    const armsGrp = new THREE.Group();
    world.add(armsGrp);
    // The true crossing angle is 4° (nearly parallel), so the X is drawn at an
    // exaggerated display angle for legibility — a presentation choice; the real
    // angle, carrier, and fringe live in the data/HUD.
    const alpha = 0.36; // ≈20° display; physical armAngleDeg is in the snapshot
    const INFACE = 1.15; // ≈66° — the incoming legs, split wide, facing each other
    const ARM = 3.0;
    const PLATE_Z = 2.2;
    function beam(sign: number, color: number) {
      // leg 1: from a source out at the side, aimed inward at the knot —
      // the two sources face each other across the axis. leg 2: folded at the
      // knot (which takes the recoil), continuing as the narrow X to the plate.
      const inDir = new THREE.Vector3(Math.sin(sign * INFACE), 0, Math.cos(INFACE));
      const src = inDir.clone().multiplyScalar(-ARM * 0.85);
      const outDir = new THREE.Vector3(Math.sin(sign * alpha), 0, Math.cos(alpha));
      const tip = outDir.clone().multiplyScalar(ARM);
      const g = new THREE.Group();
      g.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([src, new THREE.Vector3(0, 0, 0), tip]),
          new THREE.LineBasicMaterial({ color, transparent: true, opacity: 0.55 })
        )
      );
      const em = new THREE.Mesh(new THREE.SphereGeometry(0.08, 18, 12), new THREE.MeshBasicMaterial({ color }));
      em.position.copy(src);
      g.add(em);
      armsGrp.add(g);
      return g;
    }
    beam(-1, 0xff5cc8); // object arm — fixed
    const refArm = beam(1, 0x6ea8ff); // reference arm — the knot steers this one around

    // ── the plate: the recorded off-axis fringes ──
    const plateGrp = new THREE.Group();
    world.add(plateGrp);
    const ni = snap.recording.n;
    const tex = new Uint8Array(ni * ni * 4);
    for (let j = 0; j < ni; j++) {
      for (let i = 0; i < ni; i++) {
        const v = snap.recording.image[j][i];
        const o = (j * ni + i) * 4;
        tex[o] = Math.round(v * 0.32);
        tex[o + 1] = Math.round(v * 0.92);
        tex[o + 2] = Math.round(v * 0.82);
        tex[o + 3] = 255;
      }
    }
    const plateTex = new THREE.DataTexture(tex, ni, ni, THREE.RGBAFormat);
    plateTex.center.set(0.5, 0.5); // rotate the fringes about their center as pages are written
    plateTex.needsUpdate = true;
    const plate = new THREE.Mesh(
      new THREE.PlaneGeometry(2.6, 2.6),
      new THREE.MeshBasicMaterial({
        map: plateTex,
        transparent: true,
        opacity: 0.85,
        blending: THREE.AdditiveBlending,
        side: THREE.DoubleSide,
        depthWrite: false,
      })
    );
    plate.position.set(0, 0, PLATE_Z);
    plateGrp.add(plate);
    plateGrp.add(
      new THREE.LineSegments(
        new THREE.EdgesGeometry(new THREE.PlaneGeometry(2.6, 2.6)),
        new THREE.LineBasicMaterial({ color: 0x55e9d0, transparent: true, opacity: 0.35 })
      ).translateZ(PLATE_Z)
    );

    // ── the three bands: the spectrum panel (inline overlap vs off-axis split) ──
    const specGrp = new THREE.Group();
    world.add(specGrp);
    const SP_Z = -2.3,
      SP_W = 3.6,
      SP_H = 1.5,
      SP_Y = 0.7,
      SP_CX = -0.4;
    const fArr = snap.spectrum.f;
    const fMin = fArr[0],
      fMax = fArr[fArr.length - 1];
    const spx = (fv: number) => SP_CX + (-SP_W / 2 + (SP_W * (fv - fMin)) / (fMax - fMin));
    const spy = (a: number) => SP_Y + a * SP_H;
    function smooth(arr: number[], w: number) {
      // display-only envelope so the three bands read cleanly (data is exact)
      const out = arr.slice();
      for (let i = 0; i < arr.length; i++) {
        let s = 0,
          n = 0;
        for (let j = -w; j <= w; j++) {
          const k = i + j;
          if (k >= 0 && k < arr.length) {
            s += arr[k];
            n++;
          }
        }
        out[i] = s / n;
      }
      return out;
    }
    function specLine(arr: number[], color: number, opacity: number) {
      const sm = smooth(arr, 2);
      specGrp.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(sm.map((a, i) => new THREE.Vector3(spx(fArr[i]), spy(a), SP_Z))),
          new THREE.LineBasicMaterial({ color, transparent: true, opacity })
        )
      );
    }
    specLine(snap.spectrum.inline, 0x7b6cff, 0.55); // inline: piled at center
    specLine(snap.spectrum.offaxis, 0x9fd0ff, 0.95); // off-axis: three separated bands
    // carrier markers ±f_c
    for (const s of [-1, 1]) {
      specGrp.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([
            new THREE.Vector3(spx(s * snap.spectrum.carrier), spy(0), SP_Z),
            new THREE.Vector3(spx(s * snap.spectrum.carrier), spy(1.05), SP_Z),
          ]),
          new THREE.LineBasicMaterial({ color: 0xff5c7a, transparent: true, opacity: 0.4 })
        )
      );
    }

    // ── the proof: recovery correlation vs crossing angle ──
    const recGrp = new THREE.Group();
    world.add(recGrp);
    const RC_X = 2.7,
      RC_W = 2.1,
      RC_H = 1.8,
      RC_Y = -2.1;
    const aMax = snap.recovery.angleDeg[snap.recovery.angleDeg.length - 1];
    const rx = (a: number) => RC_X + (RC_W * a) / aMax;
    const ry = (cc: number) => RC_Y + cc * RC_H;
    recGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          snap.recovery.angleDeg.map((a, i) => new THREE.Vector3(rx(a), ry(snap.recovery.corr[i]), 0))
        ),
        new THREE.LineBasicMaterial({ color: 0xf5c542, transparent: true, opacity: 0.95 })
      )
    );
    // baseline + Leith threshold marker
    recGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(rx(0), ry(0), 0),
          new THREE.Vector3(rx(aMax), ry(0), 0),
        ]),
        new THREE.LineBasicMaterial({ color: 0x39415c, transparent: true, opacity: 0.7 })
      )
    );
    recGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(rx(snap.recovery.leithAngleDeg), ry(0), 0),
          new THREE.Vector3(rx(snap.recovery.leithAngleDeg), ry(1.05), 0),
        ]),
        new THREE.LineBasicMaterial({ color: 0xff5c7a, transparent: true, opacity: 0.5 })
      )
    );
    const workDot = new THREE.Mesh(
      new THREE.SphereGeometry(0.05, 12, 10),
      new THREE.MeshBasicMaterial({ color: 0x55e9d0 })
    );
    workDot.position.set(rx(snap.recovery.workingAngleDeg), ry(snap.recovery.offaxisCorr), 0);
    recGrp.add(workDot);

    // ── the golden multiplex: the knot's page angles (proposed) ──
    const mxGrp = new THREE.Group();
    world.add(mxGrp);
    const RING = 0.62;
    function ringDots(dirs: number[], radius: number, color: number, size: number) {
      const dots: THREE.Mesh[] = [];
      const seen = new Set<number>();
      for (const a of dirs) {
        const key = Math.round(a * 1000);
        const fresh = !seen.has(key);
        seen.add(key);
        const dot = new THREE.Mesh(
          new THREE.SphereGeometry(size, 8, 6),
          new THREE.MeshBasicMaterial({ color, transparent: true, opacity: fresh ? 0.55 : 0.55 })
        );
        dot.position.set(Math.cos(a) * radius, Math.sin(a) * radius, 0);
        mxGrp.add(dot);
        dots.push(dot);
      }
      return dots;
    }
    const goldenDots = ringDots(snap.multiplex.goldenDirs, RING, 0xb79cff, 0.02); // golden: all distinct
    ringDots(snap.multiplex.uniformDirs, RING + 0.16, 0xff5c7a, 0.03); // rational: collapses to a few
    mxGrp.visible = false; // proposed layer starts off; its legend row reflects that

    // ── the selectable legend ──
    const registry: Record<string, THREE.Object3D[]> = {
      knot: [knotGrp],
      arms: [armsGrp],
      plate: [plateGrp],
      spectrum: [specGrp],
      recovery: [recGrp],
      multiplex: [mxGrp],
    };
    document.querySelectorAll<HTMLButtonElement>('#holo-legend .lg-row').forEach((row) => {
      const parts = registry[row.dataset.g || ''];
      if (parts && !parts[0].visible) row.classList.add('off');
      row.addEventListener('click', () => {
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    // ── post / resize / freeze / animate ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.42, 0.6, 0.32));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    let frozen = false;
    const hudState = document.getElementById('hud-state');

    // ── the mechanism: the knot's turn IS the read/write head ──
    // Each turn of the knot addresses the next page — the reference arm steps
    // forward by the golden angle (137.5°) and the plate's fringes re-orient with
    // it. Golden-stepped so each new page lands in the widest gap left by all the
    // pages before it: the knot's rotation literally does something to the
    // hologram, and it addresses the most pages without two ever colliding.
    const PHI = (1 + Math.sqrt(5)) / 2;
    const GOLDEN = 2 * Math.PI * (1 - 1 / PHI); // 137.5° — the step between pages
    const PAGES = snap.multiplex.goldenDirs.length;
    const PAGE_DT = 0.75; // seconds the knot takes to write one page
    let pageCount = 0;
    let pageTimer = 0;
    let armAz = 0; // eased reference-arm azimuth, unwrapped (keeps stepping forward)

    function showPage() {
      const idx = ((pageCount % PAGES) + PAGES) % PAGES;
      for (let i = 0; i < goldenDots.length; i++) {
        const active = i === idx;
        goldenDots[i].scale.setScalar(active ? 2.6 : 1);
        (goldenDots[i].material as THREE.MeshBasicMaterial).opacity = active ? 1 : 0.5;
      }
      if (hudState && !frozen) hudState.textContent = `page ${idx + 1}/${PAGES} · +137.5° · no collision`;
    }
    showPage();

    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudState) hudState.textContent = frozen ? 'FROZEN' : `page ${(pageCount % PAGES) + 1}/${PAGES} · writing`;
      }
    });

    const clock = new THREE.Clock();
    function frameLoop() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        const t = clock.elapsedTime;
        knot.rotation.y += dt * 0.6; // the knot turns — this is what drives the head
        knot.rotation.x = Math.sin(t * 0.3) * 0.3;

        // the knot writes a new page every PAGE_DT: step forward one golden angle
        pageTimer += dt;
        if (pageTimer >= PAGE_DT) {
          pageTimer -= PAGE_DT;
          pageCount++;
          showPage();
        }
        // the reference arm swings around the optical axis to the new page's
        // golden azimuth; the plate's fringes re-orient the same amount
        const targetAz = pageCount * GOLDEN;
        armAz += (targetAz - armAz) * Math.min(1, dt * 3.2); // ease toward the page
        refArm.rotation.z = armAz;
        plateTex.rotation = armAz;
        workDot.scale.setScalar(1 + 0.16 * Math.sin(t * 1.6));
      }
      controls.update();
      composer.render();
      requestAnimationFrame(frameLoop);
    }
    frameLoop();
  </script>
</Layout>
