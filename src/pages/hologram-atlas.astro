---
// ============================================================
// HOLOGRAPHIC ATLAS — the cross-section, proven.
//
// Two phase-locked emitters, trapped circling one another, projecting
// outward — and the cross-section of their joint field is a hologram.
// Not an illustration: the fringes shown are the exact computed
// interference intensity, and the reconstruction plane shows the proof —
// illuminate the recorded slice with EITHER partner's wave, run the wave
// backward, and the OTHER partner reappears at its true position (error
// stored in wavelengths). The phase lock is the coherence condition:
// without it, no fringes, nothing to reconstruct.
//
// ONE SOURCE OF TRUTH, LOCKED: everything is read from
// `src/data/hologram-snapshot.json` (scripts/generate-hologram-snapshot.py).
// The renderer draws it; it re-derives nothing.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import snapshot from '~/data/hologram-snapshot.json';

const metadata = {
  title: 'Holographic Atlas — the cross-section, proven',
  description:
    'Two phase-locked emitters, trapped circling one another; the cross-section of their joint field is a hologram — demonstrated by reconstruction: the recorded slice plus either partner recovers the other at its true position, to a tenth of a wavelength.',
};

const m = snapshot.meta;
const c = snapshot.checks;
const gs = snapshot.goldenSpray;
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="holo-stage">
      <canvas
        id="holo-canvas"
        aria-label="Rotatable 3D rendering of two phase-locked emitters, their interference cross-section, and its holographic reconstruction"
      ></canvas>

      <div class="holo-title">
        <div class="holo-eyebrow">Holographic Atlas</div>
        <h1>The cross-section is a hologram</h1>
        <p class="holo-sub">
          two bound emitters, phase-locked · the slice records their joint field · keep the slice and either partner —
          the other reappears · drag to orbit · scroll to zoom · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="holo-legend" id="holo-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>
        <button class="lg-row" data-g="pair">
          <span class="sw" style="--c:#ff5cc8"></span><b>The bound pair</b> · separation {m.separation}λ · phase-locked
          — the coherence holography requires
        </button>
        <button class="lg-row" data-g="waves">
          <span class="sw" style="--c:#9fd0ff"></span><b>Wavefronts</b> · both inners projected out, in step
        </button>
        <button class="lg-row" data-g="holo">
          <span class="sw" style="--c:#55e9d0"></span><b>The cross-section</b> · exact interference intensity at {
            m.planeZ
          }λ — the hologram itself, fringes computed not painted
        </button>
        <button class="lg-row" data-g="recon">
          <span class="sw" style="--c:#ffc46b"></span><b>Reconstruction</b> · the slice illuminated with one partner's wave,
          run backward — the other partner reappears
        </button>
        <button class="lg-row" data-g="proof">
          <span class="sw" style="--c:#f5c542"></span><b>Proof marks</b> · recovered peak ringed at ({
            c.recoveredPartner[0]
          },
          {c.recoveredPartner[1]})λ vs truth ({c.recoveredTruth[0]}, {c.recoveredTruth[1]})λ — error {
            c.recoveredErrorLambda
          }λ
        </button>
        <button class="lg-row" data-g="spray">
          <span class="sw" style="--c:#b79cff"></span><b>Golden spray (proposed)</b> · repeated emission at the golden angle
          never self-overlaps — max gap {gs.maxGapGoldenDeg}° after {gs.emissions} shots vs {gs.maxGapRationalDeg}°
          forever for the rational control
        </button>
      </div>

      <div class="holo-hud" id="holo-hud">
        <div class="hud-h">Holographic Atlas · locked</div>
        <div class="hud-m"><span>pair separation · plane</span><b>{m.separation}λ · z = {m.planeZ}λ</b></div>
        <div class="hud-m"><span>coherence</span><b class="ok">phase-locked</b></div>
        <div class="hud-m">
          <span>fringe period · paraxial / measured</span><b>{c.fringePeriodPredicted} / {c.fringePeriodMeasured} λ</b>
        </div>
        <div class="hud-m">
          <span>recovered partner</span><b>({c.recoveredPartner[0]}, {c.recoveredPartner[1]}) λ</b>
        </div>
        <div class="hud-m"><span>truth</span><b>({c.recoveredTruth[0]}, {c.recoveredTruth[1]}) λ</b></div>
        <div class="hud-m"><span>recovery error</span><b>{c.recoveredErrorLambda} λ</b></div>
        <div class="hud-m">
          <span>golden spray gap · rational control</span><b>{gs.maxGapGoldenDeg}° · {gs.maxGapRationalDeg}°</b>
        </div>
        <div class="hud-m"><span>state</span><b id="hud-state">projecting · locked</b></div>
        <div class="hud-src">
          source: hologram-snapshot.json · twin-image halo visible, stated · spray layer proposed
        </div>
      </div>

      <noscript><div class="holo-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .holo-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #0f1018 0%, #08080f 70%, #04040a 100%);
    }
    #holo-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #holo-canvas:active {
      cursor: grabbing;
    }

    .holo-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 60%;
      pointer-events: none;
      z-index: 2;
    }
    .holo-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #ffc46b;
      margin-bottom: 12px;
    }
    .holo-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.6vw, 2.9rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .holo-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .holo-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .holo-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(255, 196, 107, 0.2);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 9px;
      max-width: 340px;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
      margin-bottom: 2px;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .holo-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(14, 13, 20, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 300px;
    }
    .hud-h {
      color: #ffc46b;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-m b.ok {
      color: #55e9d0;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .holo-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 760px) {
      .holo-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .holo-legend {
        top: auto;
        bottom: 260px;
        right: 16px;
        padding: 11px 12px;
        max-width: 76%;
      }
      .holo-hud {
        left: 16px;
        right: 16px;
        bottom: 16px;
        min-width: 0;
      }
    }
  </style>

  <script type="application/json" id="holo-snap" set:html={JSON.stringify(snapshot)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface Snap {
      meta: { separation: number; planeZ: number; planeSize: number };
      checks: {
        recoveredPartner: number[];
        recoveredTruth: number[];
        keyRefocus: number[];
        keyTruth: number[];
      };
      sources: { positions: number[][]; phaseLocked: boolean };
      hologram: { n: number; extent: number; z: number; intensity: number[][] };
      reconstruction: { n: number; extent: number; z: number; intensity: number[][] };
      goldenSpray: { emissions: number; goldenDirs: number[]; rationalDirs: number[] };
    }

    const snap: Snap = JSON.parse((document.getElementById('holo-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('holo-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // scene scale: 0.05 units per wavelength (a drawing decision)
    const S = 0.05;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(4.6, 2.8, 7.6);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.2;
    controls.maxDistance = 22;
    controls.target.set(0, 0, 1.4);
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.3;

    const world = new THREE.Group();
    scene.add(world);

    // ── intensity grid → additive-blended texture (colormapped in JS) ──
    function planeTexture(grid: number[][], tint: [number, number, number]) {
      const n = grid.length;
      const data = new Uint8Array(n * n * 4);
      for (let j = 0; j < n; j++) {
        for (let i = 0; i < n; i++) {
          const v = grid[j][i];
          const o = (j * n + i) * 4;
          data[o] = Math.round(v * tint[0]);
          data[o + 1] = Math.round(v * tint[1]);
          data[o + 2] = Math.round(v * tint[2]);
          data[o + 3] = 255;
        }
      }
      const tex = new THREE.DataTexture(data, n, n, THREE.RGBAFormat);
      tex.needsUpdate = true;
      return tex;
    }
    const planeGeo = new THREE.PlaneGeometry(snap.hologram.extent * S, snap.hologram.extent * S);

    // ── the bound pair ──
    const pairGrp = new THREE.Group();
    world.add(pairGrp);
    const srcMeshes = snap.sources.positions.map((p) => {
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(0.06, 20, 14),
        new THREE.MeshBasicMaterial({ color: 0xff5cc8 })
      );
      mesh.position.set(p[0] * S, p[1] * S, p[2] * S);
      pairGrp.add(mesh);
      return mesh;
    });
    // the mutual orbit they are trapped on, and the bond through the center
    const orbitPts: THREE.Vector3[] = [];
    const orbR = (snap.meta.separation / 2) * S;
    for (let i = 0; i <= 96; i++) {
      const a = (i / 96) * Math.PI * 2;
      orbitPts.push(new THREE.Vector3(Math.cos(a) * orbR, Math.sin(a) * orbR, 0));
    }
    pairGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(orbitPts),
        new THREE.LineBasicMaterial({ color: 0xff5cc8, transparent: true, opacity: 0.3 })
      )
    );
    pairGrp.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-orbR, 0, 0), new THREE.Vector3(orbR, 0, 0)]),
        new THREE.LineBasicMaterial({ color: 0xffc46b, transparent: true, opacity: 0.5 })
      )
    );

    // ── wavefronts: both inners projected out, in step (phase-locked) ──
    const wavesGrp = new THREE.Group();
    world.add(wavesGrp);
    const WAVE_SHELLS = 4;
    const waveMeshes: { mesh: THREE.Mesh; k: number; src: number }[] = [];
    for (let s = 0; s < 2; s++) {
      for (let k = 0; k < WAVE_SHELLS; k++) {
        const mesh = new THREE.Mesh(
          new THREE.SphereGeometry(1, 24, 16),
          new THREE.MeshBasicMaterial({
            color: 0x9fd0ff,
            transparent: true,
            opacity: 0.05,
            side: THREE.DoubleSide,
            depthWrite: false,
          })
        );
        mesh.position.copy(srcMeshes[s].position);
        wavesGrp.add(mesh);
        waveMeshes.push({ mesh, k, src: s });
      }
    }

    // ── the cross-section: the hologram plane, exact computed fringes ──
    const holoGrp = new THREE.Group();
    world.add(holoGrp);
    const holoPlane = new THREE.Mesh(
      planeGeo,
      new THREE.MeshBasicMaterial({
        map: planeTexture(snap.hologram.intensity, [0.16, 0.5, 0.45]),
        transparent: true,
        opacity: 0.75,
        side: THREE.DoubleSide,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      })
    );
    holoPlane.position.set(0, 0, snap.hologram.z * S);
    holoGrp.add(holoPlane);
    // frame
    const frame = new THREE.LineSegments(
      new THREE.EdgesGeometry(planeGeo),
      new THREE.LineBasicMaterial({ color: 0x55e9d0, transparent: true, opacity: 0.35 })
    );
    frame.position.copy(holoPlane.position);
    holoGrp.add(frame);

    // ── the reconstruction: slice + one partner, run backward ──
    const reconGrp = new THREE.Group();
    world.add(reconGrp);
    const reconPlane = new THREE.Mesh(
      planeGeo,
      new THREE.MeshBasicMaterial({
        map: planeTexture(snap.reconstruction.intensity, [1.0, 0.72, 0.35]),
        transparent: true,
        opacity: 0.95,
        side: THREE.DoubleSide,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      })
    );
    reconPlane.position.set(0, 0, -0.02);
    reconGrp.add(reconPlane);
    const rFrame = new THREE.LineSegments(
      new THREE.EdgesGeometry(planeGeo),
      new THREE.LineBasicMaterial({ color: 0xffc46b, transparent: true, opacity: 0.3 })
    );
    rFrame.position.copy(reconPlane.position);
    reconGrp.add(rFrame);

    // ── proof marks: rings where the reconstruction peaked, at the sources ──
    // (texture v runs bottom-to-top, so the plane's y is the grid's -y; the
    // recovered peaks are ringed at their measured positions)
    const proofGrp = new THREE.Group();
    world.add(proofGrp);
    function proofRing(px: number, py: number, color: number) {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(0.12, 0.008, 8, 48),
        new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.9 })
      );
      ring.position.set(px * S, -py * S, 0);
      proofGrp.add(ring);
      return ring;
    }
    const recRing = proofRing(snap.checks.recoveredPartner[0], snap.checks.recoveredPartner[1], 0xf5c542);
    proofRing(snap.checks.keyRefocus[0], snap.checks.keyRefocus[1], 0x8a93ad);

    // ── golden spray (proposed): repeated emission directions on a ring ──
    const sprayGrp = new THREE.Group();
    world.add(sprayGrp);
    const SPRAY_R = 1.55;
    for (const a of snap.goldenSpray.goldenDirs) {
      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(0.014, 8, 6),
        new THREE.MeshBasicMaterial({ color: 0xb79cff, transparent: true, opacity: 0.85 })
      );
      dot.position.set(Math.cos(a) * SPRAY_R, Math.sin(a) * SPRAY_R, 0);
      sprayGrp.add(dot);
    }
    for (const a of snap.goldenSpray.rationalDirs) {
      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(0.02, 8, 6),
        new THREE.MeshBasicMaterial({ color: 0xff5c7a, transparent: true, opacity: 0.6 })
      );
      dot.position.set(Math.cos(a) * (SPRAY_R + 0.14), Math.sin(a) * (SPRAY_R + 0.14), 0);
      sprayGrp.add(dot);
    }
    sprayGrp.visible = false; // proposed layer starts off; its legend row reflects that

    // ── the selectable legend ──
    const registry: Record<string, THREE.Object3D[]> = {
      pair: [pairGrp],
      waves: [wavesGrp],
      holo: [holoGrp],
      recon: [reconGrp],
      proof: [proofGrp],
      spray: [sprayGrp],
    };
    document.querySelectorAll<HTMLButtonElement>('#holo-legend .lg-row').forEach((row) => {
      const parts = registry[row.dataset.g || ''];
      if (parts && !parts[0].visible) row.classList.add('off');
      row.addEventListener('click', () => {
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    // ── post / resize / freeze / animate ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.32, 0.6, 0.35));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize);

    let frozen = false;
    const hudState = document.getElementById('hud-state');
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudState) hudState.textContent = frozen ? 'FROZEN' : 'projecting · locked';
      }
    });

    const clock = new THREE.Clock();
    const WAVE_MAX = 2.6;
    function frame_() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        const t = clock.elapsedTime;
        // phase-locked projection: every shell leaves both sources at the
        // same moment and grows at the same rate — the lock made visible
        for (const w of waveMeshes) {
          const ph = (((t * 0.35 + w.k / WAVE_SHELLS) % 1) + 1) % 1;
          const r = 0.05 + ph * WAVE_MAX;
          w.mesh.scale.setScalar(r);
          (w.mesh.material as THREE.MeshBasicMaterial).opacity = 0.06 * (1 - ph) * (1 - ph);
        }
        const pulse = 1 + 0.15 * Math.sin(t * 1.6);
        recRing.scale.setScalar(pulse);
        void dt;
      }
      controls.update();
      composer.render();
      requestAnimationFrame(frame_);
    }
    frame_();
  </script>
</Layout>
