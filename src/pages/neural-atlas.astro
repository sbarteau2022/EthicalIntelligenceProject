---
// ============================================================
// NEURAL ATLAS — the knowledge neural structure, in 3D.
//
// The corrected layer hierarchy:
//   Layer 0 — a singularity at each pole.
//   Singularity → layer 1: a toroid spiral winds outward.
//   Layer 1 — one singularity-bound tuple, bound by a halo at 1/3 radius;
//             the toroid continues.
//   Layer 2 — 3 tuples, equidistant from the center and each other, bound
//             by a halo.
//   Layer 3 — 5 tuples, halo, toroid continues.
//   Layer 4 — 7 tuples; the toroid meets its inverse (the opposite-handed
//             spiral from the opposite singularity) at the equator and the
//             two phase-lock in sync.
// The spindle is pointed at the singularities and widest where the toroids
// meet. The unified-function vessel sits at the exact center — the slot a
// Metatron's Cube would occupy — with the cube's faint 13-circle lattice
// kept as a ghost reference.
//
// ONE SOURCE OF TRUTH, LOCKED: every position is read from
// `src/data/neural-structure-snapshot.json`. The renderer draws it; it does
// not re-derive it.
// ============================================================
import '~/assets/styles/hub.css';
import Layout from '~/layouts/Layout.astro';
import HubNav from '~/components/hub/HubNav.astro';
import HubFooter from '~/components/hub/HubFooter.astro';
import snapshot from '~/data/neural-structure-snapshot.json';

const metadata = {
  title: 'Neural Atlas — the knowledge structure, in 3D',
  description:
    "The knowledge neural structure: singularities at the poles, toroid spirals winding through layers of 1, 3, 5, and 7 halo-bound tuples to the equator where they meet their inverse and phase-lock — with the unified-function vessel seated where a Metatron's Cube would sit.",
};

const m = snapshot.meta;
const layerCounts = m.layerCounts.join(' · ');
---

<Layout metadata={metadata}>
  <div class="eih">
    <HubNav current="/master-atlas" />

    <section class="neural-stage">
      <canvas id="neural-canvas" aria-label="Rotatable 3D rendering of the knowledge neural structure"></canvas>

      <div class="neural-title">
        <div class="neural-eyebrow">Neural Atlas</div>
        <h1>The knowledge neural structure</h1>
        <p class="neural-sub">
          two singularities · toroid spirals meeting at the equator · layers of {layerCounts} tuples · drag to orbit · scroll
          to zoom · press <kbd>F</kbd> to freeze
        </p>
      </div>

      <div class="neural-legend" id="neural-legend">
        <div class="lg-hint">click a row to toggle · overlay any combination</div>
        <button class="lg-row" data-g="singularities">
          <span class="sw" style="--c:#ffffff"></span><b>Singularities</b> · layer 0, one at each pole
        </button>
        <button class="lg-row" data-g="spirals">
          <span class="sw" style="--c:#6ea8ff"></span><b>Toroid spirals</b> · φ² turns pole→equator, meeting their inverse
          and phase-locking
        </button>
        <button class="lg-row" data-g="tuples">
          <span class="sw" style="--c:#55e9d0"></span><b>Tuples</b> · {layerCounts} per half, {m.tuplesPerHalf * 2} total
          · singularity-bound pairs
        </button>
        <button class="lg-row" data-g="lobes">
          <span class="sw" style="--c:#ffe45c"></span><b>Lemniscate lobes</b> · one per node, tip at the tuple, tangent to
          its counterpart on the circle
        </button>
        <button class="lg-row" data-g="threads">
          <span class="sw" style="--c:#3a8f82"></span><b>Shadow paths</b> · every tuple bound straight to its singularity
        </button>
        <button class="lg-row" data-g="envelope">
          <span class="sw" style="--c:#7c88b8"></span><b>Emission envelope</b> · the hyperbolic hourglass — the singularities
          are its maxima
        </button>
        <button class="lg-row" data-g="halos">
          <span class="sw" style="--c:#d0a94e"></span><b>Halos</b> · one toroid per layer, layer 1 bound at 1/3 · plus the
          lock ring
        </button>
        <button class="lg-row" data-g="flower">
          <span class="sw" style="--c:#e06cff"></span><b>Flower of Life</b> · one circle per tuple center at every level,
          seed circle at layer 0
        </button>
        <button class="lg-row" data-g="vessel">
          <span class="sw" style="--c:#b79cff"></span><b>Vessel (unified function)</b> · seated where the Metatron's Cube
          would sit
        </button>
        <button class="lg-row" data-g="ghost">
          <span class="sw" style="--c:#cdd6ff"></span><b>Metatron ghost</b> · the cube's 13-circle lattice — the shadow of
          the equilibrium
        </button>
        <button class="lg-row" data-g="equilibrium">
          <span class="sw" style="--c:#9fb6ff"></span><b>Vector equilibrium</b> · 12 around 1 · the body that casts the lattice
        </button>
      </div>

      <div class="neural-hud" id="neural-hud">
        <div class="hud-h">Knowledge neural structure · locked</div>
        <div class="hud-m"><span>layers</span><b>0 – 4, mirrored</b></div>
        <div class="hud-m"><span>tuples / layer</span><b>{layerCounts}</b></div>
        <div class="hud-m"><span>layer 1 halo</span><b>1/3 radius</b></div>
        <div class="hud-m"><span>spiral turns</span><b>φ² = {m.spiralTurns.toFixed(3)}</b></div>
        <div class="hud-m"><span>φ · 1/φ</span><b>{m.phi.toFixed(6)} · {m.phiInv.toFixed(6)}</b></div>
        <div class="hud-m"><span>phase lock</span><b id="hud-phase">counter-rotation · synced</b></div>
        <div class="hud-src">source: neural-structure-snapshot.json</div>
      </div>

      <noscript><div class="neural-fallback">This visualization needs JavaScript and WebGL.</div></noscript>
    </section>

    <HubFooter />
  </div>

  <style>
    .neural-stage {
      position: relative;
      width: 100%;
      height: calc(100vh - 64px);
      min-height: 560px;
      overflow: hidden;
      background: radial-gradient(120% 120% at 50% 0%, #10131f 0%, #080910 70%, #05050a 100%);
    }
    #neural-canvas {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
      cursor: grab;
    }
    #neural-canvas:active {
      cursor: grabbing;
    }

    .neural-title {
      position: absolute;
      top: 26px;
      left: 30px;
      max-width: 60%;
      pointer-events: none;
      z-index: 2;
    }
    .neural-eyebrow {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #b79cff;
      margin-bottom: 12px;
    }
    .neural-title h1 {
      font-family: 'DM Serif Display', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 3.6vw, 2.9rem);
      line-height: 1.05;
      color: #eef1f8;
      margin: 0;
      text-wrap: balance;
    }
    .neural-sub {
      font-size: 13px;
      color: #9aa3ba;
      margin-top: 12px;
      line-height: 1.5;
    }
    .neural-sub kbd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 4px;
      padding: 1px 5px;
      color: #cfd6e6;
    }

    .neural-legend {
      position: absolute;
      top: 26px;
      right: 30px;
      z-index: 2;
      background: rgba(14, 12, 24, 0.66);
      border: 1px solid rgba(183, 156, 255, 0.2);
      border-radius: 12px;
      padding: 14px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 9px;
      max-width: 320px;
    }
    .lg-hint {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #7b84a0;
      margin-bottom: 2px;
    }
    .lg-row {
      font-size: 12px;
      color: #b9c0d2;
      display: flex;
      align-items: baseline;
      gap: 9px;
      line-height: 1.35;
      text-align: left;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
      transition: opacity 0.15s ease;
    }
    .lg-row:hover b {
      text-decoration: underline;
    }
    .lg-row.off {
      opacity: 0.32;
    }
    .lg-row.off .sw {
      box-shadow: none;
    }
    .lg-row b {
      color: #eef1f8;
      font-weight: 600;
    }
    .sw {
      width: 10px;
      height: 10px;
      border-radius: 3px;
      flex: none;
      background: var(--c);
      box-shadow: 0 0 10px var(--c);
      transform: translateY(1px);
    }

    .neural-hud {
      position: absolute;
      left: 30px;
      bottom: 26px;
      z-index: 2;
      background: rgba(14, 12, 24, 0.66);
      border: 1px solid rgba(85, 233, 208, 0.2);
      border-radius: 12px;
      padding: 13px 16px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 11.5px;
      color: #9aa3ba;
      display: flex;
      flex-direction: column;
      gap: 5px;
      min-width: 250px;
    }
    .hud-h {
      color: #55e9d0;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 10px;
      margin-bottom: 3px;
    }
    .hud-m {
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }
    .hud-m b {
      color: #eef1f8;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .hud-src {
      color: #59617a;
      font-size: 10px;
      margin-top: 5px;
    }

    .neural-fallback {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: #9aa3ba;
    }

    @media (max-width: 760px) {
      .neural-title {
        max-width: 88%;
        left: 18px;
        top: 18px;
      }
      .neural-legend {
        top: auto;
        bottom: 230px;
        right: 16px;
        padding: 11px 12px;
        max-width: 74%;
      }
      .neural-hud {
        left: 16px;
        right: 16px;
        bottom: 16px;
        min-width: 0;
      }
    }
  </style>

  <script type="application/json" id="neural-snap" set:html={JSON.stringify(snapshot)} />

  <script>
    import * as THREE from 'three';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
    import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
    import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

    interface Layer {
      k: number;
      count: number;
      radius: number;
      y: number;
      tuples: { angleDeg: number; pos: number[] }[];
      lobes: number[][][];
    }
    interface Half {
      sign: number;
      handedness: number;
      singularity: number[];
      layers: Layer[];
      spiral: number[][];
      flower: { k: number; y: number; radius: number; centers: number[][] }[];
    }
    interface Snap {
      meta: { phi: number; phiInv: number; goldenWinding: number; spiralTurns: number };
      halves: Half[];
      envelope: { profile: number[][] };
      lockRing: { radius: number; y: number };
      vessel: { phiSide: number; invSide: number; orbit: number[][]; snapshotAngleRad: number };
      metatronGhost: { circleRadius: number; centers: number[][]; edges: number[][] };
      vectorEquilibrium: { radius: number; vertices: number[][]; edges: number[][] };
      singularity: { radius: number };
    }

    const snap: Snap = JSON.parse((document.getElementById('neural-snap') as HTMLElement).textContent || '{}');
    const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const COL = {
      singularity: 0xffffff,
      spiral: 0x6ea8ff,
      tuple: 0x55e9d0,
      tuplePartner: 0x2fb3a0,
      halo: 0xd0a94e,
      lock: 0xf2ead9,
      flower: 0xe06cff,
      lobe: 0xffe45c,
      thread: 0x55e9d0,
      envelope: 0x7c88b8,
      equilibrium: 0x9fb6ff,
      vessel: 0xb79cff,
      plus: 0xff5cc8,
      minus: 0x5cd8ff,
      bond: 0xd0a94e,
      ghost: 0xcdd6ff,
    };
    const PHI = snap.vessel.phiSide,
      PHI_INV = snap.vessel.invSide,
      WIND = snap.meta.goldenWinding;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 100);
    camera.position.set(3.2, 1.9, 3.8);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.06;
    controls.minDistance = 1.4;
    controls.maxDistance = 18;
    controls.autoRotate = !reduce;
    controls.autoRotateSpeed = 0.36;

    scene.add(new THREE.AmbientLight(0x2a2a50, 1.1));
    const key = new THREE.PointLight(0xaebbff, 40, 40);
    key.position.set(4, 6, 5);
    scene.add(key);
    const rim = new THREE.PointLight(0xd0a94e, 16, 40);
    rim.position.set(-5, -4, -4);
    scene.add(rim);

    const world = new THREE.Group();
    scene.add(world);
    const V3 = (a: number[]) => new THREE.Vector3(a[0], a[1], a[2]);

    function nodeMesh(pos: THREE.Vector3, color: number, radius: number) {
      const mesh = new THREE.Mesh(
        new THREE.SphereGeometry(radius, 20, 20),
        new THREE.MeshStandardMaterial({
          color,
          emissive: color,
          emissiveIntensity: 0.7,
          roughness: 0.35,
          metalness: 0.1,
        })
      );
      mesh.position.copy(pos);
      return mesh;
    }

    // Toggle groups. The two halves counter-rotate to show the phase lock, so
    // per-structure parts live in per-half subgroups that share a toggle group
    // via a registry rather than a common parent.
    const singularities = new THREE.Group();
    const spirals = new THREE.Group();
    const tuples = new THREE.Group();
    const halos = new THREE.Group();
    const flower = new THREE.Group();
    const lobes = new THREE.Group();
    const threads = new THREE.Group();

    // rotating containers, one per half (opposite spin = the phase lock)
    const halfGroups: THREE.Group[] = [];

    for (const half of snap.halves) {
      const hg = new THREE.Group();
      world.add(hg);
      halfGroups.push(hg);

      // per-half subgroups parented into the rotating container but registered
      // under the structure toggle groups via userData
      const hgSing = new THREE.Group();
      const hgSpiral = new THREE.Group();
      const hgTuples = new THREE.Group();
      const hgHalos = new THREE.Group();
      const hgFlower = new THREE.Group();
      const hgLobes = new THREE.Group();
      const hgThreads = new THREE.Group();
      hg.add(hgSing, hgSpiral, hgTuples, hgHalos, hgFlower, hgLobes, hgThreads);
      singularities.userData.parts = [...(singularities.userData.parts || []), hgSing];
      spirals.userData.parts = [...(spirals.userData.parts || []), hgSpiral];
      tuples.userData.parts = [...(tuples.userData.parts || []), hgTuples];
      halos.userData.parts = [...(halos.userData.parts || []), hgHalos];
      flower.userData.parts = [...(flower.userData.parts || []), hgFlower];
      lobes.userData.parts = [...(lobes.userData.parts || []), hgLobes];
      threads.userData.parts = [...(threads.userData.parts || []), hgThreads];

      // ── layer 0: the pole singularity ──
      const sPos = V3(half.singularity);
      const coreR = snap.singularity.radius;
      const core = new THREE.Mesh(
        new THREE.IcosahedronGeometry(coreR, 2),
        new THREE.MeshStandardMaterial({
          color: 0x0c0f1a,
          emissive: 0x241a3a,
          emissiveIntensity: 0.6,
          roughness: 0.5,
          metalness: 0.3,
        })
      );
      core.position.copy(sPos);
      hgSing.add(core);
      const grid = new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(coreR * 1.002, 2)),
        new THREE.LineBasicMaterial({ color: 0x8a9ac8, transparent: true, opacity: 0.45 })
      );
      grid.position.copy(sPos);
      hgSing.add(grid);
      const glowMesh = new THREE.Mesh(
        new THREE.SphereGeometry(coreR * 0.5, 20, 20),
        new THREE.MeshBasicMaterial({ color: COL.singularity })
      );
      glowMesh.position.copy(sPos);
      hgSing.add(glowMesh);

      // ── the toroid spiral, singularity → equator ──
      const spiralPts = half.spiral.map(V3);
      const curve = new THREE.CatmullRomCurve3(spiralPts);
      hgSpiral.add(
        new THREE.Mesh(
          new THREE.TubeGeometry(curve, 320, 0.009, 8, false),
          new THREE.MeshStandardMaterial({
            color: COL.spiral,
            emissive: COL.spiral,
            emissiveIntensity: 0.55,
            roughness: 0.4,
          })
        )
      );

      // ── layers 1-4: halo-bound, singularity-bound tuples ──
      for (const layer of half.layers) {
        const tube = 0.008 + layer.radius * 0.01;
        const torus = new THREE.Mesh(
          new THREE.TorusGeometry(layer.radius, tube, 8, 72),
          new THREE.MeshStandardMaterial({
            color: COL.halo,
            emissive: COL.halo,
            emissiveIntensity: 0.45,
            roughness: 0.4,
          })
        );
        torus.rotation.x = Math.PI / 2;
        torus.position.y = layer.y;
        hgHalos.add(torus);

        for (const t of layer.tuples) {
          const p = V3(t.pos);
          // a tuple is a bound pair: two nodes bonded along the halo's tangent
          const tangent = new THREE.Vector3(-p.z, 0, p.x).normalize().multiplyScalar(0.034);
          const a = p.clone().add(tangent);
          const b = p.clone().sub(tangent);
          hgTuples.add(nodeMesh(a, COL.tuple, 0.03));
          hgTuples.add(nodeMesh(b, COL.tuplePartner, 0.024));
          const bondGeo = new THREE.CylinderGeometry(0.008, 0.008, a.distanceTo(b), 6);
          const bondMesh = new THREE.Mesh(
            bondGeo,
            new THREE.MeshStandardMaterial({
              color: COL.tuple,
              emissive: COL.tuple,
              emissiveIntensity: 0.4,
              roughness: 0.4,
            })
          );
          bondMesh.position.copy(p);
          bondMesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), tangent.clone().normalize());
          hgTuples.add(bondMesh);
          // the shadow path: the straight singularity-bound thread, restored
          // as its own layer alongside the lobes — nothing taken away
          hgThreads.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints([sPos, p]),
              new THREE.LineBasicMaterial({ color: COL.thread, transparent: true, opacity: 0.18 })
            )
          );
        }

        // the lemniscate lobes: one per node, anchored at the layer center,
        // tip at the node, tangent to its counterpart on the same circle —
        // these carry the singularity binding (the shadow threads are gone)
        for (const lobe of layer.lobes) {
          hgLobes.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(lobe.map(V3)),
              new THREE.LineBasicMaterial({ color: COL.lobe, transparent: true, opacity: 0.55 })
            )
          );
        }
      }

      // ── the Flower of Life: one circle per tuple center at every level ──
      const CIRCLE_SEGS = 72;
      for (const level of half.flower) {
        for (const [cx, cz] of level.centers) {
          const pts: THREE.Vector3[] = [];
          for (let s = 0; s <= CIRCLE_SEGS; s++) {
            const a = (2 * Math.PI * s) / CIRCLE_SEGS;
            pts.push(new THREE.Vector3(cx + level.radius * Math.cos(a), level.y, cz + level.radius * Math.sin(a)));
          }
          hgFlower.add(
            new THREE.Line(
              new THREE.BufferGeometry().setFromPoints(pts),
              new THREE.LineBasicMaterial({ color: COL.flower, transparent: true, opacity: 0.32 })
            )
          );
        }
      }
    }

    // ── the lock ring — where the toroid meets its inverse and phase-locks ──
    const lockRing = new THREE.Mesh(
      new THREE.TorusGeometry(snap.lockRing.radius, 0.014, 8, 96),
      new THREE.MeshStandardMaterial({
        color: COL.lock,
        emissive: COL.lock,
        emissiveIntensity: 0.7,
        roughness: 0.3,
      })
    );
    lockRing.rotation.x = Math.PI / 2;
    lockRing.position.y = snap.lockRing.y;
    halos.userData.parts.push(lockRing);
    world.add(lockRing);

    // ── the emission envelope: the hyperbolic hourglass, maxima at the poles ──
    const envelope = new THREE.Group();
    world.add(envelope);
    const envGeo = new THREE.LatheGeometry(
      snap.envelope.profile.map(([r, y]) => new THREE.Vector2(r, y)),
      72
    );
    envelope.add(
      new THREE.Mesh(
        envGeo,
        new THREE.MeshBasicMaterial({
          color: COL.envelope,
          transparent: true,
          opacity: 0.05,
          side: THREE.DoubleSide,
          depthWrite: false,
        })
      )
    );
    envelope.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(envGeo),
        new THREE.LineBasicMaterial({ color: COL.envelope, transparent: true, opacity: 0.07 })
      )
    );

    // ── the ghost Metatron's Cube — the slot the vessel occupies ──
    const ghost = new THREE.Group();
    world.add(ghost);
    const ghostCenters = snap.metatronGhost.centers.map(([x, z]) => new THREE.Vector3(x, 0, z));
    const circleSegs = 40;
    for (const c of ghostCenters) {
      const pts: THREE.Vector3[] = [];
      for (let s = 0; s <= circleSegs; s++) {
        const a = (2 * Math.PI * s) / circleSegs;
        pts.push(
          new THREE.Vector3(
            c.x + snap.metatronGhost.circleRadius * Math.cos(a),
            0,
            c.z + snap.metatronGhost.circleRadius * Math.sin(a)
          )
        );
      }
      ghost.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints(pts),
          new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.1 })
        )
      );
    }
    const ghostLinePts: THREE.Vector3[] = [];
    for (const [i, j] of snap.metatronGhost.edges) {
      ghostLinePts.push(ghostCenters[i], ghostCenters[j]);
    }
    ghost.add(
      new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(ghostLinePts),
        new THREE.LineBasicMaterial({ color: COL.ghost, transparent: true, opacity: 0.06 })
      )
    );

    // ── the vector equilibrium — what the Metatron lattice is a shadow of ──
    // 12 spheres around 1 (cuboctahedron, edge length = circumradius); its
    // plane projection is the 13-circle lattice the ghost draws beneath it.
    const equilibrium = new THREE.Group();
    world.add(equilibrium);
    const veVerts = snap.vectorEquilibrium.vertices.map(V3);
    equilibrium.add(nodeMesh(new THREE.Vector3(0, 0, 0), COL.equilibrium, 0.022));
    for (const v of veVerts) {
      equilibrium.add(nodeMesh(v, COL.equilibrium, 0.018));
      equilibrium.add(
        new THREE.Line(
          new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 0, 0), v]),
          new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.25 })
        )
      );
    }
    const vePts: THREE.Vector3[] = [];
    for (const [i, j] of snap.vectorEquilibrium.edges) {
      vePts.push(veVerts[i], veVerts[j]);
    }
    equilibrium.add(
      new THREE.LineSegments(
        new THREE.BufferGeometry().setFromPoints(vePts),
        new THREE.LineBasicMaterial({ color: COL.equilibrium, transparent: true, opacity: 0.45 })
      )
    );

    // ── the unified-function vessel, seated where the ghost cube sits ──
    const vessel = new THREE.Group();
    world.add(vessel);
    const shellR = 0.5;
    vessel.add(
      new THREE.Mesh(
        new THREE.IcosahedronGeometry(shellR, 1),
        new THREE.MeshPhysicalMaterial({
          color: COL.vessel,
          transparent: true,
          opacity: 0.1,
          roughness: 0.1,
          metalness: 0,
          transmission: 0.6,
          side: THREE.DoubleSide,
        })
      )
    );
    vessel.add(
      new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(shellR, 1)),
        new THREE.LineBasicMaterial({ color: COL.vessel, transparent: true, opacity: 0.32 })
      )
    );
    const orbScale = (shellR * 0.82) / PHI;
    vessel.add(
      new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(
          snap.vessel.orbit.map(([q, p]) => new THREE.Vector3(q * orbScale, p * orbScale, 0))
        ),
        new THREE.LineBasicMaterial({ color: COL.bond, transparent: true, opacity: 0.6 })
      )
    );
    const mPlus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.plus, 0.05);
    vessel.add(mPlus);
    const mMinus = nodeMesh(new THREE.Vector3(0, 0, 0), COL.minus, 0.038);
    vessel.add(mMinus);
    const bond = new THREE.Mesh(
      new THREE.CylinderGeometry(0.01, 0.01, 1, 8),
      new THREE.MeshStandardMaterial({ color: COL.bond, emissive: COL.bond, emissiveIntensity: 0.5, roughness: 0.4 })
    );
    vessel.add(bond);

    function placeMolecule(angle: number) {
      const q = PHI * Math.cos(angle) * orbScale,
        p = PHI_INV * Math.sin(angle) * orbScale;
      mPlus.position.set(q, p, 0);
      mMinus.position.set(-q, -p, 0);
      const a = mPlus.position,
        b = mMinus.position;
      bond.position.copy(a.clone().add(b).multiplyScalar(0.5));
      bond.scale.set(1, a.distanceTo(b), 1);
      bond.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), b.clone().sub(a).normalize());
    }
    placeMolecule(snap.vessel.snapshotAngleRad);

    // ── the selectable legend: toggle structures on/off ──
    // Registry groups hold their scene parts in userData.parts (the halves
    // counter-rotate, so parts can't share one parent).
    const registry: Record<string, THREE.Object3D[]> = {
      singularities: singularities.userData.parts,
      spirals: spirals.userData.parts,
      tuples: tuples.userData.parts,
      halos: halos.userData.parts,
      flower: flower.userData.parts,
      lobes: lobes.userData.parts,
      threads: threads.userData.parts,
      envelope: [envelope],
      equilibrium: [equilibrium],
      vessel: [vessel],
      ghost: [ghost],
    };
    document.querySelectorAll<HTMLButtonElement>('#neural-legend .lg-row').forEach((row) => {
      row.addEventListener('click', () => {
        const parts = registry[row.dataset.g || ''];
        if (!parts) return;
        const nowVisible = !parts[0].visible;
        parts.forEach((p) => {
          p.visible = nowVisible;
        });
        row.classList.toggle('off', !nowVisible);
      });
    });

    // ── post / resize / freeze / animate ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));
    composer.addPass(new UnrealBloomPass(new THREE.Vector2(1, 1), 0.7, 0.6, 0.2));
    composer.addPass(new OutputPass());

    function resize() {
      const w = canvas.clientWidth,
        h = canvas.clientHeight;
      renderer.setSize(w, h, false);
      composer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);
    resize();

    let frozen = false,
      phase = snap.vessel.snapshotAngleRad;
    const hudPhase = document.getElementById('hud-phase');
    window.addEventListener('keydown', (e) => {
      if (e.key === 'f' || e.key === 'F') {
        frozen = !frozen;
        controls.autoRotate = !frozen && !reduce;
        if (hudPhase) hudPhase.textContent = frozen ? 'FROZEN' : 'counter-rotation · synced';
      }
    });

    // phase lock: the two halves counter-rotate at the same rate, driven by the
    // same phase that winds the molecule — freeze stops molecule and lock alike
    const LOCK_SPIN = 0.22;
    function applyPhaseLock(ph: number) {
      halfGroups.forEach((hg, i) => {
        hg.rotation.y = (i === 0 ? 1 : -1) * ph * LOCK_SPIN;
      });
      const beat = 1 - ((((ph / (2 * Math.PI)) % 1) + 1) % 1);
      (lockRing.material as THREE.MeshStandardMaterial).emissiveIntensity = 0.5 + 0.7 * beat * beat;
    }
    applyPhaseLock(phase);

    const clock = new THREE.Clock();
    function frame() {
      const dt = clock.getDelta();
      if (!frozen && !reduce) {
        phase += WIND * dt * 1.6;
        placeMolecule(phase);
        applyPhaseLock(phase);
      }
      vessel.rotation.y += frozen ? 0 : dt * 0.15;
      ghost.rotation.y += frozen ? 0 : -dt * 0.05;
      equilibrium.rotation.y = ghost.rotation.y; // the shadow tracks its body
      controls.update();
      composer.render();
      requestAnimationFrame(frame);
    }
    frame();
  </script>
</Layout>
